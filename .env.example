# =============================================================================
# IMS Monorepo — Root Environment Variables
# =============================================================================
# Copy this file to .env and replace CHANGE_ME values with real credentials.
# For production, use a secret manager (Vault, AWS Secrets Manager, etc.)
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ims
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public

# Domain-specific database URLs (all point to same DB in dev, can be split in production)
CORE_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
HEALTH_SAFETY_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
ENVIRONMENT_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
QUALITY_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
AI_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
INVENTORY_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
HR_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
PAYROLL_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
WORKFLOWS_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
PROJECT_MANAGEMENT_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
