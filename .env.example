PLATFORM_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
MARKETING_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
PARTNER_PORTAL_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
RISK_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
TRAINING_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
SUPPLIERS_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
ASSETS_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
