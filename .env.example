CRM_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
INFOSEC_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
ESG_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
CMMS_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
PORTAL_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
FOOD_SAFETY_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
ENERGY_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public
