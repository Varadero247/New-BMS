# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:4000
CSRF_ENABLED=true

# CORS allowed origins (comma-separated, defaults to localhost:3000-3045)
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# -----------------------------------------------------------------------------
# AI Integration (optional)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Email (optional — required for onboarding/notifications)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=CHANGE_ME
# SENDGRID_API_KEY=

# -----------------------------------------------------------------------------
# Stripe (optional — required for billing)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# HubSpot (optional — required for CRM sync)
# -----------------------------------------------------------------------------
# HUBSPOT_API_KEY=

# -----------------------------------------------------------------------------
# Service Discovery URLs (used by gateway for proxying)
# -----------------------------------------------------------------------------
SERVICE_RISK_URL=http://localhost:4027
SERVICE_TRAINING_URL=http://localhost:4028
SERVICE_SUPPLIERS_URL=http://localhost:4029
SERVICE_ASSETS_URL=http://localhost:4030
SERVICE_DOCUMENTS_URL=http://localhost:4031
SERVICE_COMPLAINTS_URL=http://localhost:4032
SERVICE_CONTRACTS_URL=http://localhost:4033
SERVICE_PTW_URL=http://localhost:4034
SERVICE_REG_MONITOR_URL=http://localhost:4035
SERVICE_INCIDENTS_URL=http://localhost:4036
SERVICE_AUDITS_URL=http://localhost:4037
SERVICE_MGMT_REVIEW_URL=http://localhost:4038
SERVICE_SETUP_WIZARD_URL=http://localhost:4039
SERVICE_CHEMICALS_URL=http://localhost:4040
SERVICE_EMERGENCY_URL=http://localhost:4041

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
