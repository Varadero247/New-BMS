# IMS Environment Configuration Example
# Copy this file to .env and fill in your values
# Run ./scripts/generate-secrets.sh to auto-generate secure secrets

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development

# ===========================================
# DATABASE
# ===========================================
# IMPORTANT: Replace YOUR_SECURE_PASSWORD with a strong password
DATABASE_URL=postgresql://postgres:YOUR_SECURE_PASSWORD@localhost:5432/ims?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD
POSTGRES_DB=ims

# ===========================================
# REDIS (for rate limiting and caching)
# ===========================================
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# IMPORTANT: These must be at least 64 characters in production
# Run ./scripts/generate-secrets.sh to generate secure values
JWT_SECRET=YOUR_SECURE_JWT_SECRET_AT_LEAST_64_CHARACTERS_LONG_REPLACE_THIS
JWT_REFRESH_SECRET=YOUR_SECURE_REFRESH_SECRET_AT_LEAST_64_CHARACTERS_REPLACE
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# SESSION
# ===========================================
SESSION_SECRET=YOUR_SESSION_SECRET

# ===========================================
# API GATEWAY
# ===========================================
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ===========================================
# SERVICE URLs (for local development)
# ===========================================
HEALTH_SAFETY_URL=http://localhost:4001
ENVIRONMENT_URL=http://localhost:4002
QUALITY_URL=http://localhost:4003
AI_ANALYSIS_URL=http://localhost:4004
INVENTORY_URL=http://localhost:4005
HR_URL=http://localhost:4006
PAYROLL_URL=http://localhost:4007
WORKFLOWS_URL=http://localhost:4008

# ===========================================
# FRONTEND
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# MOBILE
# ===========================================
VITE_API_URL=http://localhost:4000/api

# ===========================================
# AI SERVICES (optional)
# ===========================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ===========================================
# HASHICORP VAULT (optional)
# ===========================================
# Enable Vault for secrets management
# USE_VAULT=true
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=your-vault-token
# VAULT_NAMESPACE=
# VAULT_SECRET_PATH=secret/data
# VAULT_TIMEOUT=5000

# ===========================================
# CSRF PROTECTION
# ===========================================
# CSRF is enabled by default. Set to 'false' to disable (dev only)
# CSRF_ENABLED=true

# ===========================================
# INTER-SERVICE AUTHENTICATION
# ===========================================
# Optional separate secret for service-to-service auth
# Falls back to JWT_SECRET if not set
# SERVICE_SECRET=YOUR_SERVICE_SECRET_AT_LEAST_32_CHARACTERS
