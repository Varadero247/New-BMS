{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "uid": "ims-slo-overview",
  "title": "IMS SLO Overview",
  "description": "Multi-window SLO burn rate, availability, and error budget tracking",
  "schemaVersion": 38,
  "version": 1,
  "revision": 1,
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["30s", "1m", "5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "timezone": "browser",
  "fiscalYearStartMonth": 0,
  "tags": ["slo", "ims"],
  "style": "dark",
  "editable": true,
  "graphTooltip": 1,
  "liveNow": false,
  "weekStart": "",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Cluster Availability",
      "description": "Overall cluster availability based on 1-hour rolling window",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cluster:availability:rate1h",
          "instant": true,
          "legendFormat": "Availability",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "text": { "titleSize": 14, "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "min": 0,
          "max": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "red", "value": 0 },
              { "color": "#EAB839", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "color": { "mode": "thresholds" },
          "noValue": "N/A"
        },
        "overrides": []
      },
      "transparent": false,
      "pluginVersion": "10.0.0"
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Error Budget Remaining",
      "description": "Percentage of error budget remaining. Budget is 0.1% error rate (99.9% SLO). Red <10%, yellow <25%, green >=25%.",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "clamp_min(clamp_max((1 - cluster:http_requests_error_ratio:rate1h) / (1 - 0.999) * 100, 100), 0)",
          "instant": true,
          "legendFormat": "Error Budget %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizWidth": 75,
        "minVizHeight": 75,
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "red", "value": 0 },
              { "color": "#EAB839", "value": 10 },
              { "color": "green", "value": 25 }
            ]
          },
          "color": { "mode": "thresholds" },
          "noValue": "N/A"
        },
        "overrides": []
      },
      "transparent": false,
      "pluginVersion": "10.0.0"
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "SLO Burn Rate (1h)",
      "description": "1-hour error ratio burn rate. Threshold at 14.4x (fast burn) and 6x (slow burn). Burn rate exceeding 14.4x consumes monthly error budget in 1 hour.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cluster:http_requests_error_ratio:rate1h",
          "legendFormat": "Error Ratio (1h)",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "Error Ratio",
            "axisColorMode": "text",
            "axisBorderShow": false,
            "scaleDistribution": { "type": "linear" },
            "axisCenteredZero": false,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "line" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.006 },
              { "color": "red", "value": 0.0144 }
            ]
          }
        },
        "overrides": []
      },
      "transparent": false,
      "pluginVersion": "10.0.0"
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "P95 Latency per Service",
      "description": "95th percentile HTTP request duration per service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "job:http_request_duration_seconds:p95",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max", "mean"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "Latency (s)",
            "axisColorMode": "text",
            "axisBorderShow": false,
            "scaleDistribution": { "type": "linear" },
            "axisCenteredZero": false,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        },
        "overrides": []
      },
      "transparent": false,
      "pluginVersion": "10.0.0"
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "P99 Latency per Service",
      "description": "99th percentile HTTP request duration per service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "job:http_request_duration_seconds:p99",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max", "mean"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "Latency (s)",
            "axisColorMode": "text",
            "axisBorderShow": false,
            "scaleDistribution": { "type": "linear" },
            "axisCenteredZero": false,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 1.0 },
              { "color": "red", "value": 2.5 }
            ]
          }
        },
        "overrides": []
      },
      "transparent": false,
      "pluginVersion": "10.0.0"
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error Rate per Service",
      "description": "5-minute rolling error ratio per service job",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "job:http_requests_error_ratio:rate5m",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max", "mean"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "Error Ratio",
            "axisColorMode": "text",
            "axisBorderShow": false,
            "scaleDistribution": { "type": "linear" },
            "axisCenteredZero": false,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "line" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.001 },
              { "color": "red", "value": 0.005 }
            ]
          }
        },
        "overrides": []
      },
      "transparent": false,
      "pluginVersion": "10.0.0"
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request Rate per Service",
      "description": "5-minute rolling request rate per service job (requests per second)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "job:http_requests:rate5m",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max", "mean"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "req/s",
            "axisColorMode": "text",
            "axisBorderShow": false,
            "scaleDistribution": { "type": "linear" },
            "axisCenteredZero": false,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "transparent": false,
      "pluginVersion": "10.0.0"
    },
    {
      "id": 8,
      "type": "table",
      "title": "Availability per Service",
      "description": "1-hour rolling availability per service. Color coded: green >= 99.9%, yellow >= 99.5%, red < 99.5%.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "job:availability:rate1h",
          "instant": true,
          "legendFormat": "{{job}}",
          "refId": "A",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "valueLabel": "job",
            "mode": "columns"
          }
        },
        {
          "id": "reduce",
          "options": {
            "reducers": ["lastNotNull"]
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              { "displayName": "Last *", "desc": true }
            ]
          }
        }
      ],
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": [
          { "displayName": "Value", "desc": true }
        ],
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": ""
        },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 5,
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "color-background",
              "mode": "basic"
            },
            "inspect": false,
            "filterable": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "red", "value": 0 },
              { "color": "#EAB839", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "job" },
            "properties": [
              { "id": "displayName", "value": "Service" },
              { "id": "custom.width", "value": 220 },
              { "id": "custom.cellOptions", "value": { "type": "auto" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Availability (1h)" },
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "__name__" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      },
      "transparent": false,
      "pluginVersion": "10.0.0"
    }
  ]
}
