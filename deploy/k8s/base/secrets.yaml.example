# =============================================================================
# IMS Kubernetes Secrets Template — FINDING-015
#
# USAGE:
#   cp deploy/k8s/base/secrets.yaml.example deploy/k8s/base/secrets.yaml
#   # Fill in all CHANGE_ME values with real credentials
#   kubectl apply -f deploy/k8s/base/secrets.yaml
#
# PRODUCTION RECOMMENDATION:
#   Use External Secrets Operator (ESO) or Sealed Secrets to pull credentials
#   from Vault / AWS Secrets Manager / GCP Secret Manager instead of this file.
#   See: docs/DEPLOYMENT_CHECKLIST.md → "Secrets Management"
#
# Per-service DB users: run scripts/provision-db-users.sh first, then update
# each *_DATABASE_URL below with its dedicated role password.
#
# SECURITY: deploy/k8s/base/secrets.yaml is in .gitignore.
#           NEVER commit a populated secrets.yaml to version control.
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: ims-secrets
  namespace: ims
type: Opaque
stringData:
  # Database
  DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  CORE_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  HR_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  PAYROLL_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  QUALITY_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  HEALTH_SAFETY_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  ENVIRONMENT_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  INVENTORY_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  WORKFLOWS_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  AI_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  PROJECT_MANAGEMENT_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  AUTOMOTIVE_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  MEDICAL_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  AEROSPACE_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  FINANCE_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  CRM_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  INFOSEC_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  ESG_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  CMMS_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  PORTAL_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  FOOD_SAFETY_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  ENERGY_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  ANALYTICS_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  FIELD_SERVICE_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  ISO42001_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  ISO37001_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  MARKETING_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  PARTNERS_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  RISK_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  TRAINING_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  SUPPLIERS_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  ASSETS_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  DOCUMENTS_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  COMPLAINTS_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  CONTRACTS_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  PTW_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  REG_MONITOR_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  INCIDENTS_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  AUDITS_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  MGMT_REVIEW_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  WIZARD_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  CHEMICALS_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  EMERGENCY_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  PARTNER_PORTAL_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  MARKETPLACE_DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgresql:5432/ims?schema=public"
  POSTGRES_PASSWORD: "CHANGE_ME"

  # JWT
  JWT_SECRET: "CHANGE_ME_TO_A_SECURE_64_CHARACTER_RANDOM_STRING_FOR_PRODUCTION"
  JWT_REFRESH_SECRET: "CHANGE_ME_TO_ANOTHER_SECURE_64_CHARACTER_STRING_FOR_REFRESH"
  SERVICE_SECRET: "CHANGE_ME_TO_A_SECURE_32_CHARACTER_STRING_FOR_SERVICES"

  # Redis
  REDIS_URL: "redis://:${REDIS_PASSWORD}@redis:6379"
  REDIS_PASSWORD: "CHANGE_ME"

  # Session — generate with: openssl rand -base64 32
  SESSION_SECRET: "CHANGE_ME_TO_A_SECURE_SESSION_SECRET"

  # Sentry Error Tracking — obtain from https://sentry.io/settings/projects/
  SENTRY_DSN: ""

  # Vault (optional) — for HashiCorp Vault integration
  VAULT_TOKEN: ""
