{
  "id": "food-safety-brcgs",
  "name": "Food Manufacturing — BRCGS Food Safety Issue 9",
  "version": "1.0.0",
  "standards": ["BRCGS Food Safety Issue 9", "ISO 22000:2018", "HACCP Codex Alimentarius"],
