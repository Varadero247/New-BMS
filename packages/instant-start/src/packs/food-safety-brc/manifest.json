    {
      "key": "brcgsGrade",
      "label": "Target BRCGS Grade",
      "type": "select",
      "required": false,
      "options": ["AA", "A", "B", "C"]
    },
    {
      "key": "enableAllergens",
      "label": "Enable allergen management module",
      "type": "boolean",
      "required": false
    },
    {
      "key": "productionType",
      "label": "Production Environment",
      "type": "select",
      "required": false,
      "options": ["Ambient", "Chilled", "Frozen", "Ambient High Care", "High Care", "High Risk"]
    }
  ]
