{
  "id": "professional-services-iso27001",
  "name": "Professional Services — ISO 27001:2022 + GDPR",
  "version": "1.0.0",
  "standards": ["ISO 27001:2022", "ISO 27002:2022", "UK GDPR", "EU GDPR"],
  "estimatedSetupMinutes": 30,
  "description": "Pre-configured information security management pack for professional services, SaaS companies, and consultancies. Includes 93 ISO 27002:2022 controls, GDPR data processing workflows, DSAR management, and supplier due diligence.",
  "targetCustomer": "Consultancies, SaaS companies, fintech, legal firms, accountancies",
  "includes": {
    "riskCategories": 20,
    "documentTypes": 24,
    "workflowTemplates": 14,
    "auditChecklists": 6,
    "kpis": 16
  },
  "prerequisites": ["InfoSec module enabled"],
  "customisationOptions": [
    {
      "key": "dataResidency",
      "label": "Primary Data Residency",
      "type": "select",
      "required": false,
      "options": ["UK", "EU", "USA", "Multi-region"]
    },
    {
      "key": "enableGdpr",
      "label": "Enable GDPR / UK GDPR workflows",
      "type": "boolean",
      "required": false
    },
    {
      "key": "enableBcm",
      "label": "Enable Business Continuity (ISO 22301)",
      "type": "boolean",
      "required": false
    },
    {
      "key": "cloudProvider",
      "label": "Primary Cloud Provider",
      "type": "select",
      "required": false,
      "options": ["AWS", "Azure", "GCP", "On-premise", "Hybrid"]
    }
  ]
}
