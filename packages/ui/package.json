{
  "name": "@ims/ui",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind-preset": {
      "import": "./tailwind-preset.ts",
      "require": "./tailwind-preset.ts"
    },
    "./tokens": {
      "import": "./src/tokens.ts",
      "require": "./src/tokens.ts"
    },
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./globals.css": "./globals.css"
  },
  "scripts": {
    "build": "tsup --no-dts",
    "dev": "tsup --watch --no-dts",
    "clean": "rm -rf dist node_modules .turbo",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@ims/presence": "workspace:*",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.15",
    "@storybook/react-vite": "^8.6.15",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.15",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.21"
  },
  "peerDependencies": {
    "lucide-react": ">=0.300.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    }
  }
}