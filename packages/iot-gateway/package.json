{
  "name": "@ims/iot-gateway",
  "version": "1.0.0",
  "description": "IoT device registry, normalizer and threshold-alert engine for Nexara IMS",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "jest"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "isolatedModules": true,
        "diagnostics": false
      }]
    }
  }
}
