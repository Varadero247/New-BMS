{
  "name": "@ims/ai-container",
  "version": "1.0.0",
  "description": "Secure AI containerisation with input/output validation, rate limiting, and immutable audit logging",
  "main": "src/index.ts",
  "scripts": {
    "test": "jest",
    "build": "tsc"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "isolatedModules": true, "diagnostics": false }]
    },
    "moduleNameMapper": {
      "^@anthropic-ai/sdk$": "<rootDir>/__mocks__/@anthropic-ai/sdk.js"
    }
  }
}
