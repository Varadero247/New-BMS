{
  "name": "@ims/migration-assistant",
  "version": "1.0.0",
  "description": "AI-powered data migration mapping assistant for Nexara IMS",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "node --max-old-space-size=4096 ../../node_modules/jest/bin/jest.js --runInBand --no-coverage"
  },
  "dependencies": {
    "@ims/monitoring": "workspace:*",
    "zod": "^3.22.4",
    "csv-parse": "^5.5.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.0.0",
    "ts-jest": "^29.1.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "tsconfig": "tsconfig.json",
        "isolatedModules": true,
        "diagnostics": false
      }]
    }
  }
}
