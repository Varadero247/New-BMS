{
  "name": "@ims/email",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --no-dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@ims/monitoring": "workspace:*",
    "nodemailer": "^7.0.11"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
