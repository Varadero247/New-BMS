model ChangeRequest {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  changeNumber      String @unique

  // Basic info
  title             String
  description       String
  justification     String?

  // Classification
  changeType        ChangeType
  category          ChangeCategory?
  priority          ChangePriority       @default(MEDIUM)

  // Scope
  affectedItems     Json?                // Array of affected items with type

  // Linked documents
  documentId        String?              @db.Uuid

  // Initiator
  requestedById     String
  requestedAt       DateTime             @default(now())
  department        String?

  // Risk assessment
  riskLevel         RiskLevel?
  riskAssessment    Json?

  // Status
  status            ChangeStatus         @default(DRAFT)

  // Key dates
  targetDate        DateTime?
  effectiveDate     DateTime?
  actualCompletionDate DateTime?

  // Financial
  estimatedCost     Float?
  actualCost        Float?

  // Metadata
  metadata          Json?
  attachments       Json?

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  // Relations
  approvals         ChangeApproval[]
  impacts           ChangeImpact[]
  implementations   ChangeImplementation[]
  document          QMSDocument?         @relation("DocumentChangeRequests", fields: [documentId], references: [id])

  @@index([changeNumber])
  @@index([status])
  @@index([changeType])
  @@map("change_requests")
}

model ChangeApproval {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  changeRequestId   String @db.Uuid

  // Approval workflow
  approvalLevel     Int                  @default(1)
  approverId        String
  approverRole      String?

  // CCB (Change Control Board) info
  isCCBMember       Boolean              @default(false)

  // Decision
  status            ApprovalStatus       @default(PENDING)
  decision          ApprovalDecision?
  comments          String?
  conditions        String[]

  // Timestamps
  requestedAt       DateTime             @default(now())
  respondedAt       DateTime?
  dueDate           DateTime?

  // Relations
  changeRequest     ChangeRequest        @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)

  @@index([changeRequestId])
  @@index([approverId])
  @@map("change_approvals")
}

model ChangeImpact {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  changeRequestId   String @db.Uuid

  // Impact details
  impactArea        ImpactArea
  impactDescription String
  severity          ImpactSeverity       @default(MODERATE)

  // Affected entities
  affectedEntity    String?
  affectedEntityId  String?

  // Mitigation
  mitigationRequired Boolean             @default(false)
  mitigationPlan    String?

  // Required actions
  actionsRequired   Json?

  // Training impact
  trainingRequired  Boolean              @default(false)
  trainingNotes     String?

  // Documentation impact
  documentationChanges String[]

  // Assessment
  assessedById      String?
  assessedAt        DateTime?

  // Relations
  changeRequest     ChangeRequest        @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)

  @@index([changeRequestId])
  @@map("change_impacts")
}

model ChangeImplementation {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  changeRequestId   String @db.Uuid

  // Task info
  taskNumber        Int
  description       String

  // Assignment
  assignedToId      String?
  department        String?

  // Timeline
  plannedStartDate  DateTime?
  plannedEndDate    DateTime?
  actualStartDate   DateTime?
  actualEndDate     DateTime?

  // Status
  status            ImplementationStatus @default(PLANNED)

  // Verification
  verificationMethod String?
  verifiedById      String?
  verifiedAt        DateTime?
  verificationResult String?

  // Evidence
  evidence          Json?

  // Notes
  notes             String?

  // Relations
  changeRequest     ChangeRequest        @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)

  @@index([changeRequestId])
  @@map("change_implementations")
}

enum ChangeType {
