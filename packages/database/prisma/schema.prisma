  department          HRDepartment @relation(fields: [departmentId], references: [id])
  position            Position? @relation(fields: [positionId], references: [id])
  applicants          Applicant[]
  interviews          Interview[]

  @@index([departmentId])
  @@index([status])
  @@map("hr_job_postings")
}

model Applicant {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicantNumber     String @unique
  jobPostingId        String @db.Uuid

  // Personal Info
  firstName           String
  lastName            String
  email               String
  phone               String?
  linkedinUrl         String?

  // Application
  coverLetter         String?
  resumeUrl           String?
  portfolioUrl        String?
  source              ApplicationSource
  referredBy          String?

  // Experience
  currentCompany      String?
  currentTitle        String?
  yearsExperience     Int?
  noticePeriod        Int?  // days
  expectedSalary      Float?
  salaryCurrency      String @default("USD")

  // Screening
  screeningScore      Int?
  screeningNotes      String?

  // Status
  status              ApplicantStatus @default(NEW)
  stage               RecruitmentStage @default(APPLICATION)
  rejectionReason     String?

  // Assessment scores
  assessmentScores    Json?  // {"technical": 80, "cultural": 90}

  // Offer
  offerExtended       DateTime?
  offerAccepted       DateTime?
  offerRejected       DateTime?
  startDate           DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  jobPosting          JobPosting @relation(fields: [jobPostingId], references: [id])
  interviews          Interview[]
  evaluations         InterviewEvaluation[]

  @@index([jobPostingId])
  @@index([status])
  @@index([email])
  @@map("hr_applicants")
}

model Interview {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicantId         String @db.Uuid
  jobPostingId        String @db.Uuid
  round               Int @default(1)
  interviewType       InterviewType

  // Schedule
  scheduledAt         DateTime
  duration            Int @default(60)  // minutes
  location            String?
  meetingUrl          String?
  timezone            String @default("UTC")

  // Interviewers
  interviewerIds      String[]
  organizerId         String

  // Status
  status              InterviewStatus @default(SCHEDULED)
  actualStartTime     DateTime?
  actualEndTime       DateTime?
  cancelledReason     String?

  // Notes
  agenda              String?
  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  applicant           Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  jobPosting          JobPosting @relation(fields: [jobPostingId], references: [id])
  evaluations         InterviewEvaluation[]

  @@index([applicantId])
  @@index([jobPostingId])
  @@index([scheduledAt])
  @@map("hr_interviews")
}

model InterviewEvaluation {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId         String @db.Uuid
  applicantId         String @db.Uuid
  evaluatorId         String

  // Ratings
  overallRating       Int  // 1-5
  technicalRating     Int?
  communicationRating Int?
  cultureFitRating    Int?
  leadershipRating    Int?

  // Detailed assessment
  strengths           String?
  concerns            String?
  additionalNotes     String?

  // Recommendation
  recommendation      HiringRecommendation
  recommendedSalary   Float?

  submittedAt         DateTime @default(now())

  // Relations
  interview           Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  applicant           Applicant @relation(fields: [applicantId], references: [id])

  @@unique([interviewId, evaluatorId])
  @@index([interviewId])
  @@index([applicantId])
  @@map("hr_interview_evaluations")
}

// ============================================
// EMPLOYEE DOCUMENTS & QUALIFICATIONS
// ============================================

model EmployeeDocument {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId          String @db.Uuid
  documentType        EmployeeDocumentType
  title               String
  description         String?

  // File info
  fileName            String
  fileUrl             String
  fileSize            Int?
  mimeType            String?

  // Version control
  version             Int @default(1)
  previousVersionId   String? @db.Uuid

  // Validity
  issueDate           DateTime?
  expiryDate          DateTime?
  issuingAuthority    String?
  documentNumber      String?

  // Status
  status              DocumentStatus @default(ACTIVE)
  verifiedById        String?
  verifiedAt          DateTime?

  // E-signature
  requiresSignature   Boolean @default(false)
  signedAt            DateTime?
  signatureUrl        String?

  // Privacy
  isConfidential      Boolean @default(false)
  accessRoles         String[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

  // Relations
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([documentType])
  @@index([expiryDate])
  @@map("hr_employee_documents")
}

model EmployeeQualification {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId          String @db.Uuid
  qualificationType   QualificationType

  // Education details
  institution         String
  degree              String?
  fieldOfStudy        String?
  grade               String?

  // Dates
  startDate           DateTime?
  endDate             DateTime?
  isOngoing           Boolean @default(false)

  // Verification
  documentUrl         String?
  isVerified          Boolean @default(false)
  verifiedById        String?
  verifiedAt          DateTime?

  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("hr_employee_qualifications")
}

model EmployeeCertification {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId          String @db.Uuid
  name                String
  issuingOrganization String
  credentialId        String?
  credentialUrl       String?

  issueDate           DateTime
  expiryDate          DateTime?
  doesNotExpire       Boolean @default(false)

  // Renewal
  renewalRequired     Boolean @default(false)
  renewalReminderDays Int?

  // Verification
  certificateUrl      String?
  status              CertificationStatus @default(ACTIVE)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([expiryDate])
  @@map("hr_employee_certifications")
}

model EmployeeAsset {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId          String @db.Uuid
  assetTag            String @unique
  assetType           AssetType
  name                String
  description         String?
  serialNumber        String?
  model               String?
  manufacturer        String?

  // Assignment
  assignedDate        DateTime
  returnDate          DateTime?
  returnCondition     String?

  // Value
  purchaseValue       Float?
  currentValue        Float?
  currency            String @default("USD")

  // Condition
  condition           AssetCondition @default(GOOD)
  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  employee            Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("hr_employee_assets")
}

model DisciplinaryAction {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId          String @db.Uuid
  caseNumber          String @unique

  // Incident
  incidentDate        DateTime
  incidentDescription String
  category            DisciplinaryCategory
  severity            DisciplinarySeverity

  // Investigation
  investigatorId      String?
  investigationNotes  String?
