model BenefitPlan {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String @unique
  name                String
  description         String?
  category            BenefitCategory
  provider            String?

  // Coverage options
  coverageLevels      CoverageLevel[]
  dependentsCoverage  Boolean @default(false)

  // Costs
  employeeContribution Float?
  employerContribution Float?
  contributionType    ComponentCalculationType @default(FIXED)

