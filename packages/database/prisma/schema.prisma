  likelihood        Int                  // 1-5
  impact            Int                  // 1-5
  riskScore         Int                  // L x I
  riskLevel         QMSRiskLevel

  // Detailed scoring (optional)
  likelihoodFactors Json?                // Breakdown of likelihood factors
  impactFactors     Json?                // Breakdown of impact (financial, operational, etc.)

  // Assessment notes
  rationale         String?
  assumptions       String?
  uncertainties     String?

  // Trend
  trendDirection    TrendDirection?
  previousScore     Int?

  // Audit fields
  createdAt         DateTime             @default(now())

  // Relations
  risk              QMSRisk              @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@index([riskId])
  @@index([assessmentDate])
  @@map("risk_assessments")
}

model RiskControl {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  riskId            String @db.Uuid

  // Control info
  title             String
  description       String
