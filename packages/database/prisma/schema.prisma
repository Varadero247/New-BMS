model ChangeRequest {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  changeNumber      String @unique

  // Basic info
  title             String
  description       String
  justification     String?

  // Classification
  changeType        ChangeType
  category          ChangeCategory?
  priority          ChangePriority       @default(MEDIUM)

  // Scope
  affectedItems     Json?                // Array of affected items with type

  // Linked documents
  documentId        String?              @db.Uuid

  // Initiator
  requestedById     String
  requestedAt       DateTime             @default(now())
  department        String?

  // Risk assessment
  riskLevel         RiskLevel?
  riskAssessment    Json?

  // Status
  status            ChangeStatus         @default(DRAFT)

  // Key dates
  targetDate        DateTime?
  effectiveDate     DateTime?
  actualCompletionDate DateTime?

  // Financial
  estimatedCost     Float?
  actualCost        Float?

  // Metadata
  metadata          Json?
  attachments       Json?

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  // Relations
  approvals         ChangeApproval[]
  impacts           ChangeImpact[]
  implementations   ChangeImplementation[]
  document          QMSDocument?         @relation("DocumentChangeRequests", fields: [documentId], references: [id])

  @@index([changeNumber])
  @@index([status])
  @@index([changeType])
  @@map("change_requests")
}

model ChangeApproval {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  changeRequestId   String @db.Uuid

  // Approval workflow
  approvalLevel     Int                  @default(1)
  approverId        String
  approverRole      String?

  // CCB (Change Control Board) info
  isCCBMember       Boolean              @default(false)

  // Decision
  status            ApprovalStatus       @default(PENDING)
  decision          ApprovalDecision?
  comments          String?
  conditions        String[]

  // Timestamps
  requestedAt       DateTime             @default(now())
  respondedAt       DateTime?
  dueDate           DateTime?

  // Relations
  changeRequest     ChangeRequest        @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)

  @@index([changeRequestId])
  @@index([approverId])
  @@map("change_approvals")
}

model ChangeImpact {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  changeRequestId   String @db.Uuid

  // Impact details
  impactArea        ImpactArea
  impactDescription String
  severity          ImpactSeverity       @default(MODERATE)

  // Affected entities
  affectedEntity    String?
  affectedEntityId  String?

  // Mitigation
  mitigationRequired Boolean             @default(false)
  mitigationPlan    String?

  // Required actions
  actionsRequired   Json?

  // Training impact
  trainingRequired  Boolean              @default(false)
  trainingNotes     String?

  // Documentation impact
  documentationChanges String[]

  // Assessment
  assessedById      String?
  assessedAt        DateTime?

  // Relations
  changeRequest     ChangeRequest        @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)

  @@index([changeRequestId])
  @@map("change_impacts")
}

model ChangeImplementation {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  changeRequestId   String @db.Uuid

  // Task info
  taskNumber        Int
  description       String

  // Assignment
  assignedToId      String?
  department        String?

  // Timeline
  plannedStartDate  DateTime?
  plannedEndDate    DateTime?
  actualStartDate   DateTime?
  actualEndDate     DateTime?

  // Status
  status            ImplementationStatus @default(PLANNED)

  // Verification
  verificationMethod String?
  verifiedById      String?
  verifiedAt        DateTime?
  verificationResult String?

  // Evidence
  evidence          Json?

  // Notes
  notes             String?

  // Relations
  changeRequest     ChangeRequest        @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)

  @@index([changeRequestId])
  @@map("change_implementations")
}

enum ChangeType {
  PRODUCT
  PROCESS
  DOCUMENT
  SYSTEM
  SUPPLIER
  EQUIPMENT
  MATERIAL
  ORGANIZATIONAL
}

enum ChangeCategory {
  DESIGN
  MANUFACTURING
  QUALITY
  SAFETY
  REGULATORY
  CUSTOMER_DRIVEN
  COST_REDUCTION
  IMPROVEMENT
}

enum ChangePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
  EMERGENCY
}

enum ChangeStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  IMPACT_ASSESSMENT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  IN_IMPLEMENTATION
  VERIFICATION
  COMPLETED
  CANCELLED
}

enum ImpactArea {
  QUALITY
  SAFETY
  REGULATORY
  FINANCIAL
  OPERATIONAL
  CUSTOMER
  SUPPLY_CHAIN
  DOCUMENTATION
  TRAINING
  EQUIPMENT
  PERSONNEL
}

enum ImpactSeverity {
  NEGLIGIBLE
  MINOR
  MODERATE
  MAJOR
  CRITICAL
}

// ============================================
// HR MANAGEMENT MODELS
// ============================================

model Employee {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeNumber      String @unique
  userId              String? @unique  // Link to User for self-service portal

  // Personal Information
  firstName           String
  middleName          String?
  lastName            String
  dateOfBirth         DateTime?
  gender              Gender?
  nationalId          String?
  nationality         String?
  maritalStatus       MaritalStatus?
  bloodGroup          String?

  // Contact Information
  personalEmail       String?
  workEmail           String @unique
  phone               String?
  mobilePhone         String?
  emergencyContact    String?
  emergencyPhone      String?

  // Address
  currentAddress      String?
  permanentAddress    String?
  city                String?
  state               String?
  country             String?
  postalCode          String?

  // Employment Details
  departmentId        String @db.Uuid
  positionId          String? @db.Uuid
  managerId           String? @db.Uuid
  employmentType      EmploymentType @default(FULL_TIME)
  employmentStatus    EmploymentStatus @default(ACTIVE)
  hireDate            DateTime
  confirmationDate    DateTime?
  terminationDate     DateTime?
  terminationReason   String?

  // Job Details
  jobTitle            String
  jobGrade            String?
  workLocation        String?
  costCenter          String?

  // Compensation (basic info - detailed in Payroll)
  currency            String @default("USD")
  payFrequency        PayFrequency @default(MONTHLY)

  // Bank Details
  bankName            String?
  bankBranch          String?
  accountNumber       String?
  accountName         String?
  routingNumber       String?

  // Documents
  profilePhoto        String?
  signatureFile       String?

  // Probation
  probationPeriod     Int? // months
  probationEndDate    DateTime?

  // Work Schedule
  shiftId             String? @db.Uuid
  workHoursPerWeek    Float @default(40)

  // Metadata
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?
  updatedBy           String?

  // Relations
  department          HRDepartment @relation(fields: [departmentId], references: [id])
  position            Position? @relation(fields: [positionId], references: [id])
  manager             Employee? @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates        Employee[] @relation("ManagerSubordinates")
  shift               WorkShift? @relation(fields: [shiftId], references: [id])

  attendances         Attendance[]
  leaveRequests       LeaveRequest[]
  leaveBalances       LeaveBalance[]
  performanceReviews  PerformanceReview[] @relation("EmployeeReviews")
  conductedReviews    PerformanceReview[] @relation("ReviewerReviews")
  performanceGoals    PerformanceGoal[]
  documents           EmployeeDocument[]
  qualifications      EmployeeQualification[]
  salaryRecords       EmployeeSalary[]
  benefits            EmployeeBenefit[]
  expenses            Expense[]
  payslips            Payslip[]
  loans               EmployeeLoan[]
  disciplinaryActions DisciplinaryAction[]
  trainingEnrollments HRTrainingEnrollment[]
  certifications      EmployeeCertification[]
  assets              EmployeeAsset[]

  // Workflow relations
  workflowInstances   WorkflowInstance[] @relation("WorkflowInitiator")
  workflowApprovals   WorkflowStepApproval[]
  workflowTasks       WorkflowTask[]

  @@index([departmentId])
  @@index([managerId])
  @@index([employmentStatus])
  @@index([workEmail])
  @@map("hr_employees")
}

model HRDepartment {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String @unique
  name                String
  description         String?
  parentId            String? @db.Uuid
  headId              String? @db.Uuid  // Department Head Employee ID
  costCenter          String?
  budget              Float?
  budgetCurrency      String @default("USD")
  isActive            Boolean @default(true)
  sortOrder           Int @default(0)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  parent              HRDepartment? @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children            HRDepartment[] @relation("DepartmentHierarchy")
  employees           Employee[]
  positions           Position[]
  jobPostings         JobPosting[]

  @@index([parentId])
  @@map("hr_departments")
}

model Position {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String @unique
  title               String
  description         String?
  departmentId        String @db.Uuid
  jobGrade            String?
  minSalary           Float?
  maxSalary           Float?
  currency            String @default("USD")
  headcount           Int @default(1)
  filledCount         Int @default(0)
  requirements        String?
  responsibilities    String?
  isActive            Boolean @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  department          HRDepartment @relation(fields: [departmentId], references: [id])
  employees           Employee[]
  jobPostings         JobPosting[]

  @@index([departmentId])
  @@map("hr_positions")
}

model WorkShift {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  code                String @unique
  description         String?

  // Timing
  startTime           String  // HH:MM format
  endTime             String
  breakDuration       Int @default(60)  // minutes
  workingHours        Float

  // Days
  monday              Boolean @default(true)
  tuesday             Boolean @default(true)
  wednesday           Boolean @default(true)
  thursday            Boolean @default(true)
  friday              Boolean @default(true)
  saturday            Boolean @default(false)
  sunday              Boolean @default(false)

  // Overtime rules
  overtimeThreshold   Float?  // hours
  overtimeMultiplier  Float @default(1.5)

  isActive            Boolean @default(true)
  isNightShift        Boolean @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  employees           Employee[]
  attendances         Attendance[]

  @@map("hr_work_shifts")
}

// ============================================
// ATTENDANCE & TIME TRACKING
// ============================================

model Attendance {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId          String @db.Uuid
  date                DateTime @db.Date
  shiftId             String? @db.Uuid

  // Clock Times
  clockIn             DateTime?
  clockOut            DateTime?
  clockInLocation     String?
  clockOutLocation    String?
  clockInMethod       ClockMethod?
  clockOutMethod      ClockMethod?

  // Calculated Hours
  scheduledHours      Float?
  workedHours         Float?
  overtimeHours       Float?
  breakDuration       Int?  // minutes

  // Late/Early tracking
  lateMinutes         Int @default(0)
  earlyDepartureMin   Int @default(0)

  // Status
  status              AttendanceStatus @default(PRESENT)
  isHoliday           Boolean @default(false)
  holidayName         String?

  // Approval
  approvalStatus      ApprovalStatus @default(PENDING)
  approvedById        String?
  approvedAt          DateTime?
  approvalNotes       String?

  // Notes
  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift               WorkShift? @relation(fields: [shiftId], references: [id])
  timesheetEntries    TimesheetEntry[]

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([status])
  @@map("hr_attendances")
}

model TimesheetEntry {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attendanceId        String @db.Uuid
  employeeId          String @db.Uuid

  // Task/Project details
  projectCode         String?
  projectName         String?
  taskDescription     String
  category            String?

  // Hours
  hours               Float
  startTime           DateTime?
  endTime             DateTime?

  // Billing
  isBillable          Boolean @default(false)
  billingRate         Float?
  billingCurrency     String @default("USD")

  // Approval
  approvalStatus      ApprovalStatus @default(PENDING)
  approvedById        String?
  approvedAt          DateTime?

  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  attendance          Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([employeeId])
  @@map("hr_timesheet_entries")
}

// ============================================
// LEAVE MANAGEMENT
// ============================================

model LeaveType {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String @unique
  name                String
  description         String?
  category            LeaveCategory
  color               String?

  // Entitlement settings
  defaultDaysPerYear  Float @default(0)
  maxCarryForward     Float @default(0)
  maxAccumulation     Float?
  minServiceDays      Int @default(0)  // days required before eligible

  // Rules
  isPaid              Boolean @default(true)
  requiresApproval    Boolean @default(true)
  requiresDocument    Boolean @default(false)
  allowHalfDay        Boolean @default(true)
  allowNegative       Boolean @default(false)
  encashable          Boolean @default(false)

  // Applicable to
  applicableGenders   Gender[]
  minNoticeDays       Int @default(0)

  isActive            Boolean @default(true)
  sortOrder           Int @default(0)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  leaveRequests       LeaveRequest[]
  leaveBalances       LeaveBalance[]
  policies            LeavePolicyRule[]

  @@map("hr_leave_types")
}

model LeaveBalance {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId          String @db.Uuid
  leaveTypeId         String @db.Uuid
  year                Int

  // Balance tracking
  entitled            Float @default(0)
  carryForward        Float @default(0)
  adjustment          Float @default(0)
  taken               Float @default(0)
  pending             Float @default(0)
  balance             Float @default(0)  // Calculated: entitled + carryForward + adjustment - taken - pending

  // Encashment
  encashed            Float @default(0)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType           LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
  @@map("hr_leave_balances")
}

model LeaveRequest {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestNumber       String @unique
  employeeId          String @db.Uuid
  leaveTypeId         String @db.Uuid

  // Dates
  startDate           DateTime @db.Date
  endDate             DateTime @db.Date
  days                Float
  isHalfDay           Boolean @default(false)
  halfDayPeriod       HalfDayPeriod?

  // Details
  reason              String?
  contactDuring       String?
  emergencyPhone      String?

  // Handover
  handoverToId        String? @db.Uuid
  handoverNotes       String?

  // Documents
  attachments         Json?  // Array of file URLs

  // Status
  status              LeaveRequestStatus @default(PENDING)
  cancelledAt         DateTime?
  cancellationReason  String?

  // Approval workflow
  currentApprovalStep Int @default(1)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType           LeaveType @relation(fields: [leaveTypeId], references: [id])
  approvals           LeaveApproval[]

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("hr_leave_requests")
}

model LeaveApproval {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leaveRequestId      String @db.Uuid
  approverEmployeeId  String @db.Uuid
  step                Int @default(1)

  // Decision
  status              ApprovalStatus @default(PENDING)
  decision            ApprovalDecision?
  decidedAt           DateTime?
  comments            String?

  // Delegation
  delegatedFromId     String? @db.Uuid
  delegatedReason     String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  leaveRequest        LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  @@index([leaveRequestId])
  @@index([approverEmployeeId])
  @@map("hr_leave_approvals")
}

model LeavePolicyRule {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leaveTypeId         String @db.Uuid
  name                String
  description         String?

  // Conditions
  minServiceMonths    Int?
  maxServiceMonths    Int?
  employmentTypes     EmploymentType[]
  departments         String[]  // Department IDs
  jobGrades           String[]

  // Entitlement
  daysPerYear         Float
  accrualType         AccrualType @default(ANNUAL)

  isActive            Boolean @default(true)
  effectiveFrom       DateTime
  effectiveTo         DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  leaveType           LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([leaveTypeId])
  @@map("hr_leave_policy_rules")
}

model Holiday {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  date                DateTime @db.Date
  year                Int
  type                HolidayType
  isFloating          Boolean @default(false)
  applicableLocations String[]
  description         String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([name, year])
  @@index([year])
  @@index([date])
  @@map("hr_holidays")
}

// ============================================
// PERFORMANCE MANAGEMENT
// ============================================

model PerformanceCycle {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  year                Int
  cycleType           PerformanceCycleType
  startDate           DateTime
  endDate             DateTime

  // Configuration
  goalSettingStart    DateTime?
  goalSettingEnd      DateTime?
  midYearReviewStart  DateTime?
  midYearReviewEnd    DateTime?
  annualReviewStart   DateTime?
  annualReviewEnd     DateTime?

  // Rating scale
  ratingScale         Int @default(5)  // 1-5 or 1-10
  ratingLabels        Json?  // {"1": "Needs Improvement", "2": "Meets Expectations", ...}

  status              CycleStatus @default(DRAFT)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  reviews             PerformanceReview[]
  goals               PerformanceGoal[]

  @@unique([name, year])
  @@map("hr_performance_cycles")
}

model PerformanceReview {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycleId             String @db.Uuid
  employeeId          String @db.Uuid
  reviewerId          String @db.Uuid
  reviewType          ReviewType

  // Review Period
  periodStart         DateTime
  periodEnd           DateTime

  // Self Assessment
  selfAssessment      String?
  selfRating          Int?
  selfRatingDate      DateTime?

  // Manager Review
  managerAssessment   String?
  managerRating       Int?
  managerRatingDate   DateTime?

  // Competency Ratings
  competencyRatings   Json?  // {"technical": 4, "communication": 5, ...}

  // Goal Achievement
  goalsAchievement    Float?  // percentage
  goalsNotes          String?

  // Overall
  overallRating       Int?
  overallComments     String?
  strengths           String?
  improvementAreas    String?
  developmentPlan     String?

  // Calibration
  calibratedRating    Int?
  calibrationNotes    String?
  calibratedById      String?
  calibratedAt        DateTime?

  // Acknowledgment
  employeeAcknowledged Boolean @default(false)
  acknowledgedAt      DateTime?
  employeeComments    String?

  status              ReviewStatus @default(DRAFT)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  cycle               PerformanceCycle @relation(fields: [cycleId], references: [id])
  employee            Employee @relation("EmployeeReviews", fields: [employeeId], references: [id])
  reviewer            Employee @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  feedbacks           PerformanceFeedback[]

  @@unique([cycleId, employeeId, reviewType])
  @@index([cycleId])
  @@index([employeeId])
  @@index([reviewerId])
  @@map("hr_performance_reviews")
}

model PerformanceGoal {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycleId             String @db.Uuid
  employeeId          String @db.Uuid

  // Goal details
  title               String
  description         String
  category            GoalCategory
  weight              Float @default(0)  // percentage weight

  // SMART criteria
  measurementCriteria String
  targetValue         String?
  actualValue         String?
  unit                String?

  // Timeline
  startDate           DateTime?
  dueDate             DateTime

  // Progress
  progress            Float @default(0)  // 0-100
  status              GoalStatus @default(NOT_STARTED)

  // Rating
  selfRating          Int?
  managerRating       Int?
  finalRating         Int?
  ratingComments      String?

  // Alignment
  alignedToObjective  String?  // Company/Department objective

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  cycle               PerformanceCycle @relation(fields: [cycleId], references: [id])
  employee            Employee @relation(fields: [employeeId], references: [id])
  updates             GoalUpdate[]

  @@index([cycleId])
  @@index([employeeId])
  @@map("hr_performance_goals")
}

model GoalUpdate {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goalId              String @db.Uuid
  updatedById         String

  progressBefore      Float
  progressAfter       Float
  updateNotes         String
  evidence            Json?  // File attachments

  createdAt           DateTime @default(now())

  // Relations
  goal                PerformanceGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("hr_goal_updates")
}

model PerformanceFeedback {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewId            String @db.Uuid
  feedbackType        FeedbackType
  providerId          String  // Who gave feedback

  // Feedback content
  relationship        String?  // Peer, Direct Report, Skip Level, etc.
  ratings             Json?  // Competency ratings
  strengths           String?
  improvements        String?
  additionalComments  String?

  isAnonymous         Boolean @default(false)
  submittedAt         DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  review              PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("hr_performance_feedbacks")
}

// ============================================
// RECRUITMENT & HIRING
// ============================================

model JobPosting {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobCode             String @unique
  title               String
  departmentId        String @db.Uuid
  positionId          String? @db.Uuid

  // Job Details
  description         String
  responsibilities    String
  requirements        String
  preferredSkills     String?
  benefits            String?

  // Employment
  employmentType      EmploymentType
  experienceMin       Int?
  experienceMax       Int?
  educationLevel      String?

  // Location
  location            String
  isRemote            Boolean @default(false)
  remoteType          RemoteType?

  // Compensation
  salaryMin           Float?
  salaryMax           Float?
  salaryCurrency      String @default("USD")
  salaryPeriod        PayFrequency @default(MONTHLY)
  showSalary          Boolean @default(false)

  // Posting
  openings            Int @default(1)
  filled              Int @default(0)
  status              JobPostingStatus @default(DRAFT)
  publishDate         DateTime?
  closeDate           DateTime?
  internalOnly        Boolean @default(false)

  // Workflow
  hiringManagerId     String?
  recruiterId         String?

  // Channels
  postingChannels     String[]  // LinkedIn, Indeed, Website, etc.
  applicationUrl      String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

