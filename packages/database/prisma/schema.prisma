// ============================================
// PAYROLL MODELS
// ============================================

model EmployeeSalary {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId          String @db.Uuid

  // Base salary
  baseSalary          Float
  currency            String @default("USD")
  payFrequency        PayFrequency @default(MONTHLY)

  // Effective period
  effectiveFrom       DateTime
  effectiveTo         DateTime?
  isActive            Boolean @default(true)

  // Components
  components          SalaryComponent[]

  // History
  previousSalary      Float?
  changeReason        String?
  changeType          SalaryChangeType?
  approvedById        String?
  approvedAt          DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

  // Relations
  employee            Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([effectiveFrom])
  @@map("payroll_employee_salaries")
}

model SalaryComponent {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeSalaryId    String @db.Uuid
  componentTypeId     String @db.Uuid

  // Amount
  amount              Float
  percentage          Float?  // If calculated as % of base
  calculationType     ComponentCalculationType @default(FIXED)

  isActive            Boolean @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  employeeSalary      EmployeeSalary @relation(fields: [employeeSalaryId], references: [id], onDelete: Cascade)
  componentType       SalaryComponentType @relation(fields: [componentTypeId], references: [id])

  @@index([employeeSalaryId])
  @@map("payroll_salary_components")
}

model SalaryComponentType {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String @unique
  name                String
  description         String?
  category            ComponentCategory
  type                ComponentType  // EARNING or DEDUCTION

  // Tax treatment
  isTaxable           Boolean @default(true)
  taxCategory         String?

  // Rules
  isRecurring         Boolean @default(true)
  isStatutory         Boolean @default(false)
  isMandatory         Boolean @default(false)

  // Calculation
  defaultCalculationType ComponentCalculationType @default(FIXED)
  defaultPercentage   Float?

  // Display
  showInPayslip       Boolean @default(true)
  sortOrder           Int @default(0)

  isActive            Boolean @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  components          SalaryComponent[]
  payslipItems        PayslipItem[]

  @@map("payroll_salary_component_types")
}

model PayrollRun {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runNumber           String @unique
  companyId           String?

  // Period
  periodStart         DateTime @db.Date
  periodEnd           DateTime @db.Date
  payDate             DateTime @db.Date
  payFrequency        PayFrequency

  // Employees
  totalEmployees      Int @default(0)
  processedEmployees  Int @default(0)
  errorEmployees      Int @default(0)

  // Totals
  totalGross          Float @default(0)
  totalDeductions     Float @default(0)
  totalNet            Float @default(0)
  totalEmployerCost   Float @default(0)
  currency            String @default("USD")

  // Status
  status              PayrollRunStatus @default(DRAFT)
  lockedAt            DateTime?
  lockedById          String?

  // Approval
  approvalStatus      ApprovalStatus @default(PENDING)
  approvedById        String?
  approvedAt          DateTime?

  // Payment
  paymentStatus       PaymentStatus @default(PENDING)
  paymentDate         DateTime?
  paymentReference    String?
  bankFileGenerated   Boolean @default(false)
  bankFileUrl         String?

  // Notes
  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

  // Relations
  payslips            Payslip[]
  taxFilings          TaxFiling[]

  @@index([periodStart, periodEnd])
  @@index([status])
  @@map("payroll_runs")
}

model Payslip {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payslipNumber       String @unique
  payrollRunId        String @db.Uuid
  employeeId          String @db.Uuid

  // Period
  periodStart         DateTime @db.Date
  periodEnd           DateTime @db.Date
  payDate             DateTime @db.Date

  // Employee info snapshot
  employeeName        String
  employeeNumber      String
  department          String?
  position            String?
  bankAccount         String?

  // Working days
  workingDays         Float
  paidDays            Float
  leaveDays           Float
  unpaidLeaveDays     Float
  overtimeHours       Float @default(0)

  // Earnings
  basicSalary         Float
  grossEarnings       Float

  // Deductions
  totalDeductions     Float
  statutoryDeductions Float @default(0)
  voluntaryDeductions Float @default(0)
  otherDeductions     Float @default(0)

  // Net
  netPay              Float
  currency            String @default("USD")

  // Tax
  taxableIncome       Float
  incomeTax           Float @default(0)
  yearToDateEarnings  Float @default(0)
  yearToDateTax       Float @default(0)

  // Status
  status              PayslipStatus @default(DRAFT)
  publishedAt         DateTime?
  viewedByEmployee    Boolean @default(false)
  viewedAt            DateTime?

  // Payment
  paymentMethod       PaymentMethod @default(BANK_TRANSFER)
  paymentStatus       PaymentStatus @default(PENDING)
  paymentReference    String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  payrollRun          PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee            Employee @relation(fields: [employeeId], references: [id])
  items               PayslipItem[]

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@index([employeeId])
  @@map("payroll_payslips")
}

model PayslipItem {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payslipId           String @db.Uuid
  componentTypeId     String? @db.Uuid

  // Item details
  category            ComponentCategory
  type                ComponentType
  name                String
  description         String?

  // Amount
  quantity            Float @default(1)
  rate                Float?
  amount              Float

  // Tax
  isTaxable           Boolean @default(true)

  sortOrder           Int @default(0)

  createdAt           DateTime @default(now())

  // Relations
  payslip             Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  componentType       SalaryComponentType? @relation(fields: [componentTypeId], references: [id])

  @@index([payslipId])
  @@map("payroll_payslip_items")
}

// ============================================
// BENEFITS & DEDUCTIONS
// ============================================

model EmployeeBenefit {
