model CAPA {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNumber   String @unique

  // Basic info
  title             String
  description       String

  // Classification
  capaType          CAPAType             @default(CORRECTIVE)
  severity          CAPASeverity         @default(MINOR)
  category          String?

  // Source linkage
  sourceType        String?              // 'nc', 'audit', 'investigation', 'customer_complaint'
  sourceId          String?

