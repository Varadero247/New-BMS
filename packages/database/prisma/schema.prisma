// ============================================
// HR TRAINING & DEVELOPMENT
// ============================================

model HRTrainingCourse {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String @unique
  name                String
  description         String?
  category            String
  provider            String?
  instructorName      String?

  // Course details
  deliveryMethod      DeliveryMethod
  duration            Int  // hours
  maxParticipants     Int?
  prerequisites       String[]
  objectives          String?
  syllabus            String?

  // Certification
  certificationAwarded Boolean @default(false)
  certificationValidity Int?  // months

  // Cost
  costPerPerson       Float?
  currency            String @default("USD")

  // Materials
