model CAPACorrectiveAction {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  capaId            String @db.Uuid

  // D5: Permanent Corrective Actions
  description       String
  actionCategory    CorrectiveActionCategory

