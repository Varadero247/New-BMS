model QMSTrainingCourse {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseCode        String @unique

  // Basic info
  title             String
  description       String?

  // Classification
  category          TrainingCategory
  type              TrainingType
  standard          ISOStandard?

  // Content
  objectives        String[]
  content           Json?                // Course outline/modules
  materials         Json?                // Training materials/resources

  // Duration
  durationHours     Float?
  durationDays      Float?

  // Delivery
  deliveryMethod    DeliveryMethod
  provider          String?              // Internal/External provider
  location          String?

  // Prerequisites
  prerequisites     String[]             // Course codes

  // Assessment
  assessmentRequired Boolean             @default(false)
  passingScore      Float?               // Minimum score to pass

  // Validity
  validityPeriod    Int?                 // In months

  // Status
  status            CourseStatus         @default(ACTIVE)

  // Version
  version           String               @default("1.0")

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdById       String?

  // Relations
  requirements      QMSTrainingRequirement[]
  sessions          QMSTrainingSession[]
  records           QMSTrainingRecord[]

  @@index([courseCode])
  @@index([category])
  @@index([status])
  @@map("qms_training_courses")
}

model QMSTrainingRequirement {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Target
  targetType        TrainingTargetType
  targetId          String?              // Role ID, Department ID, or User ID
  targetDescription String?              // Role name, department name, etc.

  // Course
  courseId          String               @db.Uuid

  // Requirement details
  isMandatory       Boolean              @default(true)
  priority          TrainingPriority     @default(MEDIUM)

  // Timeline
  dueWithinDays     Int?                 // Days from hire/role assignment

  // Recurrence
  isRecurring       Boolean              @default(false)
  recurringInterval Int?                 // In months

  // Status
  isActive          Boolean              @default(true)

  // Justification
  rationale         String?
  regulatoryRef     String?              // Regulatory reference if applicable

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdById       String?

  // Relations
  course            QMSTrainingCourse    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([targetType, targetId])
  @@map("qms_training_requirements")
}

model QMSTrainingRecord {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Trainee
  userId            String

  // Course
  courseId          String               @db.Uuid
  sessionId         String?              @db.Uuid

  // Completion
  status            QMSTrainingStatus    @default(NOT_STARTED)
  startedAt         DateTime?
  completedAt       DateTime?

  // Assessment
  assessmentScore   Float?
  assessmentPassed  Boolean?
  assessmentDate    DateTime?

  // Competency
  competencyLevel   CompetenceLevel?
  assessedById      String?
  competencyNotes   String?

  // Certification
  certificateNumber String?
  certificateUrl    String?
  expiryDate        DateTime?

  // Training method
  trainingMethod    String?
  trainerId         String?

  // Feedback
  effectivenessRating Int?               // 1-5
  feedback          String?

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  // Relations
  course            QMSTrainingCourse    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  session           QMSTrainingSession?  @relation(fields: [sessionId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@map("qms_training_records")
}

model QMSTrainingSession {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionNumber     String @unique

  // Course
  courseId          String               @db.Uuid

  // Schedule
  scheduledDate     DateTime
  startTime         String?              // HH:MM format
  endTime           String?

  // Location
  location          String?
  virtualLink       String?

  // Trainer
  trainerId         String?
  trainerName       String?

  // Capacity
  maxParticipants   Int?
  enrolledCount     Int                  @default(0)
  attendedCount     Int                  @default(0)

  // Status
  status            SessionStatus        @default(SCHEDULED)

  // Notes
  notes             String?
  materials         Json?

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdById       String?

  // Relations
  course            QMSTrainingCourse    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  records           QMSTrainingRecord[]

  @@index([courseId])
  @@index([scheduledDate])
  @@index([status])
  @@map("qms_training_sessions")
}

model CompetencyMatrix {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

