  impactFactors     Json?                // Breakdown of impact (financial, operational, etc.)

  // Assessment notes
  rationale         String?
  assumptions       String?
  uncertainties     String?

  // Trend
  trendDirection    TrendDirection?
  previousScore     Int?

  // Audit fields
  createdAt         DateTime             @default(now())

  // Relations
  risk              QMSRisk              @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@index([riskId])
  @@index([assessmentDate])
  @@map("risk_assessments")
}

