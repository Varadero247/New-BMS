model ExpenseReport {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportNumber        String @unique
  employeeId          String
  title               String
  description         String?

  // Period
  periodStart         DateTime @db.Date
  periodEnd           DateTime @db.Date

  // Totals
  totalAmount         Float @default(0)
  currency            String @default("USD")
  expenseCount        Int @default(0)

  // Status
  status              ExpenseReportStatus @default(DRAFT)
  submittedAt         DateTime?

  // Approval
  approvalStatus      ApprovalStatus @default(PENDING)
  approvedById        String?
  approvedAt          DateTime?

  // Payment
  paymentStatus       PaymentStatus @default(PENDING)
  paidAt              DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  expenses            Expense[]

  @@index([employeeId])
  @@index([status])
  @@map("payroll_expense_reports")
}

// ============================================
// TAX & COMPLIANCE
// ============================================

model TaxFiling {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollRunId        String? @db.Uuid
  filingType          TaxFilingType
  taxPeriod           String  // e.g., "2024-Q1", "2024-01"
  taxYear             Int

  // Amounts
  grossWages          Float
  taxableWages        Float
  taxWithheld         Float
  employerTax         Float
  totalTax            Float
  currency            String @default("USD")

  // Filing
  filingDeadline      DateTime
  filedAt             DateTime?
  filedById           String?
  confirmationNumber  String?

  // Payment
  paymentDue          Float
  paymentDate         DateTime?
  paymentReference    String?
  paymentStatus       PaymentStatus @default(PENDING)

  // Documents
  filingDocumentUrl   String?
  supportingDocs      String[]

  status              TaxFilingStatus @default(PENDING)
  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  payrollRun          PayrollRun? @relation(fields: [payrollRunId], references: [id])

  @@index([taxYear])
  @@index([filingType])
  @@map("payroll_tax_filings")
}

model TaxBracket {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taxYear             Int
  country             String
  region              String?
  filingStatus        String?  // Single, Married, etc.

  // Bracket
  minIncome           Float
  maxIncome           Float?
  rate                Float  // percentage
  fixedAmount         Float @default(0)

  isActive            Boolean @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([taxYear, country])
  @@map("payroll_tax_brackets")
}

// ============================================
// WORKFLOW ENGINE MODELS
// ============================================

model WorkflowTemplate {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String @unique
  name                String
  description         String?
  category            WorkflowCategory
  industryType        IndustryType?

  // Template definition
  version             Int @default(1)
  isPublished         Boolean @default(false)
  publishedAt         DateTime?

  // Template metadata
  estimatedDuration   Int?  // hours
  complexity          WorkflowComplexity @default(MEDIUM)
  requiredRoles       String[]

  // Icon/visual
  icon                String?
  color               String?

  isActive            Boolean @default(true)
  isSystem            Boolean @default(false)  // Built-in templates

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

  // Relations
  definitions         WorkflowDefinition[]

  @@index([category])
  @@index([industryType])
  @@map("workflow_templates")
}

model WorkflowDefinition {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId          String? @db.Uuid
  code                String @unique
  name                String
  description         String?

  // Version control
  version             Int @default(1)
  status              WorkflowDefinitionStatus @default(DRAFT)
  publishedVersion    Int?

  // Trigger configuration
  triggerType         WorkflowTriggerType
  triggerConfig       Json?  // Conditions for auto-triggering

  // Process definition (BPMN-like)
  nodes               Json  // Array of workflow nodes
  edges               Json  // Connections between nodes
  variables           Json?  // Workflow variables schema

  // SLA Configuration
  defaultSLA          Int?  // hours
  escalationRules     Json?

  // Notifications
  notificationConfig  Json?

  isActive            Boolean @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

  // Relations
  template            WorkflowTemplate? @relation(fields: [templateId], references: [id])
  instances           WorkflowInstance[]
  rules               WorkflowRule[]
  approvalChains      ApprovalChain[]

  @@index([templateId])
  @@index([status])
  @@map("workflow_definitions")
}

model WorkflowInstance {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instanceNumber      String @unique
  definitionId        String @db.Uuid
  initiatorId         String @db.Uuid

  // Context
  title               String
  description         String?
  entityType          String?  // LeaveRequest, Expense, CAPA, etc.
  entityId            String?  // ID of the linked entity
  priority            WorkflowPriority @default(NORMAL)

  // Variables/Data
  variables           Json?
  formData            Json?

  // Status
  status              WorkflowInstanceStatus @default(PENDING)
  currentNodeId       String?
  completedNodeIds    String[]

  // Timing
  startedAt           DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  cancelledById       String?
  cancellationReason  String?

  // SLA
  dueDate             DateTime?
  isOverdue           Boolean @default(false)
  escalationLevel     Int @default(0)

  // Outcome
  outcome             WorkflowOutcome?
  outcomeNotes        String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  definition          WorkflowDefinition @relation(fields: [definitionId], references: [id])
  initiator           Employee @relation("WorkflowInitiator", fields: [initiatorId], references: [id])
  steps               WorkflowStepInstance[]
  tasks               WorkflowTask[]
  history             WorkflowHistory[]
  escalations         WorkflowEscalation[]

  @@index([definitionId])
  @@index([initiatorId])
  @@index([status])
  @@index([entityType, entityId])
  @@map("workflow_instances")
}

model WorkflowStepInstance {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instanceId          String @db.Uuid
  nodeId              String  // Reference to node in definition
  stepNumber          Int

  // Step details
  name                String
  stepType            WorkflowStepType
  description         String?

  // Assignment
  assigneeType        AssigneeType
  assigneeId          String?
  assigneeRole        String?

  // Status
  status              WorkflowStepStatus @default(PENDING)
  startedAt           DateTime?
  completedAt         DateTime?

  // Decision/Action
  action              String?  // Approve, Reject, Complete, etc.
  actionData          Json?
  comments            String?

  // SLA
  dueDate             DateTime?
  isOverdue           Boolean @default(false)

  // Parallel execution
  parallelBranchId    String?
  isParallel          Boolean @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  instance            WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  approvals           WorkflowStepApproval[]

  @@index([instanceId])
  @@index([status])
  @@map("workflow_step_instances")
}

model WorkflowStepApproval {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stepInstanceId      String @db.Uuid
  approverId          String @db.Uuid
  approvalOrder       Int @default(1)

  // Decision
  decision            ApprovalDecision?
  decidedAt           DateTime?
  comments            String?

  // Delegation
  delegatedFromId     String?
  delegatedReason     String?

  // Reminder
  reminderSentAt      DateTime?
  reminderCount       Int @default(0)

  status              ApprovalStatus @default(PENDING)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  stepInstance        WorkflowStepInstance @relation(fields: [stepInstanceId], references: [id], onDelete: Cascade)
  approver            Employee @relation(fields: [approverId], references: [id])

  @@unique([stepInstanceId, approverId])
  @@index([stepInstanceId])
  @@index([approverId])
  @@map("workflow_step_approvals")
}

model WorkflowTask {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instanceId          String @db.Uuid
  assigneeId          String @db.Uuid
  taskNumber          String @unique

  // Task details
  title               String
  description         String?
  taskType            WorkflowTaskType
  priority            WorkflowPriority @default(NORMAL)

  // Assignment
  assignedAt          DateTime @default(now())
  dueDate             DateTime?

  // Status
  status              WorkflowTaskStatus @default(PENDING)
  startedAt           DateTime?
  completedAt         DateTime?

  // Result
  result              Json?
  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  instance            WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  assignee            Employee @relation(fields: [assigneeId], references: [id])

  @@index([instanceId])
  @@index([assigneeId])
  @@index([status])
  @@map("workflow_tasks")
}

model WorkflowRule {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  definitionId        String @db.Uuid
  name                String
  description         String?
  ruleType            WorkflowRuleType

  // Condition
  condition           Json  // Rule condition expression
  conditionType       ConditionType @default(EXPRESSION)

  // Action
  action              Json  // Action to execute
  actionType          WorkflowActionType

  // Priority
  priority            Int @default(0)
  stopOnMatch         Boolean @default(false)

  isActive            Boolean @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  definition          WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@map("workflow_rules")
}

model ApprovalChain {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  definitionId        String? @db.Uuid
  name                String
  description         String?
  chainType           ApprovalChainType

  // Levels
  levels              Json  // Array of approval levels configuration

  // Rules
  skipConditions      Json?  // Conditions to skip levels
  escalationConfig    Json?

  isActive            Boolean @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  definition          WorkflowDefinition? @relation(fields: [definitionId], references: [id])

  @@index([definitionId])
  @@map("workflow_approval_chains")
}

model WorkflowEscalation {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instanceId          String @db.Uuid
  level               Int
  reason              EscalationReason

  // Escalation details
  escalatedFromId     String?
  escalatedToId       String?
  escalatedToRole     String?

  // Notification
  notificationSent    Boolean @default(false)
  notificationSentAt  DateTime?
  notificationMethod  String[]

  // Resolution
  resolvedAt          DateTime?
  resolution          String?

  createdAt           DateTime @default(now())

  // Relations
  instance            WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@map("workflow_escalations")
}

model WorkflowHistory {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instanceId          String @db.Uuid
  action              String
  actionBy            String?
  actionAt            DateTime @default(now())

  // Details
  nodeId              String?
  fromStatus          String?
  toStatus            String?
  details             Json?
  comments            String?

  // Relations
  instance            WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([actionAt])
  @@map("workflow_history")
}

model WorkflowNotification {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instanceId          String?
  recipientId         String
  recipientEmail      String

  // Notification details
  notificationType    NotificationType
  channel             NotificationChannel
  subject             String
  body                String
  templateId          String?

  // Status
  status              NotificationStatus @default(PENDING)
  sentAt              DateTime?
  failureReason       String?
  retryCount          Int @default(0)

  // Read tracking
  readAt              DateTime?

  createdAt           DateTime @default(now())

  @@index([instanceId])
  @@index([recipientId])
  @@index([status])
  @@map("workflow_notifications")
}

