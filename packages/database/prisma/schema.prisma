  isActive            Boolean @default(true)
  isMandatory         Boolean @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  sessions            HRTrainingSession[]
  enrollments         HRTrainingEnrollment[]

  @@map("hr_training_courses")
}

model HRTrainingSession {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId            String @db.Uuid
  sessionCode         String @unique

  // Schedule
  startDate           DateTime
  endDate             DateTime
  location            String?
  isVirtual           Boolean @default(false)
  meetingUrl          String?

  // Instructor
  instructorId        String?
  instructorName      String?

  // Capacity
  maxParticipants     Int
  enrolledCount       Int @default(0)
  waitlistCount       Int @default(0)

  // Status
  status              TrainingSessionStatus @default(SCHEDULED)
  cancelledReason     String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  course              HRTrainingCourse @relation(fields: [courseId], references: [id])
  enrollments         HRTrainingEnrollment[]

  @@index([courseId])
  @@index([startDate])
  @@map("hr_training_sessions")
}

model HRTrainingEnrollment {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId          String @db.Uuid
  courseId            String @db.Uuid
  sessionId           String? @db.Uuid

  // Status
  status              EnrollmentStatus @default(ENROLLED)
  enrolledAt          DateTime @default(now())
  completedAt         DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?

  // Attendance
  attendancePercent   Float?

  // Assessment
  assessmentScore     Float?
  assessmentDate      DateTime?
  passed              Boolean?

  // Certification
  certificateIssued   Boolean @default(false)
  certificateUrl      String?
  certificateExpiry   DateTime?

  // Feedback
  feedbackRating      Int?
  feedbackComments    String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  employee            Employee @relation(fields: [employeeId], references: [id])
  course              HRTrainingCourse @relation(fields: [courseId], references: [id])
  session             HRTrainingSession? @relation(fields: [sessionId], references: [id])

  @@unique([employeeId, courseId, sessionId])
  @@index([employeeId])
  @@index([courseId])
  @@index([sessionId])
  @@map("hr_training_enrollments")
