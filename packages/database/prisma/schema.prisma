model QMSRisk {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  riskNumber        String @unique

  // Basic info
  title             String
  description       String

  // Classification
  riskCategory      RiskCategory
  riskType          QMSRiskType
  standard          ISOStandard?

  // Context
  process           String?
  department        String?
  objective         String?              // Related strategic objective

  // Risk ownership
  ownerId           String?

  // Current assessment (inherent risk)
  likelihood        Int                  @default(1) // 1-5
  impact            Int                  @default(1) // 1-5
  currentRiskScore  Int?                 // L x I
  currentRiskLevel  QMSRiskLevel?

  // Residual risk (after controls)
  residualLikelihood Int?
  residualImpact    Int?
  residualRiskScore Int?
  residualRiskLevel QMSRiskLevel?

  // Target risk (acceptable level)
  targetRiskScore   Int?

  // Status
  status            QMSRiskStatus        @default(IDENTIFIED)

  // Review cycle
  reviewFrequency   Int?                 // In months
  nextReviewDate    DateTime?
  lastReviewedAt    DateTime?
  lastReviewedById  String?

  // Metadata
  metadata          Json?

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdById       String?
  updatedById       String?

  // Relations
  assessments       RiskAssessment[]
  controls          RiskControl[]
  treatments        RiskTreatment[]

  @@index([riskNumber])
  @@index([status])
  @@index([currentRiskLevel])
  @@map("qms_risks")
}

model RiskAssessment {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  riskId            String @db.Uuid

  // Assessment info
  assessmentDate    DateTime             @default(now())
