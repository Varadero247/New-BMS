// ============================================
// ENTERPRISE QMS - ENHANCED CAPA (8D PROBLEM SOLVING)
// ============================================

model CAPA {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNumber   String @unique

  // Basic info
  title             String
  description       String

  // Classification
  capaType          CAPAType             @default(CORRECTIVE)
  severity          CAPASeverity         @default(MINOR)
  category          String?

  // Source linkage
  sourceType        String?              // 'nc', 'audit', 'investigation', 'customer_complaint'
  sourceId          String?

  // 8D Phase tracking
  currentPhase      CAPAPhase            @default(D1_TEAM)
  phaseHistory      Json?                // Array of phase transitions with dates

  // Key dates
  initiatedDate     DateTime             @default(now())
  targetClosureDate DateTime?
  actualClosureDate DateTime?

  // Status
  status            CAPAStatus           @default(OPEN)

  // Effectiveness
  effectivenessVerified Boolean          @default(false)
  effectivenessScore   Int?              // 1-100

  // Financial tracking
  estimatedCost     Float?
  actualCost        Float?
  costAvoidance     Float?

  // Metadata
  metadata          Json?
  attachments       Json?

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdById       String?
  updatedById       String?
  closedById        String?

  // Relations
  teamMembers       CAPATeamMember[]
  problemStatement  CAPAProblemStatement?
  containmentActions CAPAContainmentAction[]
  rootCauses        CAPARootCause[]
  correctiveActions CAPACorrectiveAction[]
  implementations   CAPAImplementation[]
  preventionActions CAPAPreventionAction[]
  effectivenessChecks CAPAEffectivenessCheck[]
  horizontalDeployments CAPAHorizontalDeployment[]

  @@index([referenceNumber])
  @@index([status, currentPhase])
  @@index([capaType])
  @@map("capas")
}

model CAPATeamMember {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  capaId            String @db.Uuid

  // D1: Team formation
  userId            String
  role              CAPATeamRole
  department        String?
  responsibilities  String?

  // Participation
  assignedAt        DateTime             @default(now())
  removedAt         DateTime?
  isActive          Boolean              @default(true)

  // Relations
  capa              CAPA                 @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@unique([capaId, userId])
  @@index([capaId])
  @@map("capa_team_members")
}

model CAPAProblemStatement {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  capaId            String @unique @db.Uuid

  // D2: 5W2H Problem Description
  what              String               // What is the problem?
  when              String?              // When did it occur?
  whereLocation     String?              // Where was it discovered?
  who               String?              // Who is affected?
  why               String?              // Why is it a problem?
  howDiscovered     String?              // How was it discovered?
  howMany           String?              // How many/how much?

  // Quantified impact
  defectsCount      Int?
  unitsAffected     Int?
  customerAffected  String?
  financialImpact   Float?

  // Problem statement summary
  problemSummary    String?

  // Is/Is Not analysis
  isIsNotAnalysis   Json?                // {is: [], isNot: []}

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdById       String?

  // Relations
  capa              CAPA                 @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@map("capa_problem_statements")
}

model CAPAContainmentAction {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  capaId            String @db.Uuid

  // D3: Interim Containment Actions
  description       String
  actionType        ContainmentActionType

  // Assignment
  assignedToId      String?

  // Timeline
  plannedDate       DateTime?
  implementedDate   DateTime?

  // Status
  status            ActionStatus         @default(OPEN)

  // Verification
  verificationMethod String?
  verifiedById      String?
  verifiedAt        DateTime?
  isEffective       Boolean?

  // Evidence
  evidence          Json?

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdById       String?

  // Relations
  capa              CAPA                 @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@index([capaId])
  @@map("capa_containment_actions")
}

model CAPARootCause {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  capaId            String @db.Uuid

  // D4: Root Cause Analysis
  causeDescription  String
  causeType         RootCauseType
  causeCategory     String?              // Equipment, People, Process, etc.

  // Analysis method
  analysisMethod    RCAMethod

  // For 5 Whys
  fiveWhysData      Json?                // Array of {level: 1-5, question: "", answer: ""}

  // For Fishbone
  fishboneData      Json?                // {category: "", causes: []}

  // Verification
  isVerified        Boolean              @default(false)
  verificationMethod String?
  verifiedById      String?
  verifiedAt        DateTime?

  // Evidence
  evidence          Json?

  // Contribution
  contributionPercent Float?
  isPrimary         Boolean              @default(false)

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdById       String?

  // Relations
  capa              CAPA                 @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@index([capaId])
  @@map("capa_root_causes")
