// ============================================
// ENTERPRISE QMS - INVESTIGATION MANAGEMENT & RCA
// ============================================

model Investigation {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNumber   String @unique

  // Basic info
  title             String
  description       String

  // Classification
  investigationType InvestigationType
  category          String?
  severity          InvestigationSeverity @default(MINOR)

  // Source linkage
  sourceType        String?              // 'incident', 'audit_finding', 'customer_complaint', etc.
  sourceId          String?

  // Event details
  eventDate         DateTime
  eventLocation     String?
  reportedDate      DateTime             @default(now())

  // Impact assessment
  impactDescription String?
  financialImpact   Float?
  productionImpact  String?
  customerImpact    String?
  regulatoryImpact  String?

  // Investigation ownership
  leadInvestigatorId String?

  // Status and timeline
  status            InvestigationStatus  @default(INITIATED)
  targetCompletionDate DateTime?
  actualCompletionDate DateTime?

  // Conclusions
  rootCauseSummary  String?
  conclusion        String?
  lessonsLearned    String?

  // Evidence and attachments
  evidence          Json?                // Array of evidence items
  attachments       Json?                // Array of attachment URLs

  // Metadata
  metadata          Json?

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdById       String?
  updatedById       String?

  // Relations
  timeline          InvestigationTimeline[]
  causes            InvestigationCause[]
  recommendations   InvestigationRecommendation[]
  teamMembers       InvestigationTeamMember[]

  @@index([referenceNumber])
  @@index([status])
  @@index([investigationType])
  @@index([eventDate])
  @@map("investigations")
}

model InvestigationTimeline {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  investigationId   String @db.Uuid

  // Event details
  eventDateTime     DateTime
  description       String
  eventType         TimelineEventType

  // Evidence
  evidence          Json?                // Photos, documents, etc.
  witnesses         String[]

  // Source
  source            String?
  verified          Boolean              @default(false)
  verifiedById      String?
  verifiedAt        DateTime?

  // Order
  sequenceOrder     Int

  // Audit fields
  createdAt         DateTime             @default(now())
  createdById       String?

  // Relations
  investigation     Investigation        @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@map("investigation_timelines")
}

model InvestigationCause {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  investigationId   String @db.Uuid

  // Cause details
  causeType         CauseType
  category          String?              // Equipment, People, Process, etc.
  description       String

  // Analysis method used
  analysisMethod    RCAMethod?

  // For 5 Whys
  whyLevel          Int?                 // 1-5 for 5 Whys
  parentCauseId     String?              @db.Uuid

  // For Fishbone
  fishboneCategory  FishboneCategory?

  // Evidence
  evidence          Json?
  verified          Boolean              @default(false)

  // Contribution factor (0-100%)
  contributionFactor Float?

  // Audit fields
  createdAt         DateTime             @default(now())
  createdById       String?

  // Relations
  investigation     Investigation        @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  parentCause       InvestigationCause?  @relation("CauseHierarchy", fields: [parentCauseId], references: [id])
  childCauses       InvestigationCause[] @relation("CauseHierarchy")

  @@index([investigationId])
  @@index([causeType])
  @@map("investigation_causes")
}

model InvestigationRecommendation {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  investigationId   String @db.Uuid

  // Recommendation details
  description       String
  recommendationType RecommendationType
  priority          ActionPriority       @default(MEDIUM)

  // Assignment
  assignedToId      String?
  department        String?

  // Timeline
  dueDate           DateTime?
  completedDate     DateTime?

  // Status tracking
  status            RecommendationStatus @default(PROPOSED)

  // Linked action
  actionId          String?

  // Verification
  verificationMethod String?
  verifiedById      String?
  verifiedAt        DateTime?
  effectivenessRating Int?               // 1-5

  // Audit fields
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdById       String?

  // Relations
  investigation     Investigation        @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@index([status])
  @@map("investigation_recommendations")
}

model InvestigationTeamMember {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  investigationId   String @db.Uuid

  // Member details
  userId            String
  role              InvestigationRole
  responsibilities  String?

  // Timeline
  assignedAt        DateTime             @default(now())
  removedAt         DateTime?

  // Status
  isActive          Boolean              @default(true)

  // Relations
  investigation     Investigation        @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@unique([investigationId, userId])
  @@index([investigationId])
  @@map("investigation_team_members")
}

enum InvestigationType {
