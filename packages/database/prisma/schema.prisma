  @@map("payroll_benefit_plans")
}

model EmployeeLoan {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loanNumber          String @unique
  employeeId          String @db.Uuid
  loanType            LoanType

  // Loan details
  principalAmount     Float
  interestRate        Float @default(0)
  totalAmount         Float
  currency            String @default("USD")

  // Terms
  termMonths          Int
  startDate           DateTime
  endDate             DateTime
  installmentAmount   Float
  paymentFrequency    PayFrequency @default(MONTHLY)

  // Tracking
  disbursedAmount     Float @default(0)
  repaidAmount        Float @default(0)
  remainingBalance    Float

  // Status
  status              LoanStatus @default(PENDING)
  approvedById        String?
  approvedAt          DateTime?
  disbursedAt         DateTime?

  // Notes
  purpose             String?
  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  employee            Employee @relation(fields: [employeeId], references: [id])
  repayments          LoanRepayment[]

  @@index([employeeId])
  @@index([status])
  @@map("payroll_employee_loans")
}

model LoanRepayment {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loanId              String @db.Uuid
  installmentNumber   Int
  dueDate             DateTime @db.Date
  amount              Float
  principal           Float
  interest            Float

  // Payment
  paidAmount          Float @default(0)
  paidDate            DateTime?
  paymentMethod       PaymentMethod?
  payrollRunId        String?
  status              RepaymentStatus @default(PENDING)

  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  loan                EmployeeLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, installmentNumber])
  @@index([loanId])
  @@index([dueDate])
  @@map("payroll_loan_repayments")
}

// ============================================
// EXPENSE MANAGEMENT
// ============================================

model Expense {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expenseNumber       String @unique
  employeeId          String @db.Uuid

  // Details
  category            ExpenseCategory
  subcategory         String?
  description         String
  merchant            String?

  // Amount
  amount              Float
  currency            String @default("USD")
  exchangeRate        Float @default(1)
  amountInBaseCurrency Float

  // Date
  expenseDate         DateTime @db.Date
  submittedAt         DateTime @default(now())

  // Receipts
  receiptUrls         String[]
  hasReceipt          Boolean @default(false)

  // Project/Cost center
  projectCode         String?
  costCenter          String?
  isBillable          Boolean @default(false)
  clientName          String?

  // Status
  status              ExpenseStatus @default(DRAFT)

  // Approval
  approvalStatus      ApprovalStatus @default(PENDING)
  approvedById        String?
  approvedAt          DateTime?
  approvalNotes       String?

  // Reimbursement
  reimbursementStatus ReimbursementStatus @default(PENDING)
  reimbursedAt        DateTime?
  reimbursementMethod PaymentMethod?
  payrollRunId        String?

  // Policy
  policyViolation     Boolean @default(false)
  violationNotes      String?

  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  employee            Employee @relation(fields: [employeeId], references: [id])
  report              ExpenseReport? @relation(fields: [reportId], references: [id])
  reportId            String? @db.Uuid

  @@index([employeeId])
  @@index([status])
  @@index([expenseDate])
