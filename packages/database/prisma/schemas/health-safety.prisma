// Health & Safety Schema - Occupational Health & Safety Domain (ISO 45001)
// This schema is used by the Health & Safety microservice
// Database: ims_health_safety

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output   = "../../generated/health-safety"
}

datasource db {
  provider = "postgresql"
  url      = env("HEALTH_SAFETY_DATABASE_URL")
}

// ============================================
// INCIDENTS
// ============================================

model Incident {
  id              String   @id @default(cuid())
  orgId           String?
  referenceNumber String   @unique
  title           String
  description     String

  // Classification
  type            IncidentType
  severity        IncidentSeverity @default(MINOR)
  category        String?

  // Details
  location        String?
  dateOccurred    DateTime
  dateReported    DateTime @default(now())

  // People
  reporterId      String   // Reference to User in core DB
  investigatorId  String?
  personsInvolved String?

  // H&S specific
  injuryType      String?
  bodyPart        String?
  daysLost        Int?
  treatmentType   String?

  // Investigation
  immediateCause      String?
  rootCauses          String?
  contributingFactors String?

  // Person details (extended)
  injuredPersonName   String?
  injuredPersonRole   String?
  employmentType      String?  // EMPLOYEE, CONTRACTOR, VISITOR, MEMBER_OF_PUBLIC
  lostTime            Boolean  @default(false)
  witnesses           String?

  // RIDDOR / Regulatory
  riddorReportable       Boolean  @default(false)
  regulatoryReference    String?
  reportedToAuthority    Boolean  @default(false)
  reportedToAuthorityDate DateTime?
  reportedBy             String?

  // Investigation control
  investigationRequired  Boolean  @default(false)
  investigationDueDate   DateTime?

  // AI root cause analysis
  aiImmediateCause       String?
  aiUnderlyingCause      String?
  aiRootCause            String?
  aiContributingFactors  String?
  aiRecurrencePrevention String?
  aiAnalysisGenerated    Boolean  @default(false)

  // Status
  status          IncidentStatus @default(OPEN)
  closedAt        DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  // Relations
  risk            Risk?    @relation(fields: [riskId], references: [id])
  riskId          String?
  actions         HSAction[]
  fiveWhyAnalyses FiveWhyAnalysis[]
  fishboneAnalyses FishboneAnalysis[]
  capas           Capa[]

  @@index([status])
  @@index([type])
  @@index([severity])
  @@index([reporterId])
  @@index([investigatorId])
  @@index([riskId])
  @@index([dateOccurred])
  @@index([orgId])

  @@map("hs_incidents")
}

enum IncidentType {
  INJURY
  NEAR_MISS
  DANGEROUS_OCCURRENCE
  OCCUPATIONAL_ILLNESS
  PROPERTY_DAMAGE
  FIRST_AID
  MEDICAL_TREATMENT
  LOST_TIME
  // ISO 27001 Information Security Incident Types
  SECURITY_BREACH
  DATA_BREACH
  UNAUTHORIZED_ACCESS
  PHISHING_ATTEMPT
}

enum IncidentSeverity {
  MINOR
  MODERATE
  MAJOR
  CRITICAL
  CATASTROPHIC
}

enum IncidentStatus {
  OPEN
  UNDER_INVESTIGATION
  AWAITING_ACTIONS
  ACTIONS_IN_PROGRESS
  VERIFICATION
  CLOSED
}

// ============================================
// RISK ASSESSMENTS
// ============================================

model Risk {
  id              String   @id @default(cuid())
  orgId           String?
  referenceNumber String?  @unique
  title           String
  description     String
  category        String?
  source          String?  // Activity / Location
  whoAtRisk       String?

  // Initial Risk Assessment (before controls)
  likelihood        Int        @default(1) // 1-5
  severity          Int        @default(1) // 1-5
  detectability     Int        @default(1) // 1-5
  riskScore         Int?
  riskLevel         RiskLevel?

  // AI-Generated Controls (Hierarchy of Controls)
  existingControls        String?
  aiControlElimination    String?
  aiControlSubstitution   String?
  aiControlEngineering    String?
  aiControlAdministrative String?
  aiControlPPE            String?
  aiControlsGenerated     Boolean    @default(false)
  additionalControls      String?

  // Residual Risk Assessment (after controls)
  residualLikelihood Int?
  residualSeverity   Int?
  residualRiskScore  Int?
  residualRiskLevel  RiskLevel?
  residualRisk       Int?

  // Management
  riskOwner      String?
  legalReference String?
  responsible    String?
  createdBy      String?

  // Status
  status         RiskStatus @default(ACTIVE)
  reviewDate     DateTime?
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  updatedBy String?

  // Relations
  incidents      Incident[]
  actions        HSAction[]
  hazards        Hazard[]
  bowTieAnalyses BowTieAnalysis[]
  capas          Capa[]

  @@index([status])
  @@index([riskLevel])
  @@index([createdAt])
  @@index([orgId])

  @@map("hs_risks")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  ACTIVE
  UNDER_REVIEW
  MITIGATED
  CLOSED
  ACCEPTED
}

// ============================================
// HAZARDS
// ============================================

model Hazard {
  id          String   @id @default(cuid())
  orgId           String?
  riskId      String?
  title       String
  description String
  category    HazardCategory
  location    String?

  // Assessment
  potentialSeverity Int @default(1) // 1-5
  exposureFrequency Int @default(1) // 1-5
  numberOfExposed   Int @default(1)

  // Controls
  controlMeasures   String?
  controlHierarchy  ControlHierarchy?
  ppeRequired       String[]

  // Status
  status            HazardStatus @default(ACTIVE)
  reviewDate        DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  createdBy         String?
  updatedBy         String?

  // Relations
  risk              Risk? @relation(fields: [riskId], references: [id])

  @@index([riskId])
  @@index([category])
  @@index([status])
  @@index([orgId])

  @@map("hs_hazards")
}

enum HazardCategory {
  PHYSICAL
  CHEMICAL
  BIOLOGICAL
  ERGONOMIC
  PSYCHOSOCIAL
  ELECTRICAL
  FIRE
  MECHANICAL
  ENVIRONMENTAL
  OTHER
}

enum HazardStatus {
  ACTIVE
  CONTROLLED
  ELIMINATED
  UNDER_REVIEW
}

enum ControlHierarchy {
  ELIMINATION
  SUBSTITUTION
  ENGINEERING
  ADMINISTRATIVE
  PPE
}

// ============================================
// ACTIONS
// ============================================

model HSAction {
  id              String   @id @default(cuid())
  orgId           String?
  referenceNumber String   @unique
  title           String
  description     String

  // Source
  incidentId      String?
  riskId          String?

  // Classification
  type            ActionType
  priority        ActionPriority @default(MEDIUM)

  // Assignment
  ownerId         String
  createdById     String

  // Timeline
  dueDate         DateTime
  completedAt     DateTime?
  verifiedAt      DateTime?

  // Verification
  verificationMethod  String?
  verificationNotes   String?
  effectivenessRating Int?

  // Status
  status          ActionStatus @default(OPEN)

  // Cost
  estimatedCost   Decimal? @db.Decimal(14, 2)
  actualCost      Decimal? @db.Decimal(14, 2)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relations
  incident        Incident? @relation(fields: [incidentId], references: [id])
  risk            Risk?     @relation(fields: [riskId], references: [id])

  @@index([incidentId])
  @@index([riskId])
  @@index([status, dueDate])
  @@index([ownerId])
  @@index([type])
  @@index([priority])
  @@index([orgId])

  @@map("hs_actions")
}

enum ActionType {
  CORRECTIVE
  PREVENTIVE
  IMPROVEMENT
  IMMEDIATE
  LONG_TERM
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  VERIFIED
  OVERDUE
  CANCELLED
}

// ============================================
// ROOT CAUSE ANALYSIS
// ============================================

model FiveWhyAnalysis {
  id         String   @id @default(cuid())
  orgId           String?
  incidentId String

  why1       String?
  why2       String?
  why3       String?
  why4       String?
  why5       String?

  rootCause  String?
  conclusion String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@index([orgId])

  @@map("hs_five_why_analyses")
}

model FishboneAnalysis {
  id               String   @id @default(cuid())
  orgId           String?
  incidentId       String

  problemStatement String

  // 6M Categories
  manpower         String?
  method           String?
  machine          String?
  material         String?
  measurement      String?
  environment      String?

  conclusion       String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  incident         Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@index([orgId])

  @@map("hs_fishbone_analyses")
}

model BowTieAnalysis {
  id     String @id @default(cuid())
  orgId           String?
  riskId String

  // Top Event
  topEvent           String

  // Threats (causes) - JSON array
  threats            Json // [{id, description, likelihood}]

  // Consequences - JSON array
  consequences       Json // [{id, description, severity}]

  // Controls
  preventiveControls Json // [{id, description, effectiveness, threatId}]
  mitigatingControls Json // [{id, description, effectiveness, consequenceId}]

  // Barriers
  escalationFactors  Json?

  notes              String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  risk               Risk @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@index([riskId])
  @@index([orgId])

  @@map("hs_bow_tie_analyses")
}

// ============================================
// SAFETY METRICS
// ============================================

model SafetyMetric {
  id    String @id @default(cuid())
  orgId           String?
  year  Int
  month Int

  // Hours & Incidents
  hoursWorked             Decimal @default(0) @db.Decimal(14, 2)
  lostTimeInjuries        Int     @default(0)
  totalRecordableInjuries Int     @default(0)
  daysLost                Int     @default(0)
  nearMisses              Int     @default(0)
  firstAidCases           Int     @default(0)

  // Calculated Rates
  ltifr        Decimal? @db.Decimal(8, 4) // Lost Time Injury Frequency Rate
  trir         Decimal? @db.Decimal(8, 4) // Total Recordable Incident Rate
  severityRate Decimal? @db.Decimal(8, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
  @@index([orgId])

  @@map("hs_safety_metrics")
}

// ============================================
// PERMITS & INSPECTIONS
// ============================================

model SafetyPermit {
  id            String   @id @default(cuid())
  orgId           String?
  permitNumber  String   @unique
  permitType    PermitType
  title         String
  description   String?

  // Location & Work
  location      String
  workDescription String

  // People
  requestedById String
  approvedById  String?
  supervisorId  String?

  // Timeline
  requestedAt   DateTime @default(now())
  approvedAt    DateTime?
  validFrom     DateTime
  validTo       DateTime

  // Hazards & Controls
  hazardsIdentified String[]
  controlMeasures   String[]
  ppeRequired       String[]

  // Status
  status        PermitStatus @default(REQUESTED)
  closedAt      DateTime?
  closureNotes  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  createdBy     String?
  updatedBy     String?

  @@index([status])
  @@index([permitType])
  @@index([requestedById])
  @@index([validFrom])
  @@index([createdAt])
  @@index([orgId])

  @@map("hs_safety_permits")
}

enum PermitType {
  HOT_WORK
  CONFINED_SPACE
  WORKING_AT_HEIGHT
  EXCAVATION
  ELECTRICAL
  LOCKOUT_TAGOUT
  GENERAL
}

enum PermitStatus {
  REQUESTED
  APPROVED
  ACTIVE
  SUSPENDED
  CLOSED
  REJECTED
  EXPIRED
}

model SafetyInspection {
  id              String   @id @default(cuid())
  orgId           String?
  inspectionNumber String  @unique
  inspectionType  InspectionType
  title           String
  description     String?

  // Location
  location        String
  area            String?
  department      String?

  // Schedule
  scheduledDate   DateTime
  conductedDate   DateTime?

  // Inspector
  inspectorId     String
  inspectorName   String?

  // Results
  totalItems      Int @default(0)
  compliantItems  Int @default(0)
  nonCompliantItems Int @default(0)
  complianceScore Decimal? @db.Decimal(5, 2)

  // Status
  status          InspectionStatus @default(SCHEDULED)

  // Findings
  findings        Json?  // Array of findings
  recommendations String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  @@index([status])
  @@index([inspectionType])
  @@index([inspectorId])
  @@index([scheduledDate])
  @@index([createdAt])
  @@index([orgId])

  @@map("hs_safety_inspections")
}

enum InspectionType {
  WORKPLACE
  EQUIPMENT
  FIRE_SAFETY
  PPE
  ERGONOMIC
  CHEMICAL
  ELECTRICAL
  HOUSEKEEPING
  EMERGENCY_PREPAREDNESS
}

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// LEGAL REQUIREMENTS
// ============================================

model LegalRequirement {
  id                String   @id @default(cuid())
  orgId           String?
  referenceNumber   String   @unique
  title             String
  description       String

  // Classification
  category          LegalCategory
  jurisdiction      String?
  legislationRef    String?
  section           String?
  applicableAreas   String?

  // Dates
  effectiveDate     DateTime?
  reviewDate        DateTime?
  lastReviewedAt    DateTime?

  // Compliance
  complianceStatus  ComplianceStatus @default(NOT_ASSESSED)
  complianceNotes   String?
  responsiblePerson String?

  // AI Compliance Assessment
  aiKeyObligations        String?
  aiGapAnalysis           String?
  aiRequiredActions       String?
  aiEvidenceRequired      String?
  aiPenaltyForNonCompliance String?
  aiAssessmentGenerated   Boolean  @default(false)

  // Status
  status            LegalStatus @default(ACTIVE)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  createdBy         String?
  updatedBy         String?

  @@index([complianceStatus])
  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@index([orgId])

  @@map("hs_legal_requirements")
}

enum LegalCategory {
  PRIMARY_LEGISLATION
  SUBORDINATE_LEGISLATION
  ACOP
  HSE_GUIDANCE
  INTERNATIONAL_STANDARD
  INDUSTRY_STANDARD
  CONTRACTUAL
  VOLUNTARY
}

enum ComplianceStatus {
  COMPLIANT
  PARTIAL
  NON_COMPLIANT
  UNDER_REVIEW
  NOT_ASSESSED
}

enum LegalStatus {
  ACTIVE
  REVIEW_DUE
  SUPERSEDED
  ARCHIVED
}

// ============================================
// OHS OBJECTIVES
// ============================================

model OhsObjective {
  id                String   @id @default(cuid())
  orgId           String?
  referenceNumber   String   @unique
  title             String
  objectiveStatement String?

  // Classification
  category          ObjectiveCategory
  ohsPolicyLink     String?
  department        String?
  owner             String?

  // Timeline
  startDate         DateTime?
  targetDate        DateTime
  completedDate     DateTime?

  // Measurement
  kpiDescription    String?
  baselineValue     Float?
  targetValue       Float?
  currentValue      Float    @default(0)
  unit              String?
  progressPercent   Float    @default(0)
  monitoringFrequency String?

  // Resources
  resourcesRequired String?
  progressNotes     String?

  // AI
  aiRecommendations String?
  aiGenerated       Boolean  @default(false)

  // Status
  status            ObjectiveStatus @default(ACTIVE)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  createdBy         String?
  updatedBy         String?

  // Relations
  milestones        ObjectiveMilestone[]

  @@index([status])
  @@index([category])
  @@index([orgId])

  @@map("hs_ohs_objectives")
}

model ObjectiveMilestone {
  id            String   @id @default(cuid())
  orgId           String?
  objectiveId   String
  title         String
  dueDate       DateTime
  completed     Boolean  @default(false)
  completedDate DateTime?
  sortOrder     Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  objective     OhsObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@index([objectiveId])
  @@index([dueDate])
  @@index([orgId])

  @@map("hs_objective_milestones")
}

enum ObjectiveCategory {
  INCIDENT_REDUCTION
  HAZARD_ELIMINATION
  TRAINING
  AUDIT
  LEGAL_COMPLIANCE
  HEALTH_WELLBEING
  RISK_REDUCTION
  CONTRACTOR_MANAGEMENT
  OTHER
}

enum ObjectiveStatus {
  ACTIVE
  ON_TRACK
  AT_RISK
  BEHIND
  ACHIEVED
  CANCELLED
}

// ============================================
// CAPA (Corrective & Preventive Actions)
// ============================================

model Capa {
  id                    String   @id @default(cuid())
  orgId           String?
  referenceNumber       String   @unique
  title                 String

  // Classification
  capaType              CapaType
  source                CapaSource
  sourceReference       String?
  priority              CapaPriority @default(MEDIUM)

  // Timeline
  raisedDate            DateTime @default(now())
  targetCompletionDate  DateTime?
  department            String?
  responsiblePerson     String?

  // Problem Analysis
  problemStatement      String?
  rootCauseAnalysis     String?
  containmentActions    String?
  successCriteria       String?
  verificationMethod    String?
  verificationDate      DateTime?

  // AI
  aiAnalysis            String?
  aiAnalysisGenerated   Boolean  @default(false)

  // Closure
  status                CapaStatus @default(OPEN)
  closureNotes          String?
  closedDate            DateTime?
  closedBy              String?
  effectivenessRating   String?

  // Audit
  createdBy             String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?
  updatedBy             String?

  // Relations
  actions               CapaAction[]
  incident              Incident? @relation(fields: [incidentId], references: [id])
  incidentId            String?
  risk                  Risk?     @relation(fields: [riskId], references: [id])
  riskId                String?

  @@index([status])
  @@index([capaType])
  @@index([priority])
  @@index([incidentId])
  @@index([riskId])
  @@index([targetCompletionDate])
  @@index([orgId])

  @@map("hs_capas")
}

model CapaAction {
  id              String   @id @default(cuid())
  orgId           String?
  capaId          String
  title           String
  description     String?
  type            CapaActionType
  owner           String?
  dueDate         DateTime?
  completedAt     DateTime?
  status          CapaActionStatus @default(OPEN)
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  capa            Capa @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@index([capaId])
  @@index([status])
  @@index([dueDate])
  @@index([orgId])

  @@map("hs_capa_actions")
}

enum CapaType {
  CORRECTIVE
  PREVENTIVE
  IMPROVEMENT
}

enum CapaSource {
  INCIDENT
  NEAR_MISS
  AUDIT
  RISK_ASSESSMENT
  LEGAL
  MANAGEMENT_REVIEW
  WORKER_SUGGESTION
  OTHER
}

enum CapaPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum CapaStatus {
  OPEN
  IN_PROGRESS
  PENDING_VERIFICATION
  CLOSED
  OVERDUE
}

enum CapaActionType {
  IMMEDIATE
  CORRECTIVE
  PREVENTIVE
}

enum CapaActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  VERIFIED
  OVERDUE
  CANCELLED
}

// ============================================
// MANAGEMENT REVIEW (ISO 45001 Clause 9.3)
// ============================================

model HSManagementReview {
  id                    String    @id @default(cuid())
  orgId           String?
  tenantId              String    @default("default")
  refNumber             String    @unique  // HS-MR-YYYY-NN
  reviewDate            DateTime
  chair                 String
  attendees             String[]
  status                HSReviewStatus @default(DRAFT)
  // ISO 45001 Clause 9.3 mandatory inputs
  prevActionStatus      String?
  ohsObjectivesProgress String?
  legalComplianceStatus String?
  incidentStatistics    String?
  riskOpportunityReview String?
  auditResults          String?
  workerParticipation   String?
  externalCommunications String?
  changesInIssues       String?
  // ISO 45001 Clause 9.3 mandatory outputs
  continualImprovement  String?
  resourceNeeds         String?
  systemChanges         String?
  actions               HSMRAction[]
  createdBy             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  @@index([tenantId, status])
  @@index([reviewDate])
  @@index([orgId])

  @@map("hs_management_reviews")
}

model HSMRAction {
  id          String              @id @default(cuid())
  orgId           String?
  reviewId    String
  action      String
  owner       String
  dueDate     DateTime
  status      HSMRActionStatus    @default(OPEN)
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  review      HSManagementReview  @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([status])
  @@index([dueDate])
  @@index([orgId])

  @@map("hs_mr_actions")
}

enum HSReviewStatus {
  DRAFT
  COMPLETED
  APPROVED
}

enum HSMRActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETE
  OVERDUE
}

// ============================================
// COMMUNICATION REGISTER (S4-07 — H&S side)
// ============================================

model HSCommunication {
  id              String    @id @default(cuid())
  orgId           String?
  tenantId        String    @default("default")
  refNumber       String    @unique
  direction       HSCommDirection
  commType        HSCommType
  subject         String
  description     String?
  stakeholders    String[]
  date            DateTime
  responseRequired Boolean  @default(false)
  responseDate    DateTime?
  responseNotes   String?
  status          HSCommStatus @default(OPEN)
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, direction])
  @@index([status])
  @@index([date])
  @@index([orgId])

  @@map("hs_communications")
}

enum HSCommDirection {
  INTERNAL
  EXTERNAL
}

enum HSCommType {
  WORKER_CONSULTATION
  MANAGEMENT_NOTIFICATION
  REGULATORY_COMMUNICATION
  EXTERNAL_STAKEHOLDER
  CONTRACTOR_BRIEFING
  TOOLBOX_TALK
  COMMITTEE_MEETING
}

enum HSCommStatus {
  OPEN
  RESPONDED
  CLOSED
}
