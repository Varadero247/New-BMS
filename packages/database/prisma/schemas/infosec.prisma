// InfoSec Schema - Information Security Management System (ISO 27001 / ISO 27701)
// ISMS scope, asset register, Annex A controls, risk register, incidents, audits,
// vulnerability scans, penetration tests, ROPA, DPIA, DSAR, consent & retention

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "../../generated/infosec"
}

datasource db {
  provider = "postgresql"
  url      = env("INFOSEC_DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum IsScopeStatus {
  DRAFT
  APPROVED
  REVIEW_DUE
}

enum IsAssetType {
  DATA
  SYSTEM
  APPLICATION
  PHYSICAL
  PERSONNEL
  SERVICE
  FACILITY
}

enum IsAssetClassification {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IsAssetFormat {
  DIGITAL
  PHYSICAL
  BOTH
}

enum IsAssetStatus {
  ACTIVE
  INACTIVE
  DISPOSED
  UNDER_REVIEW
}

enum IsControlDomain {
  ORGANISATIONAL
  PEOPLE
  PHYSICAL
  TECHNOLOGICAL
}

enum IsControlApplicability {
  APPLICABLE
  NOT_APPLICABLE
}

enum IsControlImplementationStatus {
  NOT_STARTED
  PARTIAL
  IMPLEMENTED
  NOT_APPLICABLE
}

enum IsRiskLevel {
  VERY_LOW
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IsRiskTreatment {
  ACCEPT
  MITIGATE
  TRANSFER
  AVOID
}

enum IsRiskStatus {
  OPEN
  IN_TREATMENT
  ACCEPTED
  CLOSED
}

enum IsIncidentType {
  DATA_BREACH
  UNAUTHORISED_ACCESS
  MALWARE
  PHISHING
  PHYSICAL_BREACH
  SYSTEM_FAILURE
  INSIDER_THREAT
}

enum IsIncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IsIncidentStatus {
  REPORTED
  INVESTIGATING
  CONTAINED
  RESOLVED
  CLOSED
}

enum IsAuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum IsFindingType {
  CONFORMITY
  MINOR_NC
  MAJOR_NC
  OBSERVATION
  OFI
}

enum IsFindingStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  VERIFIED
}

enum IsScanStatus {
  PENDING_REVIEW
  REVIEWED
  REMEDIATED
}

enum IsPenTestStatus {
  PENDING_REVIEW
  REVIEWED
  REMEDIATED
}

enum IsRopaLawfulBasis {
  CONSENT
  CONTRACT
  LEGAL_OBLIGATION
  VITAL_INTERESTS
  PUBLIC_TASK
  LEGITIMATE_INTERESTS
}

enum IsRopaStatus {
  ACTIVE
  UNDER_REVIEW
  ARCHIVED
}

enum IsDpiaStatus {
  DRAFT
  IN_PROGRESS
  APPROVED
  REJECTED
}

enum IsDsarRequestType {
  ACCESS
  RECTIFICATION
  ERASURE
  RESTRICTION
  PORTABILITY
  OBJECTION
}

enum IsDsarStatus {
  RECEIVED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum IsConsentMethod {
  WEB_FORM
  EMAIL
  PAPER
  VERBAL
}

enum IsRetentionUnit {
  DAYS
  MONTHS
  YEARS
}

// ============================================
// ISMS SCOPE
// ============================================

model IsScope {
  id             String        @id @default(cuid())
  orgId           String?
  title          String
  description    String
  boundaries     String?
  exclusions     String?
  justifications String?
  version        Int           @default(1)
  status         IsScopeStatus @default(DRAFT)
  approvedBy     String?
  approvedAt     DateTime?
  createdBy      String
  updatedBy      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([orgId])


  @@map("is_scopes")
}

// ============================================
// INFORMATION ASSET REGISTER
// ============================================

model IsAsset {
  id                  String              @id @default(cuid())
  orgId           String?
  refNumber           String              @unique
  name                String
  type                IsAssetType
  classification      IsAssetClassification
  format              IsAssetFormat
  owner               String
  custodian           String?
  location            String?
  retentionPeriod     String?
  encryptionRequired  Boolean             @default(false)
  description         String?
  notes               String?
  status              IsAssetStatus       @default(ACTIVE)
  createdBy           String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?
  deletedBy           String?

  @@index([orgId])


  @@map("is_assets")
}

// ============================================
// ANNEX A CONTROLS
// ============================================

model IsControl {
  id                   String                        @id @default(cuid())
  orgId           String?
  controlId            String                        @unique
  domain               IsControlDomain
  title                String
  description          String
  applicability        IsControlApplicability         @default(APPLICABLE)
  justification        String?
  implementationStatus IsControlImplementationStatus  @default(NOT_STARTED)
  implementationNotes  String?
  evidence             String?
  owner                String?
  reviewDate           DateTime?
  lastReviewedAt       DateTime?
  createdBy            String
  updatedBy            String?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  deletedAt            DateTime?

  @@index([orgId])


  @@map("is_controls")
  @@index([domain])
  @@index([implementationStatus])
}

// ============================================
// INFORMATION SECURITY RISK REGISTER
// ============================================

model IsRisk {
  id                  String          @id @default(cuid())
  orgId           String?
  refNumber           String          @unique
  title               String
  description         String
  assetId             String?
  threat              String
  vulnerability       String
  likelihood          Int
  impact              Int
  riskScore           Int
  riskLevel           IsRiskLevel
  treatment           IsRiskTreatment
  treatmentPlan       String?
  controlIds          String[]        @default([])
  residualLikelihood  Int?
  residualImpact      Int?
  residualScore       Int?
  owner               String
  reviewDate          DateTime?
  status              IsRiskStatus    @default(OPEN)
  createdBy           String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  @@index([orgId])


  @@map("is_risks")
  @@index([riskLevel])
  @@index([status])
}

// ============================================
// SECURITY INCIDENT LOG
// ============================================

model IsIncident {
  id                       String            @id @default(cuid())
  orgId           String?
  refNumber                String            @unique
  title                    String
  description              String
  type                     IsIncidentType
  severity                 IsIncidentSeverity
  status                   IsIncidentStatus  @default(REPORTED)
  reportedBy               String
  reportedAt               DateTime          @default(now())
  personalDataInvolved     Boolean           @default(false)
  gdprBreachNotification   Boolean           @default(false)
  gdprNotificationDeadline DateTime?
  gdprNotifiedAt           DateTime?
  investigationNotes       String?
  rootCause                String?
  lessonsLearned           String?
  resolvedAt               DateTime?
  closedAt                 DateTime?
  createdBy                String
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  deletedAt                DateTime?

  @@index([orgId])


  @@map("is_incidents")
  @@index([type])
  @@index([status])
  @@index([severity])
}

// ============================================
// ISMS AUDITS
// ============================================

model IsAudit {
  id            String        @id @default(cuid())
  orgId           String?
  refNumber     String        @unique
  title         String
  auditDate     DateTime
  leadAuditor   String
  auditees      String[]      @default([])
  scope         String?
  status        IsAuditStatus @default(PLANNED)
  summary       String?
  nextAuditDate DateTime?
  completedAt   DateTime?
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  findings      IsAuditFinding[]

  @@index([orgId])


  @@map("is_audits")
  @@index([status])
  @@index([auditDate])
}

// ============================================
// AUDIT FINDINGS
// ============================================

model IsAuditFinding {
  id          String          @id @default(cuid())
  orgId           String?
  auditId     String
  audit       IsAudit         @relation(fields: [auditId], references: [id], onDelete: Cascade)
  clause      String?
  findingType IsFindingType
  description String
  evidence    String?
  status      IsFindingStatus @default(OPEN)
  dueDate     DateTime?
  closedDate  DateTime?
  capaRef     String?
  createdBy   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([orgId])


  @@map("is_audit_findings")
  @@index([auditId])
}

// ============================================
// VULNERABILITY SCANS
// ============================================

model IsVulnerabilityScan {
  id               String       @id @default(cuid())
  orgId           String?
  refNumber        String       @unique
  scanDate         DateTime
  scanner          String?
  targetSystem     String?
  totalFindings    Int          @default(0)
  criticalFindings Int          @default(0)
  highFindings     Int          @default(0)
  mediumFindings   Int          @default(0)
  lowFindings      Int          @default(0)
  report           String?
  status           IsScanStatus @default(PENDING_REVIEW)
  createdBy        String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  @@index([orgId])


  @@map("is_vulnerability_scans")
}

// ============================================
// PENETRATION TESTS
// ============================================

model IsPenetrationTest {
  id               String         @id @default(cuid())
  orgId           String?
  refNumber        String         @unique
  testDate         DateTime
  tester           String
  scope            String?
  methodology      String?
  totalFindings    Int            @default(0)
  criticalFindings Int            @default(0)
  highFindings     Int            @default(0)
  report           String?
  status           IsPenTestStatus @default(PENDING_REVIEW)
  createdBy        String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  @@index([orgId])


  @@map("is_penetration_tests")
}

// ============================================
// RECORDS OF PROCESSING ACTIVITIES (ISO 27701)
// ============================================

model IsRopa {
  id                     String          @id @default(cuid())
  orgId           String?
  refNumber              String          @unique
  name                   String
  purpose                String
  lawfulBasis            IsRopaLawfulBasis
  dataCategories         String[]        @default([])
  dataSubjects           String[]        @default([])
  recipients             String[]        @default([])
  retentionPeriod        String?
  transfersOutsideEEA    Boolean         @default(false)
  transferSafeguards     String?
  technicalMeasures      String?
  organisationalMeasures String?
  dpoReviewDate          DateTime?
  status                 IsRopaStatus    @default(ACTIVE)
  createdBy              String
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  deletedAt              DateTime?

  @@index([orgId])


  @@map("is_ropa")
}

// ============================================
// DATA PROTECTION IMPACT ASSESSMENT
// ============================================

model IsDpia {
  id                    String       @id @default(cuid())
  orgId           String?
  refNumber             String       @unique
  title                 String
  description           String
  processingDescription String?
  necessityAssessment   String?
  riskAssessment        String?
  mitigationMeasures    String?
  dpoOpinion            String?
  status                IsDpiaStatus @default(DRAFT)
  approvedBy            String?
  approvedAt            DateTime?
  createdBy             String
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  deletedAt             DateTime?

  @@index([orgId])


  @@map("is_dpia")
  @@index([status])
}

// ============================================
// DATA SUBJECT ACCESS REQUEST
// ============================================

model IsDsar {
  id              String           @id @default(cuid())
  orgId           String?
  refNumber       String           @unique
  subjectName     String
  subjectEmail    String
  requestType     IsDsarRequestType
  description     String?
  receivedAt      DateTime         @default(now())
  deadline        DateTime
  status          IsDsarStatus     @default(RECEIVED)
  responseNotes   String?
  respondedAt     DateTime?
  rejectionReason String?
  createdBy       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  @@index([orgId])


  @@map("is_dsar")
  @@index([status])
  @@index([deadline])
}

// ============================================
// CONSENT RECORDS
// ============================================

model IsConsent {
  id            String           @id @default(cuid())
  orgId           String?
  subjectEmail  String
  purpose       String
  consentGiven  Boolean
  consentDate   DateTime
  withdrawnDate DateTime?
  method        IsConsentMethod?
  createdBy     String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  @@index([orgId])


  @@map("is_consents")
  @@index([subjectEmail])
}

// ============================================
// DATA RETENTION SCHEDULES
// ============================================

model IsRetentionSchedule {
  id              String          @id @default(cuid())
  orgId           String?
  dataCategory    String
  retentionPeriod String
  unit            IsRetentionUnit
  legalBasis      String?
  reviewDate      DateTime?
  lastReviewedAt  DateTime?
  notes           String?
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([orgId])


  @@map("is_retention_schedules")
}

// ===== ISO 27001:2022 NEW CONTROLS & GDPR GAP MODELS =====

// A.5.7 - Threat Intelligence
model IsThreatIntelligence {
  id                  String    @id @default(uuid())
  title               String
  source              String
  category            String
  threatType          String
  description         String    @db.Text
  iocIndicators       String[]
  affectedSystems     String[]
  severity            String
  confidence          String
  tlpLevel            String?
  recommendedActions  String?   @db.Text
  validUntil          DateTime?
  reportedBy          String
  mitigationNotes     String?   @db.Text
  status              String    @default("ACTIVE")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  @@map("is_threat_intelligence")
}

// A.5.23 - Cloud Security
model IsCloudService {
  id                    String            @id @default(uuid())
  serviceName           String
  provider              String
  serviceType           IsCloudServiceType
  dataClassification    String
  personalDataProcessed Boolean           @default(false)
  dataResidency         String?
  baaRequired           Boolean           @default(false)
  encryptionAtRest      Boolean           @default(false)
  encryptionInTransit   Boolean           @default(false)
  mfaEnabled            Boolean           @default(false)
  businessOwner         String
  technicalContact      String?
  contractRef           String?
  reviewDate            DateTime?
  riskRating            String            @default("MEDIUM")
  riskNotes             String?           @db.Text
  status                String            @default("ACTIVE")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?

  @@map("is_cloud_services")
}

// A.5.30 - ICT Readiness for Business Continuity
model IsIctReadiness {
  id                   String    @id @default(uuid())
  systemName           String
  criticality          String
  rto                  Int?
  rpo                  Int?
  backupFrequency      String?
  backupLocation       String?
  lastBackupTest       DateTime?
  failoverCapability   Boolean   @default(false)
  failoverTarget       String?
  redundancyDetails    String?   @db.Text
  bcpReference         String?
  drpReference         String?
  ictOwner             String
  lastReviewed         DateTime?
  status               String    @default("CURRENT")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  @@map("is_ict_readiness")
}

// A.7.4 - Physical Security Monitoring
model IsPhysicalMonitoring {
  id              String   @id @default(uuid())
  location        String
  monitoringType  String
  description     String   @db.Text
  coverage        String
  retentionDays   Int      @default(30)
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  status          String   @default("OPERATIONAL")
  incidents       Int      @default(0)
  notes           String?  @db.Text
  owner           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@map("is_physical_monitoring")
}

// A.8.9 - Configuration Management
model IsConfigBaseline {
  id                   String    @id @default(uuid())
  systemName           String
  systemType           String
  baselineVersion      String
  baselineDate         DateTime
  configurationItems   String[]
  deviations           String?   @db.Text
  complianceScore      Float?
  reviewedBy           String
  nextReviewDate       DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  @@map("is_config_baselines")
}

// A.8.10 - Information Deletion
model IsInfoDeletion {
  id                 String    @id @default(uuid())
  assetDescription   String
  assetType          String
  dataClassification String
  deletionMethod     String
  deletionDate       DateTime
  performedBy        String
  witnessedBy        String?
  certificateRef     String?
  quantity           Int?
  verifiedComplete   Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  @@map("is_info_deletions")
}

// A.8.12 - Data Leakage Prevention
model IsDlpPolicy {
  id          String   @id @default(uuid())
  name        String
  scope       String
  dataTypes   String[]
  action      String
  description String   @db.Text
  owner       String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@map("is_dlp_policies")
}

model IsDlpIncident {
  id                 String    @id @default(uuid())
  policyId           String?
  policyName         String
  eventDate          DateTime
  dataType           String
  channel            String
  userIdentifier     String
  dataVolume         String?
  destination        String?
  blocked            Boolean   @default(false)
  falsePositive      Boolean   @default(false)
  investigationNotes String?   @db.Text
  severity           String
  detectedBy         String
  status             String    @default("OPEN")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  @@map("is_dlp_incidents")
}

// A.8.16 - Monitoring Activities
model IsMonitoringReview {
  id                String    @id @default(uuid())
  reviewType        String
  reviewDate        DateTime
  systemsCovered    String[]
  period            String
  findings          String?   @db.Text
  anomaliesDetected Int       @default(0)
  actionsTaken      String?   @db.Text
  reviewedBy        String
  nextReviewDate    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@map("is_monitoring_reviews")
}

// A.8.28 - Secure Coding
model IsSecureCodingStandard {
  id          String   @id @default(uuid())
  name        String
  version     String
  language    String[]
  description String   @db.Text
  guidelines  String   @db.Text
  references  String[]
  status      String   @default("ACTIVE")
  owner       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@map("is_secure_coding_standards")
}

model IsSecurityCodeReview {
  id               String   @id @default(uuid())
  projectName      String
  repository       String?
  reviewDate       DateTime
  reviewer         String
  findingsCount    Int      @default(0)
  criticalFindings Int      @default(0)
  highFindings     Int      @default(0)
  mediumFindings   Int      @default(0)
  findings         String?  @db.Text
  remediatedCount  Int      @default(0)
  status           String   @default("OPEN")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("is_security_code_reviews")
}

// GDPR A.37-39 - DPO Management
model IsDpo {
  id                  String    @id @default(uuid())
  name                String
  email               String
  phone               String?
  isExternal          Boolean   @default(false)
  organisation        String?
  appointmentDate     DateTime
  responsibilities    String?   @db.Text
  publishedOnWebsite  Boolean   @default(false)
  notifiedToSa        Boolean   @default(false)
  saNotificationDate  DateTime?
  status              String    @default("ACTIVE")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  @@map("is_dpo")
}

// GDPR Art 28 - Data Processing Agreements
model IsDpa {
  id                   String    @id @default(uuid())
  processorName        String
  processorContact     String?
  processingActivities String    @db.Text
  dataCategories       String[]
  effectiveDate        DateTime
  expiryDate           DateTime?
  subProcessorsAllowed Boolean   @default(false)
  subProcessorList     String?   @db.Text
  article28Compliant   Boolean   @default(false)
  documentRef          String?
  createdBy            String
  status               String    @default("ACTIVE")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  @@map("is_dpas")
}

// GDPR Art 46 - International Transfers
model IsInternationalTransfer {
  id                String   @id @default(uuid())
  recipientCountry  String
  recipientOrg      String
  transferMechanism String
  dataCategories    String[]
  purpose           String   @db.Text
  documentRef       String?
  validFrom         DateTime
  validUntil        DateTime?
  createdBy         String
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@map("is_international_transfers")
}

// GDPR Art 25 - Privacy by Design
model IsPrivacyByDesign {
  id                  String    @id @default(uuid())
  projectName         String
  projectDescription  String    @db.Text
  dpiaRequired        Boolean   @default(false)
  dpiaCompleted       Boolean   @default(false)
  dpiaDate            DateTime?
  dpiaFindings        String?   @db.Text
  dataMinimisation    Boolean   @default(false)
  pseudonymisation    Boolean   @default(false)
  encryptionApplied   Boolean   @default(false)
  accessControls      String?   @db.Text
  retentionPeriod     String?
  deletionMechanism   String?
  approvedBy          String?
  reviewDate          DateTime?
  createdBy           String
  status              String    @default("IN_PROGRESS")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  @@map("is_privacy_by_design")
}

// GDPR Art 77 - Supervisory Authority Complaints
model IsSaComplaint {
  id                   String    @id @default(uuid())
  complaintRef         String?
  complainantType      String
  supervisoryAuthority String
  receivedDate         DateTime
  subject              String
  description          String    @db.Text
  artCited             String[]
  responseDeadline     DateTime?
  assignedTo           String?
  createdBy            String
  responseNotes        String?   @db.Text
  resolvedAt           DateTime?
  closedAt             DateTime?
  status               String    @default("OPEN")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  @@map("is_sa_complaints")
}

enum IsThreatCategory {
  MALWARE
  PHISHING
  RANSOMWARE
  APT
  INSIDER_THREAT
  DDOS
  VULNERABILITY
  ZERO_DAY
  SUPPLY_CHAIN
  OTHER
}

enum IsThreatStatus {
  ACTIVE
  MITIGATED
  EXPIRED
  FALSE_POSITIVE
}

enum IsCloudServiceType {
  IAAS
  PAAS
  SAAS
  CAAS
  OTHER
}

enum IsDpaStatus {
  DRAFT
  UNDER_REVIEW
  SIGNED
  ACTIVE
  EXPIRED
  TERMINATED
}

enum IsTransferMechanism {
  ADEQUACY_DECISION
  STANDARD_CONTRACTUAL_CLAUSES
  BINDING_CORPORATE_RULES
  CODES_OF_CONDUCT
  CERTIFICATION
  DEROGATION_ART49
}

enum IsSaComplaintStatus {
  RECEIVED
  UNDER_INVESTIGATION
  RESPONSE_SENT
  AWAITING_DECISION
  RESOLVED
  CLOSED
}
