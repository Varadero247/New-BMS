// Workflows Schema - Workflow Engine Domain
// This schema is used by the Workflows microservice
// Database: ims_workflows

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output   = "../../generated/workflows"
}

datasource db {
  provider = "postgresql"
  url      = env("WORKFLOWS_DATABASE_URL")
}

// ============================================
// WORKFLOW DEFINITIONS
// ============================================

model WorkflowDefinition {
  id                String   @id @default(cuid())
  orgId           String?
  code              String   @unique
  name              String
  description       String?
  category          WorkflowCategory
  version           Int      @default(1)

  // Configuration
  triggerType       WorkflowTriggerType @default(MANUAL)
  triggerConfig     Json?    // Trigger-specific configuration

  // Steps definition
  steps             Json     // Array of step definitions

  // Rules & routing
  rules             Json?    // Conditional routing rules

  // SLA settings
  defaultSlaHours   Int?
  escalationConfig  Json?

  // Status
  status            WorkflowDefinitionStatus @default(DRAFT)
  isActive          Boolean  @default(true)

  // Publishing
  publishedAt       DateTime?
  publishedById     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  createdById       String?
  updatedBy         String?

  // Relations
  instances         WorkflowInstance[]

  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([orgId])

  @@map("wf_definitions")
}

enum WorkflowCategory {
  APPROVAL
  REVIEW
  CHANGE_MANAGEMENT
  INCIDENT
  REQUEST
  ONBOARDING
  OFFBOARDING
  PROCUREMENT
  DOCUMENT_CONTROL
  AUDIT
  CAPA
  TRAINING
  CUSTOM
}

enum WorkflowTriggerType {
  MANUAL
  AUTOMATIC
  SCHEDULED
  EVENT
  API
}

enum WorkflowDefinitionStatus {
  DRAFT
  ACTIVE
  DEPRECATED
  ARCHIVED
}

// ============================================
// WORKFLOW INSTANCES
// ============================================

model WorkflowInstance {
  id                String   @id @default(cuid())
  orgId           String?
  definitionId      String
  referenceNumber   String   @unique

  // Source entity
  entityType        String?  // 'incident', 'capa', 'document', etc.
  entityId          String?

  // Context data
  contextData       Json?    // Form data and variables

  // Initiator
  initiatedById     String
  initiatedAt       DateTime @default(now())

  // Status
  status            WorkflowInstanceStatus @default(PENDING)
  currentStepId     String?
  outcome           WorkflowOutcome?

  // Priority
  priority          WorkflowPriority @default(NORMAL)

  // SLA
  slaDeadline       DateTime?
  slaBreach         Boolean  @default(false)

  // Completion
  completedAt       DateTime?
  completedById     String?
  cancellationReason String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  createdBy         String?
  updatedBy         String?

  // Relations
  definition        WorkflowDefinition @relation(fields: [definitionId], references: [id])
  steps             WorkflowStep[]
  tasks             WorkflowTask[]
  comments          WorkflowComment[]
  history           WorkflowHistory[]

  @@index([status])
  @@index([definitionId])
  @@index([entityType, entityId])
  @@index([initiatedById])
  @@index([orgId])

  @@map("wf_instances")
}

enum WorkflowInstanceStatus {
  PENDING
  IN_PROGRESS
  WAITING_APPROVAL
  PAUSED
  COMPLETED
  CANCELLED
  ERROR
  EXPIRED
}

enum WorkflowPriority {
  LOW
  NORMAL
  HIGH
  URGENT
  CRITICAL
}

enum WorkflowOutcome {
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
  EXPIRED
  ERROR
}

// ============================================
// WORKFLOW STEPS
// ============================================

model WorkflowStep {
  id                String   @id @default(cuid())
  orgId           String?
  instanceId        String
  stepDefinitionId  String   // References step in definition.steps

  // Step info
  name              String
  stepType          WorkflowStepType
  sequenceNumber    Int

  // Assignment
  assigneeType      AssigneeType?
  assigneeId        String?  // User ID or role/department name
  assignedAt        DateTime?

  // Status
  status            WorkflowStepStatus @default(PENDING)
  startedAt         DateTime?
  completedAt       DateTime?

  // Result
  decision          String?  // For approval steps
  notes             String?
  formData          Json?    // Captured form data

  // SLA
  dueDate           DateTime?
  slaBreached       Boolean  @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  instance          WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([status])
  @@index([orgId])

  @@map("wf_steps")
}

enum WorkflowStepType {
  START
  END
  TASK
  APPROVAL
  DECISION
  PARALLEL_GATEWAY
  EXCLUSIVE_GATEWAY
  NOTIFICATION
  AUTOMATION
  SUBPROCESS
  TIMER
}

enum WorkflowStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  CANCELLED
  ERROR
}

enum AssigneeType {
  USER
  ROLE
  DEPARTMENT
  MANAGER
  INITIATOR
  DYNAMIC
}

// ============================================
// WORKFLOW TASKS
// ============================================

model WorkflowTask {
  id                String   @id @default(cuid())
  orgId           String?
  instanceId        String
  stepId            String?

  // Task info
  title             String
  description       String?
  taskType          WorkflowTaskType

  // Assignment
  assignedToId      String?
  assignedToName    String?

  // Timeline
  dueDate           DateTime?
  startedAt         DateTime?
  completedAt       DateTime?

  // Status
  status            WorkflowTaskStatus @default(PENDING)

  // Form & data
  formDefinition    Json?    // Form schema for data capture
  formData          Json?    // Submitted form data

  // Result
  outcome           String?
  notes             String?

  // Delegation
  delegatedToId     String?
  delegatedAt       DateTime?
  delegationReason  String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  createdBy         String?
  updatedBy         String?

  // Relations
  instance          WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([assignedToId])
  @@index([status])
  @@index([orgId])

  @@map("wf_tasks")
}

enum WorkflowTaskType {
  REVIEW
  APPROVE
  COMPLETE_FORM
  UPLOAD_DOCUMENT
  VERIFICATION
  DATA_ENTRY
  NOTIFICATION
  CUSTOM
}

enum WorkflowTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

// ============================================
// WORKFLOW COMMENTS
// ============================================

model WorkflowComment {
  id                String   @id @default(cuid())
  orgId           String?
  instanceId        String
  stepId            String?
  taskId            String?

  // Comment
  content           String
  commentType       CommentType @default(GENERAL)

  // Author
  authorId          String
  authorName        String?

  // Visibility
  isInternal        Boolean  @default(false)

  // Attachments
  attachments       Json?    // Array of attachment URLs

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  instance          WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([orgId])

  @@map("wf_comments")
}

enum CommentType {
  GENERAL
  APPROVAL
  REJECTION
  QUESTION
  ANSWER
  ESCALATION
  SYSTEM
}

// ============================================
// WORKFLOW HISTORY
// ============================================

model WorkflowHistory {
  id                String   @id @default(cuid())
  instanceId        String
  stepId            String?
  taskId            String?

  // Event
  eventType         WorkflowEventType
  description       String?
  previousStatus    String?
  newStatus         String?

  // Data changes
  previousData      Json?
  newData           Json?

  // Actor
  actorId           String?
  actorName         String?
  actorType         ActorType @default(USER)

  // Metadata
  metadata          Json?
  ipAddress         String?

  createdAt         DateTime @default(now())

  // Relations
  instance          WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([eventType])
  @@index([createdAt])
  @@map("wf_history")
}

enum WorkflowEventType {
  CREATED
  STARTED
  STEP_COMPLETED
  TASK_ASSIGNED
  TASK_COMPLETED
  APPROVED
  REJECTED
  COMMENTED
  ESCALATED
  DELEGATED
  PAUSED
  RESUMED
  CANCELLED
  COMPLETED
  ERROR
  SLA_WARNING
  SLA_BREACH
}

enum ActorType {
  USER
  SYSTEM
  AUTOMATION
  SCHEDULER
}

// ============================================
// WORKFLOW TEMPLATES
// ============================================

model WorkflowTemplate {
  id                String   @id @default(cuid())
  orgId           String?
  code              String   @unique
  name              String
  description       String?
  category          WorkflowCategory
  industryType      IndustryType?

  // Template content
  definitionTemplate Json    // Pre-configured workflow definition

  // Form templates
  formTemplates     Json?    // Associated form definitions

  // Usage
  usageCount        Int      @default(0)
  lastUsedAt        DateTime?

  // Status
  isActive          Boolean  @default(true)
  isSystem          Boolean  @default(false) // Built-in templates

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  createdById       String?

  @@index([category])
  @@index([isActive])
  @@index([orgId])

  @@map("wf_templates")
}

enum IndustryType {
  MANUFACTURING
  HEALTHCARE
  CONSTRUCTION
  RETAIL
  FINANCE
  TECHNOLOGY
  EDUCATION
  HOSPITALITY
  LOGISTICS
  ENERGY
  PHARMACEUTICAL
  AUTOMOTIVE
  AEROSPACE
  FOOD_BEVERAGE
  GENERAL
}

// ============================================
// APPROVAL CHAINS
// ============================================

model ApprovalChain {
  id                String   @id @default(cuid())
  orgId           String?
  name              String
  description       String?
  chainType         ApprovalChainType

  // Configuration
  levels            Json     // Array of approval levels with approvers
  requireAllLevels  Boolean  @default(true)
  skipOnUnavailable Boolean  @default(false)

  // Conditions
  conditions        Json?    // Conditions for when this chain applies

  isActive          Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  createdById       String?

  @@index([orgId])


  @@map("wf_approval_chains")
}

enum ApprovalChainType {
  SEQUENTIAL
  PARALLEL
  HIERARCHICAL
  DYNAMIC
}

// ============================================
// ESCALATION RULES
// ============================================

model EscalationRule {
  id                String   @id @default(cuid())
  orgId           String?
  name              String
  description       String?

  // Trigger
  triggerType       EscalationTrigger
  triggerValue      Int      // Hours/days depending on trigger type

  // Action
  actionType        EscalationActionType
  notifyUserIds     String[]
  notifyRoles       String[]

  // Scope
  workflowCategories WorkflowCategory[]
  priorityThreshold WorkflowPriority?

  isActive          Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([orgId])


  @@map("wf_escalation_rules")
}

enum EscalationTrigger {
  HOURS_PENDING
  HOURS_BEFORE_DUE
  PERCENT_SLA_ELAPSED
  NO_RESPONSE
  REJECTION_COUNT
}

enum EscalationActionType {
  NOTIFY
  REASSIGN
  ESCALATE_APPROVER
  AUTO_APPROVE
  AUTO_REJECT
  CANCEL
}

// ============================================
// NOTIFICATIONS
// ============================================

model WorkflowNotification {
  id                String   @id @default(cuid())
  orgId           String?
  instanceId        String?
  taskId            String?

  // Recipient
  recipientId       String
  recipientEmail    String?

  // Notification
  notificationType  NotificationType
  channel           NotificationChannel
  subject           String
  content           String
  metadata          Json?

  // Status
  status            NotificationStatus @default(PENDING)
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failureReason     String?

  // Retry
  retryCount        Int      @default(0)
  maxRetries        Int      @default(3)

  createdAt         DateTime @default(now())

  @@index([recipientId])
  @@index([status])
  @@index([notificationType])
  @@index([orgId])

  @@map("wf_notifications")
}

enum NotificationType {
  TASK_ASSIGNED
  APPROVAL_REQUIRED
  TASK_COMPLETED
  WORKFLOW_COMPLETED
  DEADLINE_REMINDER
  ESCALATION
  STATUS_UPDATE
  COMMENT_ADDED
  CUSTOM
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
  PUSH
  WEBHOOK
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

// ============================================
// WORKFLOW STEP APPROVALS
// ============================================

model WorkflowStepApproval {
  id                String   @id @default(cuid())
  orgId           String?
  stepId            String
  approverId        String
  approverName      String?
  approvalOrder     Int      @default(1)

  // Decision
  decision          ApprovalDecision?
  decidedAt         DateTime?
  comments          String?

  // Delegation
  delegatedFromId   String?
  delegatedReason   String?

  // Reminder
  reminderSentAt    DateTime?
  reminderCount     Int      @default(0)

  status            ApprovalStatus @default(PENDING)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([stepId, approverId])
  @@index([stepId])
  @@index([approverId])
  @@index([status])
  @@index([orgId])

  @@map("wf_step_approvals")
}

enum ApprovalStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  ESCALATED
  EXPIRED
  DELEGATED
  CANCELLED
}

enum ApprovalDecision {
  APPROVE
  APPROVED
  APPROVED_WITH_COMMENTS
  REJECT
  REJECTED
  RETURNED_FOR_REVISION
  REQUEST_CHANGES
  DELEGATE
  ABSTAIN
}

// ============================================
// AUTOMATION RULES
// ============================================

model AutomationRule {
  id                String   @id @default(cuid())
  orgId           String?
  name              String
  description       String?
  code              String   @unique

  // Trigger configuration
  triggerType       AutomationTriggerType
  triggerEvent      String?  // Event name for EVENT trigger
  triggerSchedule   String?  // Cron expression for SCHEDULED trigger
  triggerCondition  Json?    // Conditions that must be met

  // Action configuration
  actionType        AutomationActionType
  actionConfig      Json     // Action-specific configuration

  // Scope
  entityType        String?  // Entity type this rule applies to
  workflowCategory  WorkflowCategory?

  // Execution settings
  priority          Int      @default(0)
  maxRetries        Int      @default(3)
  retryDelaySeconds Int      @default(60)
  timeoutSeconds    Int      @default(300)

  // Status
  isActive          Boolean  @default(true)
  lastExecutedAt    DateTime?
  executionCount    Int      @default(0)
  failureCount      Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  createdById       String?

  // Relations
  executions        AutomationExecution[]

  @@index([triggerType])
  @@index([isActive])
  @@index([entityType])
  @@index([orgId])

  @@map("wf_automation_rules")
}

enum AutomationTriggerType {
  EVENT           // Triggered by system events
  SCHEDULED       // Triggered by cron schedule
  CONDITION       // Triggered when conditions are met
  WORKFLOW_EVENT  // Triggered by workflow events
  API             // Triggered via API call
  WEBHOOK         // Triggered by external webhook
}

enum AutomationActionType {
  CREATE_WORKFLOW    // Start a new workflow
  UPDATE_ENTITY      // Update an entity
  SEND_NOTIFICATION  // Send email/SMS/push
  CALL_WEBHOOK       // Call external API
  EXECUTE_SCRIPT     // Run custom script
  ASSIGN_TASK        // Create and assign a task
  ESCALATE           // Escalate to higher level
  UPDATE_STATUS      // Change status of entity
  GENERATE_REPORT    // Generate a report
  CUSTOM             // Custom action handler
}

// ============================================
// AUTOMATION EXECUTIONS
// ============================================

model AutomationExecution {
  id                String   @id @default(cuid())
  orgId           String?
  ruleId            String

  // Execution context
  triggeredBy       String?  // User ID or 'SYSTEM'
  triggerType       AutomationTriggerType
  triggerData       Json?    // Data that triggered the execution

  // Target entity
  entityType        String?
  entityId          String?

  // Execution details
  status            AutomationExecutionStatus @default(PENDING)
  startedAt         DateTime?
  completedAt       DateTime?

  // Result
  result            Json?
  output            String?
  errorMessage      String?
  errorStack        String?

  // Retry info
  attemptNumber     Int      @default(1)
  nextRetryAt       DateTime?

  // Performance
  durationMs        Int?

  createdAt         DateTime @default(now())

  // Relations
  rule              AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([status])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([orgId])

  @@map("wf_automation_executions")
}

enum AutomationExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
  TIMEOUT
}

// ============================================
// APPROVAL REQUESTS (Standalone)
// ============================================

model ApprovalRequest {
  id                String   @id @default(cuid())
  orgId           String?
  requestNumber     String   @unique

  // Request details
  title             String
  description       String?
  requestType       ApprovalRequestType
  priority          WorkflowPriority @default(NORMAL)

  // Requester
  requesterId       String
  requesterName     String?
  departmentId      String?

  // Entity reference
  entityType        String?
  entityId          String?
  entityData        Json?    // Snapshot of entity at request time

  // Approval chain
  approvalChainId   String?
  currentLevel      Int      @default(1)
  totalLevels       Int      @default(1)

  // Status
  status            ApprovalRequestStatus @default(PENDING)

  // Timeline
  submittedAt       DateTime @default(now())
  dueDate           DateTime?
  decidedAt         DateTime?

  // Outcome
  outcome           ApprovalOutcome?
  outcomeReason     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  createdBy         String?
  updatedBy         String?

  // Relations
  responses         ApprovalResponse[]

  @@index([requesterId])
  @@index([status])
  @@index([requestType])
  @@index([entityType, entityId])
  @@index([orgId])

  @@map("wf_approval_requests")
}

enum ApprovalRequestType {
  DOCUMENT_APPROVAL
  PURCHASE_REQUEST
  LEAVE_REQUEST
  EXPENSE_CLAIM
  CHANGE_REQUEST
  ACCESS_REQUEST
  POLICY_EXCEPTION
  BUDGET_APPROVAL
  CONTRACT_APPROVAL
  CUSTOM
}

enum ApprovalRequestStatus {
  DRAFT
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  ON_HOLD
}

enum ApprovalOutcome {
  APPROVED
  REJECTED
  APPROVED_WITH_CONDITIONS
  PARTIALLY_APPROVED
  CANCELLED
  EXPIRED
}

// ============================================
// WEBHOOKS
// ============================================

model Webhook {
  id          String   @id @default(cuid())
  orgId           String?
  name        String
  url         String
  secret      String   // HMAC secret for signature verification
  events      String[] // Array of event types to subscribe to
  isActive    Boolean  @default(true)
  headers     Json?    // Custom headers to send
  retryCount  Int      @default(3)
  timeout     Int      @default(5000) // ms
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  deliveries WebhookDelivery[]

  @@index([isActive])
  @@index([createdAt])
  @@index([orgId])

  @@map("webhooks")
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  orgId           String?
  webhookId   String
  event       String   // e.g., "incident.created"
  payload     Json
  statusCode  Int?
  response    String?
  success     Boolean  @default(false)
  attempts    Int      @default(0)
  lastError   String?
  deliveredAt DateTime?
  createdAt   DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([event])
  @@index([success])
  @@index([createdAt])
  @@index([orgId])

  @@map("webhook_deliveries")
}

// ============================================
// APPROVAL RESPONSES
// ============================================

model ApprovalResponse {
  id                String   @id @default(cuid())
  orgId           String?
  requestId         String

  // Approver
  approverId        String
  approverName      String?
  approverRole      String?
  level             Int      @default(1)

  // Decision
  decision          ApprovalDecision
  comments          String?
  conditions        String?  // For conditional approvals

  // Delegation
  delegatedFromId   String?
  delegatedFromName String?

  // Attachments
  attachments       Json?

  respondedAt       DateTime @default(now())

  // Relations
  request           ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)


  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([requestId])
  @@index([approverId])
  @@index([orgId])

  @@map("wf_approval_responses")
}
