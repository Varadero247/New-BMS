// HR Schema - Human Resources Domain
// This schema is used by the HR microservice
// Database: ims_hr

generator client {
  provider = "prisma-client-js"
  output   = "../../generated/hr"
}

datasource db {
  provider = "postgresql"
  url      = env("HR_DATABASE_URL")
}

// ============================================
// EMPLOYEES
// ============================================

model Employee {
  id             String    @id @default(cuid())
  userId         String    @unique // Reference to User in core DB
  employeeCode   String    @unique
  firstName      String
  lastName       String
  email          String    @unique
  phone          String?
  departmentId   String?
  positionId     String?
  managerId      String? // Self-reference for org hierarchy
  hireDate       DateTime
  terminationDate DateTime?
  employmentType EmploymentType @default(FULL_TIME)
  status         EmployeeStatus @default(ACTIVE)
  salary         Decimal?       @db.Decimal(12, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  department        Department?        @relation(fields: [departmentId], references: [id])
  position          Position?          @relation(fields: [positionId], references: [id])
  manager           Employee?          @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates      Employee[]         @relation("EmployeeManager")
  attendanceRecords Attendance[]
  leaveRequests     LeaveRequest[]
  trainingRecords   TrainingRecord[]
  performanceReviews PerformanceReview[]
  documents         EmployeeDocument[]

  @@index([departmentId])
  @@index([managerId])
  @@index([status])
  @@map("employees")
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  TEMPORARY
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

// ============================================
// DEPARTMENTS & POSITIONS
// ============================================

model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique
  description String?
  managerId   String? // User ID from core DB
  parentId    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  employees Employee[]
  positions Position[]

  @@map("departments")
}

model Position {
  id           String   @id @default(cuid())
  title        String
  code         String   @unique
  description  String?
  departmentId String?
  level        Int      @default(1) // Job level for hierarchy
  minSalary    Decimal? @db.Decimal(12, 2)
  maxSalary    Decimal? @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department? @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@map("positions")
}

// ============================================
// ATTENDANCE
// ============================================

model Attendance {
  id         String           @id @default(cuid())
  employeeId String
  date       DateTime         @db.Date
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENT)
  hoursWorked Decimal?        @db.Decimal(4, 2)
  overtime   Decimal?         @db.Decimal(4, 2)
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([status])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  REMOTE
  HOLIDAY
  LEAVE
}

// ============================================
// LEAVE MANAGEMENT
// ============================================

model LeaveRequest {
  id          String      @id @default(cuid())
  employeeId  String
  leaveType   LeaveType
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  days        Decimal     @db.Decimal(4, 1)
  reason      String?
  status      LeaveStatus @default(PENDING)
  approvedBy  String? // User ID from core DB
  approvedAt  DateTime?
  rejectedReason String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  BEREAVEMENT
  UNPAID
  STUDY
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ============================================
// TRAINING
// ============================================

model TrainingRecord {
  id              String         @id @default(cuid())
  employeeId      String
  trainingName    String
  trainingType    TrainingType
  provider        String?
  startDate       DateTime       @db.Date
  endDate         DateTime?      @db.Date
  hoursCompleted  Decimal?       @db.Decimal(5, 1)
  status          TrainingStatus @default(SCHEDULED)
  score           Decimal?       @db.Decimal(5, 2) // Percentage score if applicable
  certificateUrl  String?
  expiryDate      DateTime?      @db.Date
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([expiryDate])
  @@map("training_records")
}

enum TrainingType {
  ONBOARDING
  COMPLIANCE
  SAFETY
  TECHNICAL
  SOFT_SKILLS
  LEADERSHIP
  CERTIFICATION
  OTHER
}

enum TrainingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================
// PERFORMANCE REVIEWS
// ============================================

model PerformanceReview {
  id           String       @id @default(cuid())
  employeeId   String
  reviewerId   String // User ID from core DB
  reviewPeriod String // e.g., "2024-Q1", "2024-H1", "2024"
  reviewType   ReviewType
  rating       Decimal?     @db.Decimal(3, 2) // 1.00 - 5.00
  strengths    String?
  improvements String?
  goals        String?
  comments     String?
  status       ReviewStatus @default(DRAFT)
  submittedAt  DateTime?
  acknowledgedAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([reviewerId])
  @@index([status])
  @@map("performance_reviews")
}

enum ReviewType {
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  PROBATION
  PROJECT
}

enum ReviewStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
  COMPLETED
}

// ============================================
// EMPLOYEE DOCUMENTS
// ============================================

model EmployeeDocument {
  id          String       @id @default(cuid())
  employeeId  String
  documentType DocumentType
  title       String
  description String?
  fileUrl     String
  fileName    String
  fileSize    Int
  mimeType    String
  expiryDate  DateTime?    @db.Date
  isVerified  Boolean      @default(false)
  verifiedBy  String? // User ID from core DB
  verifiedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([documentType])
  @@index([expiryDate])
  @@map("employee_documents")
}

enum DocumentType {
  CONTRACT
  ID_PROOF
  ADDRESS_PROOF
  EDUCATION
  CERTIFICATION
  MEDICAL
  TAX
  OTHER
}
