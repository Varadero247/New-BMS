// Core Schema - Authentication, Users, Sessions, Audit
// This schema is used by the API Gateway and shared across all services
// Database: ims_core

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output   = "../../generated/core"
}

datasource db {
  provider = "postgresql"
  url      = env("CORE_DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  avatar        String?
  role          UserRole  @default(USER)
  department    String?
  jobTitle      String?
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  sessions  Session[]
  auditLogs AuditLog[]

  @@index([role])
  @@index([isActive])
  @@index([createdAt])
  @@map("users")
  @@index([deletedAt])
}

model Session {
  id             String   @id @default(cuid())
  userId         String
  token          String   @unique
  expiresAt      DateTime
  lastActivityAt DateTime @default(now())
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([lastActivityAt])
  @@map("sessions")
}

enum UserRole {
  ADMIN
  MANAGER
  AUDITOR
  USER
}

// ============================================
// AUDIT LOGGING
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // CREATE, UPDATE, DELETE, VIEW, LOGIN, LOGOUT, etc.
  entity    String // User, Incident, Risk, etc.
  entityId  String?
  changes   Json? // Before/after values for updates
  metadata  Json? // Additional context (IP, user agent, etc.)
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// ENHANCED AUDIT TRAIL (21 CFR Part 11)
// ============================================

model EnhancedAuditTrail {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  userId        String
  userEmail     String
  userFullName  String
  action        String   // CREATE | UPDATE | DELETE | APPROVE | SIGN | VIEW
  resourceType  String   // e.g. 'DeviceMasterRecord'
  resourceId    String
  resourceRef   String   // e.g. 'DMR-2602-0001'
  changes       Json     @default("[]") // Array of { field, oldValue, newValue }
  ipAddress     String
  userAgent     String
  sessionId     String   @default("")
  esignatureId  String?
  systemVersion String   @default("1.0.0")
  checksum      String   // SHA-256 tamper detection
  createdAt     DateTime @default(now())

  esignature ESignature? @relation(fields: [esignatureId], references: [id])

  @@index([tenantId, resourceType, resourceId])
  @@index([tenantId, userId])
  @@index([resourceType, resourceId])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("enhanced_audit_trail")
}

model ESignature {
  id            String   @id @default(cuid())
  userId        String
  userEmail     String
  userFullName  String
  meaning       String   // APPROVED | REVIEWED | RELEASED | VERIFIED | etc.
  reason        String
  resourceType  String
  resourceId    String
  resourceRef   String
  ipAddress     String
  userAgent     String
  checksum      String   // SHA-256 tamper detection
  valid         Boolean  @default(true)
  createdAt     DateTime @default(now())

  auditEntries EnhancedAuditTrail[]

  @@index([userId, createdAt])
  @@index([resourceType, resourceId])
  @@index([valid])
  @@map("esignatures")
}

// ============================================
// API KEYS (for service-to-service auth)
// ============================================

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique // Hashed API key (bcrypt)
  prefix      String    // First 12 chars for identification
  permissions String[]  // List of scopes/operations
  orgId       String    @default("default")
  createdById String    @default("")
  usageCount  Int       @default(0)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([keyHash])
  @@index([prefix])
  @@index([orgId])
  @@index([isActive])
  @@map("api_keys")
}

// ============================================
// DASHBOARD READ MODELS
// Read-only model definitions for gateway dashboard
// to query cross-domain aggregate data.
// No relations defined — scalar fields only.
// ============================================

enum ISOStandard {
  ISO_45001
  ISO_14001
  ISO_9001
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  ACTIVE
  UNDER_REVIEW
  MITIGATED
  CLOSED
  ACCEPTED
}

model Risk {
  id              String      @id @default(cuid())
  standard        ISOStandard
  title           String
  description     String
  category        String?
  source          String?
  likelihood      Int         @default(1)
  severity        Int         @default(1)
  detectability   Int         @default(1)
  riskScore       Int?
  riskLevel       RiskLevel?
  referenceNumber String?     @unique
  whoAtRisk       String?
  initialLikelihood       Int?
  initialSeverity         Int?
  initialRiskScore        Int?
  initialRiskLevel        RiskLevel?
  aiControlElimination    String?
  aiControlSubstitution   String?
  aiControlEngineering    String?
  aiControlAdministrative String?
  aiControlPPE            String?
  aiControlsGenerated     Boolean    @default(false)
  residualLikelihood      Int?
  residualSeverity        Int?
  residualRiskScore       Int?
  residualRiskLevel       RiskLevel?
  riskOwner               String?
  legalReference          String?
  createdBy               String?
  aspectType          String?
  environmentalImpact String?
  scale               Int?
  frequency           Int?
  legalImpact         Int?
  significanceScore   Int?
  processOwner   String?
  processInputs  String?
  processOutputs String?
  kpis           String?
  existingControls   String?
  additionalControls String?
  residualRisk       Int?
  status         RiskStatus @default(ACTIVE)
  reviewDate     DateTime?
  lastReviewedAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  @@index([standard, status])
  @@index([createdAt])
  @@index([riskLevel])
  @@map("risks")
  @@index([deletedAt])
}

enum IncidentType {
  INJURY
  NEAR_MISS
  DANGEROUS_OCCURRENCE
  OCCUPATIONAL_ILLNESS
  PROPERTY_DAMAGE
  FIRST_AID
  MEDICAL_TREATMENT
  LOST_TIME
  SPILL
  EMISSION
  WASTE_INCIDENT
  ENVIRONMENTAL_COMPLAINT
  REGULATORY_BREACH
  NON_CONFORMANCE
  CUSTOMER_COMPLAINT
  SUPPLIER_ISSUE
  PROCESS_DEVIATION
  PRODUCT_DEFECT
  AUDIT_FINDING
  // ISO 27001 Information Security Incident Types
  SECURITY_BREACH
  DATA_BREACH
  UNAUTHORIZED_ACCESS
  PHISHING_ATTEMPT
}

enum IncidentSeverity {
  MINOR
  MODERATE
  MAJOR
  CRITICAL
  CATASTROPHIC
}

enum IncidentStatus {
  OPEN
  UNDER_INVESTIGATION
  AWAITING_ACTIONS
  ACTIONS_IN_PROGRESS
  VERIFICATION
  CLOSED
}

model Incident {
  id              String           @id @default(cuid())
  standard        ISOStandard
  referenceNumber String           @unique @default(cuid())
  title           String
  description     String
  type            IncidentType
  severity        IncidentSeverity @default(MINOR)
  category        String?
  location        String?
  dateOccurred    DateTime
  dateReported    DateTime         @default(now())
  reporterId      String
  investigatorId  String?
  personsInvolved String?
  injuryType      String?
  bodyPart        String?
  daysLost        Int?
  treatmentType   String?
  environmentalMedia String?
  quantity           Float?
  unit               String?
  regulatoryReport   Boolean @default(false)
  productAffected      String?
  customerImpact       String?
  costOfNonConformance Float?
  immediateCause      String?
  rootCauses          String?
  contributingFactors String?
  status          IncidentStatus   @default(OPEN)
  closedAt        DateTime?
  riskId          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  @@index([standard, status])
  @@index([dateOccurred])
  @@index([reporterId])
  @@index([createdAt])
  @@map("incidents")
  @@index([deletedAt])
}

enum ActionType {
  CORRECTIVE
  PREVENTIVE
  IMPROVEMENT
  IMMEDIATE
  LONG_TERM
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  VERIFIED
  OVERDUE
  CANCELLED
}

model Action {
  id              String         @id @default(cuid())
  standard        ISOStandard
  referenceNumber String         @unique @default(cuid())
  title           String
  description     String
  type            ActionType
  priority        ActionPriority @default(MEDIUM)
  ownerId         String
  createdById     String
  dueDate         DateTime
  completedAt     DateTime?
  verifiedAt      DateTime?
  verificationMethod  String?
  verificationNotes   String?
  effectivenessRating Int?
  status          ActionStatus   @default(OPEN)
  estimatedCost   Float?
  actualCost      Float?
  riskId             String?
  incidentId         String?
  legalRequirementId String?
  objectiveId        String?
  aiAnalysisId       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  @@index([standard])
  @@index([status, dueDate])
  @@index([ownerId, status])
  @@index([type])
  @@index([priority])
  @@index([riskId])
  @@index([incidentId])
  @@index([createdById])
  @@index([createdAt])
  @@map("actions")
  @@index([deletedAt])
}

enum AIProvider {
  OPENAI
  ANTHROPIC
  GROK
}

enum AIAnalysisStatus {
  PENDING
  COMPLETED
  ACCEPTED
  PARTIALLY_ACCEPTED
  REJECTED
  ERROR
}

model AIAnalysis {
  id             String           @id @default(cuid())
  userId         String
  sourceType     String
  sourceId       String
  sourceData     Json
  prompt         String
  provider       AIProvider
  model          String?
  response       Json
  suggestedRootCause String?
  suggestedActions   Json?
  complianceGaps     Json?
  highlights         Json?
  status         AIAnalysisStatus @default(PENDING)
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  riskId         String?
  incidentId     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId])
  @@index([sourceType, sourceId])
  @@index([status])
  @@index([createdAt])
  @@map("ai_analyses")
}

model MonthlyTrend {
  id       String      @id @default(cuid())
  standard ISOStandard
  metric   String
  year     Int
  month    Int
  value    Float
  createdAt DateTime   @default(now())

  @@unique([standard, metric, year, month])
  @@index([standard, metric])
  @@map("monthly_trends")
}

model ComplianceScore {
  id             String      @id @default(cuid())
  standard       ISOStandard
  overallScore   Float       @default(0)
  riskScore      Float?
  incidentScore  Float?
  legalScore     Float?
  objectiveScore Float?
  actionScore    Float?
  trainingScore  Float?
  documentScore  Float?
  totalItems     Int         @default(0)
  compliantItems Int         @default(0)
  calculatedAt   DateTime    @default(now())

  @@unique([standard])
  @@map("compliance_scores")
}

// ============================================
// COMPLIANCE CALENDAR
// ============================================

enum ComplianceStandard {
  ISO_9001_CAL
  ISO_14001_CAL
  ISO_45001_CAL
  IATF_16949
  AS9100D
  ISO_13485
  COMBINED
}

enum ComplianceEventType {
  AUDIT
  LEGAL_REVIEW
  OBJECTIVE_REVIEW
  CAPA_DUE
  MANAGEMENT_REVIEW
  CERT_EXPIRY
  CALIBRATION_DUE
  TRAINING_EXPIRY
  PPAP_GATE
  FAI_DUE
  REGULATORY_SUBMISSION
}

enum ComplianceEventStatus {
  UPCOMING
  DUE_SOON
  OVERDUE
  COMPLETED
}

model ComplianceEvent {
  id          String                @id @default(cuid())
  title       String
  description String?
  type        ComplianceEventType
  standard    ComplianceStandard
  status      ComplianceEventStatus @default(UPCOMING)
  dueDate     DateTime
  completedAt DateTime?
  assigneeId  String?
  assignee    String?
  location    String?
  notes       String?
  recurrence  String?               // DAILY, WEEKLY, MONTHLY, QUARTERLY, ANNUALLY
  createdBy   String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  deletedAt   DateTime?

  @@index([dueDate])
  @@index([standard])
  @@index([type])
  @@index([status])
  @@index([standard, status])
  @@index([dueDate, status])
  @@index([assigneeId])
  @@index([createdAt])
  @@map("compliance_events")
  @@index([deletedAt])
}

// ============================================
// GDPR / DATA PROTECTION
// ============================================

model DataRetentionPolicy {
  id             String   @id @default(cuid())
  dataCategory   String   // e.g., "audit_logs", "incidents", "user_sessions"
  module         String   // e.g., "health-safety", "environment", "quality"
  retentionDays  Int      // Days to retain
  action         String   // "ARCHIVE" | "DELETE" | "ANONYMIZE"
  legalBasis     String?  // GDPR article or other legal basis
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([dataCategory, module])
  @@map("data_retention_policies")
}

model ErasureRequest {
  id          String    @id @default(cuid())
  userId      String
  userEmail   String
  reason      String?
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, REJECTED
  processedBy String?
  processedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@map("erasure_requests")
}

// ============================================
// AUTO-REPORT GENERATION
// ============================================

model GeneratedReport {
  id           String   @id @default(cuid())
  title        String
  type         String   // MANAGEMENT_REVIEW, AUDIT, KPI_PACK, COMPLIANCE_SUMMARY
  module       String?  // health-safety, environment, quality, etc.
  parameters   Json?    // Input parameters used to generate
  content      Json     // Report content/data
  htmlTemplate String?  // HTML template for PDF rendering
  format       String   @default("JSON") // JSON, HTML, PDF
  generatedBy  String
  createdAt    DateTime @default(now())

  @@index([type])
  @@index([module])
  @@index([createdAt])
  @@map("generated_reports")
}

// ============================================
// TEMPLATE LIBRARY
// ============================================

enum TemplateModule {
  HEALTH_SAFETY
  ENVIRONMENT
  QUALITY
  AUTOMOTIVE
  MEDICAL
  AEROSPACE
  HR
  PAYROLL
  WORKFLOWS
  PROJECT_MANAGEMENT
  INVENTORY
  CRM
  FINANCE
  INFOSEC
  ISO37001
  ISO42001
  ESG
  CMMS
  FOOD_SAFETY
  ENERGY
  FIELD_SERVICE
  ANALYTICS
}

enum TemplateCategory {
  RISK_ASSESSMENT
  INCIDENT_INVESTIGATION
  AUDIT
  MANAGEMENT_REVIEW
  CAPA
  COMPLIANCE
  INSPECTION
  TRAINING
  DESIGN_DEVELOPMENT
  PROCESS_CONTROL
  SUPPLIER
  CUSTOMER
  REGULATORY
  PLANNING
  REPORTING
  GENERAL
  CERTIFICATION
}

enum TemplateStatus {
  DRAFT
  ACTIVE
  DEPRECATED
  ARCHIVED
}

model Template {
  id             String           @id @default(cuid())
  code           String           @unique // TPL-{MODULE}-{NNN}
  name           String
  description    String?
  module         TemplateModule
  category       TemplateCategory
  status         TemplateStatus   @default(ACTIVE)
  version        Int              @default(1)
  tags           String[]
  fields         Json             // Array of FieldDefinition
  defaultContent Json?            // Default pre-filled values
  usageCount     Int              @default(0)
  isBuiltIn      Boolean          @default(true)
  createdBy      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  versions  TemplateVersion[]
  instances TemplateInstance[]

  @@index([module])
  @@index([category])
  @@index([status])
  @@index([module, category])
  @@index([module, status])
  @@index([isBuiltIn])
  @@index([usageCount])
  @@index([createdAt])
  @@map("templates")
  @@index([deletedAt])
}

model TemplateVersion {
  id             String   @id @default(cuid())
  templateId     String
  version        Int
  fields         Json
  defaultContent Json?
  changedById    String?
  changeNote     String?
  createdAt      DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId])
  @@index([createdAt])
  @@map("template_versions")
}

model TemplateInstance {
  id           String         @id @default(cuid())
  templateId   String
  templateCode String
  templateName String
  module       TemplateModule
  filledData   Json           // User-filled form data
  createdById  String
  referenceId  String?        // Link to created entity (e.g., risk ID, incident ID)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([module])
  @@index([createdById])
  @@index([referenceId])
  @@index([createdAt])
  @@map("template_instances")
}

// ============================================
// MSP (MANAGED SERVICE PROVIDER) LINKS
// ============================================

enum MspLinkStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

model MspLink {
  id                     String        @id @default(cuid())
  consultantUserId       String
  consultantEmail        String
  clientOrganisationId   String
  clientOrganisationName String
  status                 MspLinkStatus @default(ACTIVE)
  permissions            String[]      // READ | AUDIT | MANAGE | BILLING
  whiteLabel             Json?         // { brandName?, logoUrl?, primaryColor? }
  linkedAt               DateTime      @default(now())
  linkedBy               String
  lastAccessedAt         DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@unique([consultantUserId, clientOrganisationId, status], name: "unique_active_link")
  @@index([consultantUserId])
  @@index([clientOrganisationId])
  @@index([status])
  @@index([consultantUserId, status])
  @@index([linkedAt])
  @@map("msp_links")
}

// ============================================
// SAML SSO CONFIGURATION
// ============================================

model SamlConfig {
  id                         String   @id @default(cuid())
  orgId                      String   @unique
  entryPoint                 String
  issuer                     String
  cert                       String   @db.Text
  signatureAlgorithm         String   @default("sha256") // sha1 | sha256 | sha512
  enabled                    Boolean  @default(true)
  entityId                   String?
  assertionConsumerUrl       String?
  idpMetadataUrl             String?
  nameIdFormat               String?
  allowUnencryptedAssertions Boolean  @default(false)
  createdBy                  String   @default("")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([orgId])
  @@index([enabled])
  @@map("saml_configs")
}

// ============================================
// UNIFIED AUDIT PLANS
// ============================================

enum AuditPlanType {
  INTERNAL
  EXTERNAL
  SURVEILLANCE
  CERTIFICATION
}

model UnifiedAuditPlan {
  id        String        @id @default(cuid())
  standard  String
  title     String
  scope     String
  auditType AuditPlanType
  clauses   Json          // AuditClauseStatus[]
  orgId     String        @default("default")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([orgId])
  @@index([standard])
  @@index([auditType])
  @@index([createdAt])
  @@map("unified_audit_plans")
}

// ============================================
// CUSTOM ROLES (user-defined RBAC roles)
// ============================================

model CustomRole {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  permissions Json     // Array of { module: string, level: number }
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name])
  @@map("custom_roles")
}

// ============================================
// SCIM — Cross-domain Identity Management
// ============================================

model ScimToken {
  id        String   @id @default(cuid())
  token     String   @unique  // bearer token value
  orgId     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([active])
  @@map("scim_tokens")
}

model ScimUser {
  id          String   @id  // SCIM-assigned ID (arbitrary string, may come from IdP)
  externalId  String?
  userName    String   @unique
  displayName String   @default("")
  givenName   String   @default("")
  familyName  String   @default("")
  title       String?
  active      Boolean  @default(true)
  emails      Json     @default("[]")  // Array<{value, type, primary}>
  groups      Json     @default("[]")  // Array<{value, display}>
  orgId       String   @default("default")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
  @@index([userName])
  @@map("scim_users")
}

model ScimGroup {
  id          String   @id  // SCIM-assigned ID (e.g., "role-admin")
  displayName String
  members     Json     @default("[]")  // Array<{value, display}>
  orgId       String   @default("default")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
  @@map("scim_groups")
}
