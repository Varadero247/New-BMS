// ISO 37001:2016 Anti-Bribery Management System Schema
// Comprehensive schema for anti-bribery policy, due diligence, gifts register,
// training, risk assessment, and investigation management

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "../../generated/iso37001"
}

datasource db {
  provider = "postgresql"
  url      = env("ISO37001_DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum AbPolicyStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum AbDueDiligenceLevel {
  STANDARD
  ENHANCED
  SIMPLIFIED
}

enum AbDueDiligenceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
  FAILED
}

enum AbThirdPartyType {
  SUPPLIER
  AGENT
  INTERMEDIARY
  JOINT_VENTURE
  CONSULTANT
  SUBCONTRACTOR
  OTHER
}

enum AbRiskLevel {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum AbGiftType {
  GIFT
  HOSPITALITY
  ENTERTAINMENT
  TRAVEL
  FACILITATION_PAYMENT
  DONATION
  SPONSORSHIP
}

enum AbGiftStatus {
  PENDING_APPROVAL
  APPROVED
  DECLINED
  REPORTED
}

enum AbGiftDirection {
  GIVEN
  RECEIVED
}

enum AbTrainingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  OVERDUE
  EXPIRED
}

enum AbInvestigationStatus {
  REPORTED
  UNDER_INVESTIGATION
  SUBSTANTIATED
  UNSUBSTANTIATED
  CLOSED
}

enum AbInvestigationOutcome {
  NO_ACTION
  DISCIPLINARY
  TERMINATION
  PROSECUTION_REFERRAL
  POLICY_CHANGE
}

enum AbRiskCategory {
  COUNTRY
  SECTOR
  TRANSACTION
  BUSINESS_OPPORTUNITY
  BUSINESS_PARTNER
}

enum AbRiskAssessmentStatus {
  IDENTIFIED
  ASSESSED
  MITIGATED
  ACCEPTED
  CLOSED
}

// ============================================
// MODELS
// ============================================

/// Anti-bribery policy management — tracks policies, approvals, and versioning
model AbPolicy {
  id             String         @id @default(cuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  organisationId String?
  createdBy      String

  referenceNumber String?
  title          String
  description    String?
  content        String
  version        String?        @default("1.0")
  status         String         @default("DRAFT")
  approvedBy     String?
  approvedAt     DateTime?
  effectiveDate  DateTime?
  reviewDate     DateTime?
  policyType     String         // ANTI_BRIBERY, GIFTS_HOSPITALITY, WHISTLEBLOWING, DUE_DILIGENCE, FACILITATION_PAYMENTS
  scope          String?
  owner          String?
  notes          String?
  updatedBy      String?

  @@index([organisationId, deletedAt])
  @@index([organisationId, status])
  @@index([organisationId, policyType])
  @@map("ab_policies")
  @@index([deletedAt])
}

/// Third-party due diligence register — risk-based screening of business partners
model AbDueDiligence {
  id                String              @id @default(cuid())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  organisationId    String?
  createdBy         String

  referenceNumber   String?
  thirdPartyName    String
  thirdPartyType    String
  level             String              @default("STANDARD")
  status            AbDueDiligenceStatus @default(PENDING)
  country           String
  sector            String?
  industry          String?
  riskLevel         String              @default("MEDIUM")
  riskJustification String?
  assessmentDate    DateTime?
  expiryDate        DateTime?
  findings          String?
  recommendations   String?
  approvedBy        String?
  updatedBy         String?
  scopeOfEngagement String?
  notes             String?
  contactName       String?
  contactEmail      String?
  contractValue     Float?
  conditions        String?
  completedAt       DateTime?
  completedBy       String?

  @@index([organisationId, deletedAt])
  @@index([organisationId, status])
  @@index([deletedAt])
  @@map("ab_due_diligence")
}

/// Gifts, hospitality, and facilitation payments register
model AbGiftRegister {
  id               String         @id @default(cuid())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  organisationId   String
  createdBy        String

  description      String
  giftType         AbGiftType
  direction        AbGiftDirection
  value            Decimal        @db.Decimal(10, 2)
  currency         String         @default("GBP")
  recipientOrGiver String
  organisation     String?
  date             DateTime
  reason           String?
  status           AbGiftStatus   @default(PENDING_APPROVAL)
  approvedBy       String?
  approvedAt       DateTime?
  policyReference  String?

  @@index([organisationId, deletedAt])
  @@index([organisationId, status])
  @@index([organisationId, giftType])
  @@index([organisationId, direction])
  @@index([organisationId, date])
  @@map("ab_gift_register")
  @@index([deletedAt])
}

/// Anti-bribery awareness and compliance training records
model AbTrainingRecord {
  id            String           @id @default(cuid())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?
  organisationId String
  createdBy     String

  employeeId    String
  employeeName  String
  department    String?
  courseName    String
  courseType     String          // INDUCTION, ANNUAL_REFRESHER, ROLE_SPECIFIC, MANAGEMENT
  status        AbTrainingStatus @default(NOT_STARTED)
  assignedDate  DateTime
  dueDate       DateTime
  completedDate DateTime?
  score         Int?
  passRequired  Boolean          @default(true)
  passMark      Int              @default(80)

  @@index([organisationId, deletedAt])
  @@index([organisationId, status])
  @@index([organisationId, employeeId])
  @@index([organisationId, dueDate])
  @@map("ab_training_records")
  @@index([deletedAt])
}

/// Bribery risk assessment — identifies, scores, and tracks mitigation of bribery risks
model AbRiskAssessment {
  id                 String                  @id @default(cuid())
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  deletedAt          DateTime?
  organisationId     String?
  createdBy          String
  updatedBy          String?

  referenceNumber    String?
  title              String
  description        String?
  category           String
  riskLevel          String                  @default("MEDIUM")
  businessFunction   String
  jurisdiction       String?
  country            String?
  likelihood         Int
  impact             Int
  riskScore          Int
  existingControls   String?
  mitigationMeasures String?
  mitigationPlan     String?
  residualRisk       String?
  residualLikelihood Int?
  residualImpact     Int?
  residualRiskScore  Int?
  residualRiskLevel  String?
  controlsAdded      String?
  mitigationOwner    String?
  targetDate         DateTime?
  owner              String?
  reviewDate         DateTime?
  notes              String?
  status             AbRiskAssessmentStatus  @default(IDENTIFIED)

  @@index([organisationId, deletedAt])
  @@index([organisationId, status])
  @@index([organisationId, riskLevel])
  @@map("ab_risk_assessments")
  @@index([deletedAt])
}

/// Investigation log — tracks reports, investigations, outcomes, and lessons learned
model AbInvestigation {
  id                     String                @id @default(cuid())
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  deletedAt              DateTime?
  organisationId         String?
  createdBy              String
  updatedBy              String?

  referenceNumber        String                @unique
  title                  String
  description            String?
  allegationType         String
  reportedBy             String
  reportedDate           DateTime
  department             String?
  location               String?
  involvedParties        String?
  estimatedValue         Float?
  currency               String                @default("USD")
  priority               String                @default("MEDIUM")
  notes                  String?
  anonymous              Boolean               @default(false)
  status                 AbInvestigationStatus @default(REPORTED)
  outcome                String?
  investigator           String?
  investigatorName       String?
  investigationNotes     String?
  investigationStartDate DateTime?
  findings               String?
  actions                String?
  actionsTaken           String?
  disciplinaryAction     String?
  reportedToAuthorities  Boolean               @default(false)
  authorityDetails       String?
  closedDate             DateTime?
  closedAt               DateTime?
  closedBy               String?
  lessonsLearned         String?

  @@index([organisationId, deletedAt])
  @@index([organisationId, status])
  @@index([organisationId, reportedDate])
  @@index([referenceNumber])
  @@map("ab_investigations")
  @@index([deletedAt])
}

// ============================================
// COMPLIANCE TRACKING (ISO 37001 §6)
// ============================================

enum AbComplianceStatus {
  COMPLIANT
  NON_COMPLIANT
  PARTIALLY_COMPLIANT
  NOT_APPLICABLE
  UNDER_REVIEW
}

enum AbComplianceCategory {
  POLICY
  PROCEDURE
  CONTROL
  TRAINING
  DUE_DILIGENCE
  REPORTING
  MONITORING
  MANAGEMENT_REVIEW
  OTHER
}

model AbCompliance {
  id              String                @id @default(cuid())
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deletedAt       DateTime?
  organisationId  String
  createdBy       String

  referenceNumber String                @unique
  title           String
  description     String?
  isoClause       String?
  category        AbComplianceCategory  @default(OTHER)
  status          AbComplianceStatus    @default(UNDER_REVIEW)
  owner           String?
  department      String?

  // Assessment
  assessmentDate  DateTime?
  nextReviewDate  DateTime?
  evidence        String?
  gaps            String?
  remediation     String?
  remediationDue  DateTime?
  remediationBy   String?

  // Outcome
  closedDate      DateTime?
  closedBy        String?
  closureNotes    String?
  notes           String?

  @@index([organisationId, deletedAt])
  @@index([organisationId, status])
  @@index([referenceNumber])
  @@map("ab_compliance")
  @@index([deletedAt])
}
