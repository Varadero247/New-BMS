// ============================================
// UDI Management (EU MDR / FDA)
// ============================================

model UdiDevice {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  refNumber       String    @unique  // UDI-YYMM-XXXX
  deviceName      String
  modelNumber     String
  manufacturer    String
  deviceClass     DeviceClass
  riskClass       String?
  gmdn            String?   // GMDN code
  emdn            String?   // EMDN code
  diRecords       UdiDiRecord[]
  piRecords       UdiPiRecord[]
  submissions     UdiSubmission[]
  status          UdiDeviceStatus @default(DRAFT)
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, status])
  @@index([modelNumber])
  @@map("udi_devices")
}

model UdiDiRecord {
  id              String    @id @default(cuid())
  deviceId        String
  issuingAgency   String    // GS1, HIBCC, ICCBBA
  diCode          String    @unique
  version         String?
  createdAt       DateTime  @default(now())

  device          UdiDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("udi_di_records")
}

model UdiPiRecord {
  id              String    @id @default(cuid())
  deviceId        String
  lotNumber       String?
  serialNumber    String?
  manufacturingDate DateTime?
  expirationDate  DateTime?
  createdAt       DateTime  @default(now())

  device          UdiDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("udi_pi_records")
}

model UdiSubmission {
  id              String    @id @default(cuid())
  deviceId        String
  database        UdiDatabase
  submissionDate  DateTime?
  status          UdiSubmissionStatus @default(PENDING)
  referenceNumber String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  device          UdiDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("udi_submissions")
}

enum DeviceClass {
  CLASS_I
  CLASS_IIA
  CLASS_IIB
  CLASS_III
}

enum UdiDeviceStatus {
  DRAFT
  ACTIVE
  DISCONTINUED
  RECALLED
}

enum UdiDatabase {
  GUDID
  EUDAMED
  UKCA
}

enum UdiSubmissionStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
  UPDATE_REQUIRED
}

// ============================================
// Post-Market Surveillance (EU MDR Article 83-86)
// ============================================

model PmsPlan {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  refNumber       String    @unique  // PMS-YYMM-XXXX
  deviceName      String
  deviceClass     String?
  dataSources     String[]  // JSON: complaints, MDRs, literature, MAUDE, etc.
  reviewFrequency String?   // e.g. "ANNUAL", "BIANNUAL"
  status          PmsPlanStatus @default(DRAFT)
  lastReviewDate  DateTime?
  nextReviewDate  DateTime?
  reports         PmsReport[]
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, status])
  @@map("pms_plans")
}

model PmsReport {
  id              String    @id @default(cuid())
  planId          String
  reportType      PmsReportType
  refNumber       String?
  periodStart     DateTime
  periodEnd       DateTime
  complaintCount  Int       @default(0)
  mdrCount        Int       @default(0)
  adverseEvents   Int       @default(0)
  literatureRefs  String?
  trendAnalysis   String?
  conclusions     String?
  actions         String?
  status          PmsReportStatus @default(DRAFT)
  approvedBy      String?
  approvedDate    DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  plan            PmsPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("pms_reports")
}

enum PmsPlanStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  ARCHIVED
}

enum PmsReportType {
  PSUR
  PMCF
  PMS_REPORT
  TREND_REPORT
}

enum PmsReportStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
}

// ============================================
// Software Validation (IEC 62304)
// ============================================

model SoftwareProject {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  refNumber       String    @unique  // SW-YYMM-XXXX
  title           String
  description     String?
  safetyClass     SoftwareSafetyClass
  currentPhase    SoftwarePhase @default(PLANNING)
  soupItems       SoupItem[]
  anomalies       SoftwareAnomaly[]
  phases          SoftwarePhaseDoc[]
  status          SoftwareProjectStatus @default(ACTIVE)
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, status])
  @@map("software_projects")
}

model SoupItem {
  id              String    @id @default(cuid())
  projectId       String
  title           String
  vendor          String?
  version         String
  intendedUse     String?
  knownAnomalies  String?
  riskAcceptable  Boolean   @default(false)
  verifiedDate    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project         SoftwareProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("soup_items")
}

model SoftwareAnomaly {
  id              String    @id @default(cuid())
  projectId       String
  refNumber       String?
  title           String
  description     String
  severity        AnomalySeverity @default(MINOR)
  status          AnomalyStatus @default(OPEN)
  resolution      String?
  resolvedDate    DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project         SoftwareProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@map("software_anomalies")
}

model SoftwarePhaseDoc {
  id              String    @id @default(cuid())
  projectId       String
  phase           SoftwarePhase
  documentRef     String?
  content         String?
  status          PhaseDocStatus @default(NOT_STARTED)
  reviewedBy      String?
  reviewedDate    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project         SoftwareProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, phase])
  @@index([projectId])
  @@map("software_phase_docs")
}

enum SoftwareSafetyClass {
  CLASS_A
  CLASS_B
  CLASS_C
}

enum SoftwarePhase {
  PLANNING
  REQUIREMENTS
  ARCHITECTURE
  DETAILED_DESIGN
  IMPLEMENTATION
  UNIT_TESTING
  INTEGRATION_TESTING
  SYSTEM_TESTING
  RELEASE
}

enum SoftwareProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum AnomalySeverity {
  COSMETIC
  MINOR
  MAJOR
  CRITICAL
}

enum AnomalyStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
  WONT_FIX
}

enum PhaseDocStatus {
  NOT_STARTED
  IN_PROGRESS
  REVIEW
  APPROVED
}

// ============================================
// REGULATORY SUBMISSIONS TRACKER (S4-05)
// ============================================

model RegulatorySubmission {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  refNumber       String    @unique  // REG-YYMM-XXXX
  deviceName      String
  market          RegulatoryMarket
  submissionType  SubmissionType
  status          SubmissionStatus @default(PREPARATION)
  submittedDate   DateTime?
  approvalDate    DateTime?
  expiryDate      DateTime?
  referenceNumber String?   // Regulatory body reference (e.g. K-number)
  conditions      String?   // Conditions of approval
  notes           String?
  changes         RegSubmissionChange[]
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, market])
  @@index([status])
  @@index([createdAt])
  @@map("regulatory_submissions")
}

model RegSubmissionChange {
  id              String    @id @default(cuid())
  submissionId    String
  changeType      String    // e.g. "Label Change", "Design Modification"
  description     String
  notificationDate DateTime?
  regulatoryResponse String?
  status          ChangeNotificationStatus @default(PENDING)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  submission      RegulatorySubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("reg_submission_changes")
}

enum RegulatoryMarket {
  FDA_510K
  FDA_DE_NOVO
  FDA_PMA
  EU_CE_MDR
  EU_CE_IVDR
  UKCA
  HEALTH_CANADA
  TGA_AUSTRALIA
  PMDA_JAPAN
  NMPA_CHINA
  ANVISA_BRAZIL
}

enum SubmissionType {
  INITIAL
  SUPPLEMENT
  RENEWAL
  AMENDMENT
  NOTIFICATION
}

enum SubmissionStatus {
  PREPARATION
  SUBMITTED
  UNDER_REVIEW
  ADDITIONAL_INFO_REQUESTED
  APPROVED
  CONDITIONALLY_APPROVED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum ChangeNotificationStatus {
  PENDING
  SUBMITTED
  ACKNOWLEDGED
  APPROVED
  REJECTED
}
