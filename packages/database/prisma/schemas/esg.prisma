// ESG & Sustainability Schema - Environmental, Social & Governance Module (Phase 4)
// This schema is used by the ESG microservice

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "../../generated/esg"
}

datasource db {
  provider = "postgresql"
  url      = env("ESG_DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum EsgCategory {
  ENVIRONMENTAL
  SOCIAL
  GOVERNANCE
}

enum EsgFrequency {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum EsgDataStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  REJECTED
}

enum EsgTargetStatus {
  ON_TRACK
  AT_RISK
  OFF_TRACK
  ACHIEVED
}

enum EsgReportType {
  ANNUAL
  QUARTERLY
  SUSTAINABILITY
  GRI
  SASB
  TCFD
  CDP
}

enum EsgReportStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
}

enum EsgInitiativeStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EsgEmissionScope {
  SCOPE_1
  SCOPE_2
  SCOPE_3
}

enum EsgWasteType {
  HAZARDOUS
  NON_HAZARDOUS
  RECYCLABLE
  ORGANIC
  ELECTRONIC
}

enum EsgDisposalMethod {
  LANDFILL
  RECYCLED
  INCINERATED
  COMPOSTED
  REUSED
}

enum EsgWaterType {
  INTAKE
  DISCHARGE
  RECYCLED
  CONSUMED
}

enum EsgEnergyType {
  ELECTRICITY
  NATURAL_GAS
  SOLAR
  WIND
  DIESEL
  OTHER
}

enum EsgSocialCategory {
  DIVERSITY
  HEALTH_SAFETY
  TRAINING
  COMMUNITY
  HUMAN_RIGHTS
  LABOR
}

enum EsgGovernanceCategory {
  BOARD
  ETHICS
  RISK
  COMPLIANCE
  TRANSPARENCY
  ANTI_CORRUPTION
}

enum EsgAuditType {
  INTERNAL
  EXTERNAL
  REGULATORY
}

enum EsgAuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum EsgStakeholderType {
  INVESTOR
  CUSTOMER
  EMPLOYEE
  REGULATOR
  COMMUNITY
  SUPPLIER
  NGO
}

enum EsgEngagementLevel {
  HIGH
  MEDIUM
  LOW
}

// ============================================
// FRAMEWORKS
// ============================================

model EsgFramework {
  id          String    @id @default(uuid())
  name        String
  code        String    @unique
  version     String
  description String?
  isActive    Boolean   @default(true)
  modules     Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdBy   String

  metrics EsgMetric[]

  @@map("esg_frameworks")
  @@index([deletedAt])
}

// ============================================
// METRICS
// ============================================

model EsgMetric {
  id          String       @id @default(uuid())
  frameworkId String
  category    EsgCategory
  subcategory String
  name        String
  code        String       @unique
  unit        String
  targetValue Decimal?
  description String?
  frequency   EsgFrequency
  isRequired  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  createdBy   String

  framework  EsgFramework  @relation(fields: [frameworkId], references: [id])
  dataPoints EsgDataPoint[]
  targets    EsgTarget[]

  @@index([frameworkId])
  @@index([category])
  @@index([code])
  @@map("esg_metrics")
  @@index([deletedAt])
}

// ============================================
// DATA POINTS
// ============================================

model EsgDataPoint {
  id          String        @id @default(uuid())
  metricId    String
  periodStart DateTime
  periodEnd   DateTime
  value       Decimal
  unit        String
  source      String?
  verifiedBy  String?
  verifiedAt  DateTime?
  notes       String?
  status      EsgDataStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  createdBy   String

  metric EsgMetric @relation(fields: [metricId], references: [id])

  @@index([metricId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("esg_data_points")
  @@index([deletedAt])
}

// ============================================
// TARGETS
// ============================================

model EsgTarget {
  id            String          @id @default(uuid())
  metricId      String
  year          Int
  targetValue   Decimal
  actualValue   Decimal?
  baselineYear  Int?
  baselineValue Decimal?
  status        EsgTargetStatus @default(ON_TRACK)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  createdBy     String

  metric EsgMetric @relation(fields: [metricId], references: [id])

  @@index([metricId])
  @@index([year])
  @@index([status])
  @@map("esg_targets")
  @@index([deletedAt])
}

// ============================================
// REPORTS
// ============================================

model EsgReport {
  id              String          @id @default(uuid())
  orgId           String?
  referenceNumber String?         @unique
  title           String
  reportType      EsgReportType
  year            Int
  quarter         Int?
  status          EsgReportStatus @default(DRAFT)
  publishedAt     DateTime?
  content         Json?
  aiGenerated     Boolean         @default(false)
  generatedBy     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String

  @@index([reportType])
  @@index([year])
  @@index([status])
  @@map("esg_reports")
  @@index([deletedAt])
}

// ============================================
// INITIATIVES
// ============================================

model EsgInitiative {
  id          String              @id @default(uuid())
  title       String
  description String?
  category    EsgCategory
  status      EsgInitiativeStatus @default(PLANNED)
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal?
  actualCost  Decimal?
  owner       String?
  impact      Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  createdBy   String

  @@index([category])
  @@index([status])
  @@map("esg_initiatives")
  @@index([deletedAt])
}

// ============================================
// EMISSIONS (GHG Protocol Scopes 1-3)
// ============================================

model EsgEmission {
  id            String           @id @default(uuid())
  scope         EsgEmissionScope
  category      String
  source        String
  quantity      Decimal
  unit          String
  co2Equivalent Decimal
  periodStart   DateTime
  periodEnd     DateTime
  methodology   String?
  verifiedBy    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?
  createdBy     String

  @@index([scope])
  @@index([periodStart, periodEnd])
  @@map("esg_emissions")
  @@index([deletedAt])
}

// ============================================
// WASTE MANAGEMENT
// ============================================

model EsgWaste {
  id             String           @id @default(uuid())
  wasteType      EsgWasteType
  quantity       Decimal
  unit           String
  disposalMethod EsgDisposalMethod
  periodStart    DateTime
  periodEnd      DateTime
  facility       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  createdBy      String

  @@index([wasteType])
  @@index([periodStart, periodEnd])
  @@map("esg_waste")
  @@index([deletedAt])
}

// ============================================
// WATER USAGE
// ============================================

model EsgWater {
  id          String       @id @default(uuid())
  usageType   EsgWaterType
  source      String?
  quantity    Decimal
  unit        String
  periodStart DateTime
  periodEnd   DateTime
  facility    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  createdBy   String

  @@index([usageType])
  @@index([periodStart, periodEnd])
  @@map("esg_water")
  @@index([deletedAt])
}

// ============================================
// ENERGY CONSUMPTION
// ============================================

model EsgEnergy {
  id          String        @id @default(uuid())
  energyType  EsgEnergyType
  quantity    Decimal
  unit        String
  renewable   Boolean       @default(false)
  periodStart DateTime
  periodEnd   DateTime
  facility    String?
  cost        Decimal?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  createdBy   String

  @@index([energyType])
  @@index([periodStart, periodEnd])
  @@map("esg_energy")
  @@index([deletedAt])
}

// ============================================
// SOCIAL METRICS
// ============================================

model EsgSocialMetric {
  id          String            @id @default(uuid())
  category    EsgSocialCategory
  metric      String
  value       Decimal
  unit        String?
  periodStart DateTime
  periodEnd   DateTime
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  createdBy   String

  @@index([category])
  @@index([periodStart, periodEnd])
  @@map("esg_social_metrics")
  @@index([deletedAt])
}

// ============================================
// GOVERNANCE METRICS
// ============================================

model EsgGovernanceMetric {
  id          String                @id @default(uuid())
  category    EsgGovernanceCategory
  metric      String
  value       String
  periodStart DateTime
  periodEnd   DateTime
  notes       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  deletedAt   DateTime?
  createdBy   String

  @@index([category])
  @@index([periodStart, periodEnd])
  @@map("esg_governance_metrics")
  @@index([deletedAt])
}

// ============================================
// ESG AUDITS
// ============================================

model EsgAudit {
  id        String         @id @default(uuid())
  title     String
  auditType EsgAuditType
  framework String?
  auditor   String?
  startDate DateTime?
  endDate   DateTime?
  status    EsgAuditStatus @default(PLANNED)
  findings  Json?
  score     Decimal?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
  createdBy String

  @@index([auditType])
  @@index([status])
  @@map("esg_audits")
  @@index([deletedAt])
}

// ============================================
// STAKEHOLDERS
// ============================================

model EsgStakeholder {
  id              String             @id @default(uuid())
  name            String
  type            EsgStakeholderType
  contactEmail    String?
  engagementLevel EsgEngagementLevel @default(MEDIUM)
  lastEngagement  DateTime?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  createdBy       String

  @@index([type])
  @@index([engagementLevel])
  @@map("esg_stakeholders")
  @@index([deletedAt])
}

// ============================================
// MATERIALITY ASSESSMENT
// ============================================

model EsgMateriality {
  id                       String      @id @default(uuid())
  topic                    String
  category                 EsgCategory
  importanceToStakeholders Decimal
  importanceToBusiness     Decimal
  isMaterial               Boolean     @default(false)
  description              String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  deletedAt                DateTime?
  createdBy                String

  @@index([category])
  @@map("esg_materiality")
  @@index([deletedAt])
}

// ============================================
// M9: Extended ESG Reporting Models
// ============================================

model EsgDefraFactor {
  id           String   @id @default(cuid())
  orgId        String
  category     String
  subcategory  String?
  activity     String
  unit         String
  factor       Float
  year         Int
  source       String   @default("DEFRA")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  deletedAt    DateTime?
  @@map("esg_defra_factors")
  @@index([orgId])
  @@index([category])
  @@index([deletedAt])
}

model EsgScopeEmission {
  id              String   @id @default(cuid())
  orgId           String
  referenceNumber String   @unique
  scope           Int
  category        String?
  source          String?
  activity        String?
  quantity        Float?
  unit            String?
  emissionFactor  Float?
  co2e            Float?
  period          String?
  location        String?
  verifiedBy      String?
  verifiedDate    DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
  deletedAt       DateTime?
  @@map("esg_scope_emissions")
  @@index([orgId])
  @@index([scope])
  @@index([deletedAt])
}

// ===== GRI & TCFD GAP CLOSURE MODELS =====

// GRI 2-26 - Ethics & Whistleblowing
model EsgWhistleblow {
  id                 String                  @id @default(uuid())
  referenceNumber    String                  @unique
  channel            String
  reportDate         DateTime                @default(now())
  category           EsgWhistleblowCategory
  description        String                  @db.Text
  anonymous          Boolean                 @default(false)
  status             EsgWhistleblowStatus    @default(RECEIVED)
  assignedTo         String?
  investigationNotes String?                 @db.Text
  outcomeCategory    String?
  outcome            String?                 @db.Text
  remedialActions    String?                 @db.Text
  closedAt           DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  deletedAt          DateTime?

  @@map("esg_whistleblows")
}

// GRI 2-29 - Stakeholder Engagement Plans
model EsgStakeholderPlan {
  id                     String   @id @default(uuid())
  stakeholderGroup       String
  engagementTopics       String[]
  methods                String[]
  frequency              String
  objectives             String   @db.Text
  responsibilityOwner    String
  year                   Int
  status                 String   @default("ACTIVE")
  outcomes               String?  @db.Text
  feedbackIncorporated   String?  @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?

  @@map("esg_stakeholder_plans")
}

// GRI 414-1 - Supplier Social Screening
model EsgSupplierSocialScreen {
  id                      String                 @id @default(uuid())
  supplierName            String
  supplierCountry         String
  screeningYear           Int
  isNewSupplier           Boolean                @default(true)
  screeningMethod         String
  criteriaAssessed        String[]
  labourPracticesResult   String?
  humanRightsResult       String?
  freedomAssocResult      String?
  childLabourResult       String?
  forcedLabourResult      String?
  wagesResult             String?
  nonDiscriminationResult String?
  overallResult           EsgSocialScreenResult  @default(PENDING)
  concernsIdentified      String?                @db.Text
  actionsTaken            String?                @db.Text
  followUpRequired        Boolean                @default(false)
  followUpDate            DateTime?
  followUpNotes           String?
  screenedBy              String
  screeningDate           DateTime               @default(now())
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  deletedAt               DateTime?

  @@map("esg_supplier_social_screens")
}

// TCFD - Climate Scenario Analysis
model EsgScenarioAnalysis {
  id                 String           @id @default(uuid())
  title              String
  scenarioType       EsgScenarioType
  scenarioName       String
  framework          String
  timeHorizon        String
  description        String           @db.Text
  assumptions        String           @db.Text
  physicalRisks      String?          @db.Text
  transitionRisks    String?          @db.Text
  financialImpact    String?          @db.Text
  opportunities      String?          @db.Text
  adaptationMeasures String?          @db.Text
  resilienceConclusion String?        @db.Text
  status             String           @default("DRAFT")
  approvedBy         String?
  approvedAt         DateTime?
  analysisYear       Int
  createdBy          String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  @@map("esg_scenario_analyses")
}

enum EsgWhistleblowCategory {
  FRAUD
  CORRUPTION
  BRIBERY
  ENVIRONMENTAL
  HEALTH_SAFETY
  HUMAN_RIGHTS
  DATA_PRIVACY
  FINANCIAL_MISCONDUCT
  HARASSMENT
  DISCRIMINATION
  OTHER
}

enum EsgWhistleblowStatus {
  RECEIVED
  ACKNOWLEDGED
  UNDER_INVESTIGATION
  AWAITING_INFORMATION
  RESOLVED
  CLOSED
}

enum EsgSocialScreenResult {
  PENDING
  PASSED
  CONCERNS_IDENTIFIED
  FAILED
  CORRECTIVE_PLAN_AGREED
  TERMINATED
}

enum EsgScenarioType {
  PHYSICAL
  TRANSITION
  COMBINED
}
