// Environment Schema - Environmental Management Domain (ISO 14001:2015 + 2024 Climate Amendment)
// This schema is used by the Environment microservice

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "../../generated/environment"
}

datasource db {
  provider = "postgresql"
  url      = env("ENVIRONMENT_DATABASE_URL")
}

// ============================================
// ENVIRONMENTAL ASPECTS (ISO 14001 Clause 6.1.2)
// ============================================

model EnvAspect {
  id                  String   @id @default(cuid())
  orgId           String?
  referenceNumber     String   @unique
  activityProcess     String
  activityCategory    EnvActivityCategory
  department          String
  location            String?
  lifecyclePhases     String[]
  operatingCondition  String?
  description         String?
  aspect              String
  impact              String
  impactDirection     EnvImpactDirection
  environmentalMedia  String[]
  scaleOfImpact       EnvScale
  // Significance Scoring (7 factors, each 1-5)
  scoreSeverity       Int       @default(1)
  scoreProbability    Int       @default(1)
  scoreDuration       Int       @default(1)
  scoreExtent         Int       @default(1)
  scoreReversibility  Int       @default(1)
  scoreRegulatory     Int       @default(1)
  scoreStakeholder    Int       @default(1)
  significanceScore   Int       @default(0)
  isSignificant       Boolean   @default(false)
  significanceOverride Boolean  @default(false)
  overrideReason      String?
  // Controls
  existingControls    String?
  controlHierarchy    EnvControlHierarchy?
  residualScore       Int?
  targetScore         Int?
  // Legal linkage
  legalReferences     String?
  permitReference     String?
  applicableStandards String?
  // Ownership
  responsiblePerson   String?
  reviewFrequency     EnvReviewFrequency?
  nextReviewDate      DateTime?
  status              String @default("ACTIVE")
  // AI
  aiSignificanceJustification  String?
  aiControlRecommendations     String?
  aiLegalObligations           String?
  aiBenchmarkComparison        String?
  aiImprovementOpportunities   String?
  aiClimateRelevance           String?
  aiGenerated                  Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?
  createdBy           String?
  updatedBy           String?

  @@index([status])
  @@index([isSignificant])
  @@index([activityCategory])
  @@index([department])
  @@index([createdAt])
  @@index([orgId])

  @@map("env_aspects")
}

// ============================================
// ENVIRONMENTAL EVENTS (Spills, Near Misses, Exceedances, etc.)
// ============================================

model EnvEvent {
  id                       String   @id @default(cuid())
  orgId           String?
  referenceNumber          String   @unique
  eventType                EnvEventType
  severity                 EnvEventSeverity
  regulatoryNotification   Boolean  @default(false)
  regulatoryBody           String?
  notificationReference    String?
  dateOfEvent              DateTime
  dateReported             DateTime @default(now())
  location                 String
  gpsCoordinates           String?
  department               String
  reportedBy               String
  description              String
  immediateCause           String?
  contributingFactors      String?
  mediaAffected            String[]
  substanceInvolved        String?
  quantityReleased         Float?
  quantityUnit             String?
  concentration            String?
  receptorDistance          String?
  areaSecured              Boolean?
  immediateActions         String?
  spillKitUsed             Boolean?
  emergencyServicesCalled  Boolean?
  materialsUsed            String?
  cleanupDuration          String?
  rcaMethod                EnvRCAMethod?
  rootCause                String?
  linkedAspectId           String?
  investigationLead        String?
  investigationDueDate     DateTime?
  investigationCompleted   DateTime?
  environmentalDamage      String?
  biodiversityImpact       Boolean?
  biodiversityDescription  String?
  waterCourseImpact        Boolean?
  waterCourseName          String?
  airQualityImpact         Boolean?
  remediationCost          Float?
  reputationalImpact       EnvReputationalImpact?
  capaRequired             Boolean?
  capaReference            String?
  preventiveMeasures       String?
  monitoringRequired       Boolean?
  monitoringDescription    String?
  followUpDate             DateTime?
  status                   String @default("REPORTED")
  closedBy                 String?
  closureDate              DateTime?
  lessonsLearned           String?
  sharedWithTeam           Boolean?
  // AI
  aiRootCauseAnalysis      String?
  aiImmediateActions       String?
  aiRegulatoryObligations  String?
  aiEnvironmentalImpact    String?
  aiPreventiveMeasures     String?
  aiCAPARecommendations    String?
  aiLessonsLearned         String?
  aiGenerated              Boolean @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  deletedAt                DateTime?
  createdBy                String?
  updatedBy                String?

  @@index([status])
  @@index([eventType])
  @@index([severity])
  @@index([dateOfEvent])
  @@index([linkedAspectId])
  @@index([department])
  @@index([createdAt])
  @@index([orgId])

  @@map("env_events")
}

// ============================================
// LEGAL REGISTER (ISO 14001 Clause 6.1.3)
// ============================================

model EnvLegal {
  id                      String   @id @default(cuid())
  orgId           String?
  referenceNumber         String   @unique
  obligationType          EnvObligationType
  title                   String
  jurisdiction            EnvJurisdiction
  regulatoryBody          String
  legislationReference    String
  relevantSection         String?
  effectiveDate           DateTime?
  expiryReviewDate        DateTime?
  status                  String @default("ACTIVE")
  description             String
  applicableActivities    String
  applicableSites         String?
  linkedAspects           String[]
  penalties               String?
  complianceStatus        String @default("NOT_ASSESSED")
  complianceEvidence      String?
  evidenceReference       String?
  lastAssessedDate        DateTime?
  assessedBy              String?
  assessmentMethod        EnvAssessmentMethod?
  complianceGaps          String?
  requiredActions         String?
  actionPriority          EnvPriority?
  actionsDueDate          DateTime?
  responsiblePerson       String?
  capaRequired            Boolean?
  monitoringRequirements  String?
  reportingRequirements   String?
  reportingFrequency      EnvReportingFrequency?
  nextReportingDue        DateTime?
  permitConditions        String?
  // AI
  aiKeyObligations        String?
  aiComplianceChecklist   String?
  aiGapAnalysis           String?
  aiRequiredActions       String?
  aiEvidenceRequired      String?
  aiMonitoring            String?
  aiPenalty               String?
  aiRecentChanges         String?
  aiGenerated             Boolean @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  deletedAt               DateTime?
  createdBy               String?
  updatedBy               String?

  @@index([complianceStatus])
  @@index([obligationType])
  @@index([status])
  @@index([createdAt])
  @@index([orgId])

  @@map("env_legal")
}

// ============================================
// ENVIRONMENTAL OBJECTIVES (ISO 14001 Clause 6.2)
// ============================================

model EnvObjective {
  id                     String   @id @default(cuid())
  orgId           String?
  referenceNumber        String   @unique
  title                  String
  objectiveStatement     String
  category               EnvObjectiveCategory
  status                 String @default("NOT_STARTED")
  policyCommitment       String?
  iso14001Clause         String?
  linkedAspects          String[]
  sdgAlignment           String[]
  netZeroTarget          Boolean  @default(false)
  netZeroDescription     String?
  kpiDescription         String?
  baselineValue          Float?
  baselineDate           DateTime?
  targetValue            Float?
  currentValue           Float    @default(0)
  unit                   String?
  measurementMethod      String?
  dataSource             String?
  startDate              DateTime?
  targetDate             DateTime
  department             String?
  owner                  String
  resourcesRequired      String?
  estimatedCost          Float?
  actionsRequired        Boolean  @default(false)
  reviewFrequency        EnvReviewFrequency?
  progressNotes          String?
  lastReviewDate         DateTime?
  progressPercent        Float    @default(0)
  // AI
  aiSmartAnalysis        String?
  aiImprovedStatement    String?
  aiSuggestedKPIs        String?
  aiSuggestedMilestones  String?
  aiBenchmarks           String?
  aiRisks                String?
  aiGenerated            Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?
  createdBy              String?
  updatedBy              String?
  // Relations
  milestones             EnvMilestone[]

  @@index([status])
  @@index([category])
  @@index([targetDate])
  @@index([createdAt])
  @@index([orgId])

  @@map("env_objectives")
}

model EnvMilestone {
  id            String       @id @default(cuid())
  orgId           String?
  objectiveId   String
  title         String
  dueDate       DateTime
  completed     Boolean      @default(false)
  completedDate DateTime?
  notes         String?
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  createdBy     String?
  updatedBy     String?
  objective     EnvObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@index([objectiveId])
  @@index([dueDate])
  @@index([orgId])

  @@map("env_milestones")
}

// ============================================
// ENVIRONMENTAL ACTIONS
// ============================================

model EnvAction {
  id               String    @id @default(cuid())
  orgId           String?
  referenceNumber  String    @unique
  title            String
  actionType       EnvActionType
  priority         String
  source           EnvActionSource
  sourceReference  String?
  description      String
  expectedOutcome  String?
  linkedAspectId   String?
  linkedEventId    String?
  linkedLegalId    String?
  linkedObjectiveId String?
  assignedTo       String
  department       String?
  dueDate          DateTime
  estimatedHours   Float?
  estimatedCost    Float?
  resourcesRequired String?
  status           String @default("OPEN")
  progressNotes    String?
  completionDate   DateTime?
  percentComplete  Int       @default(0)
  evidenceRefs     String?
  verificationMethod EnvVerificationMethod?
  verifiedBy       String?
  verificationDate DateTime?
  verificationNotes String?
  effective        EnvEffectiveness?
  // AI
  aiActionPlan     String?
  aiPriorityJustification String?
  aiResourceEstimate      String?
  aiObstacles      String?
  aiSuccessCriteria String?
  aiGenerated      Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  createdBy        String?
  updatedBy        String?

  @@index([status, dueDate])
  @@index([assignedTo])
  @@index([actionType])
  @@index([priority])
  @@index([linkedAspectId])
  @@index([linkedEventId])
  @@index([linkedLegalId])
  @@index([linkedObjectiveId])
  @@index([orgId])

  @@map("env_actions")
}

// ============================================
// CAPA MANAGEMENT (ISO 14001 Clause 10.2)
// ============================================

model EnvCapa {
  id                     String    @id @default(cuid())
  orgId           String?
  referenceNumber        String    @unique
  capaType               EnvCapaType
  title                  String
  severity               EnvCapaSeverity
  triggerSource          EnvCapaTrigger
  sourceReference        String?
  description            String
  dateInitiated          DateTime  @default(now())
  initiatedBy            String
  iso14001Clause         String?
  immediateActionRequired Boolean  @default(false)
  immediateActions       String?
  containmentVerifiedBy  String?
  containmentDate        DateTime?
  rcaMethod              EnvRCAMethod?
  // 5 Why fields
  problemStatement       String?
  why1                   String?
  why2                   String?
  why3                   String?
  why4                   String?
  why5                   String?
  // Fishbone fields
  fishbonePeople         String?
  fishboneProcess        String?
  fishbonePlant          String?
  fishbonePolicy         String?
  fishboneEnvironment    String?
  fishboneMeasurement    String?
  // Bowtie fields
  bowtieHazard           String?
  bowtieThreats          String?
  bowtiePreventive       String?
  bowtieConsequences     String?
  bowtieMitigating       String?
  rootCauseStatement     String?
  rootCauseCategory      EnvRootCauseCategory?
  effectivenessCriteria  String?
  effectivenessKPI       String?
  effectivenessTarget    String?
  effectivenessMethod    String?
  status                 String @default("INITIATED")
  progressNotes          String?
  percentComplete        Int       @default(0)
  responsiblePerson      String
  targetClosureDate      DateTime
  verificationDate       DateTime?
  verifiedBy             String?
  effectivenessAssessment String?
  recurrenceCheck        Boolean?
  actionsEffective       EnvEffectiveness?
  furtherActions         String?
  managementSignoff      String?
  closureDate            DateTime?
  lessonsLearned         String?
  sharedLessonsLearned   Boolean   @default(false)
  // AI
  aiRootCauseValidation  String?
  aiFiveWhyAnalysis      String?
  aiFishboneAnalysis     String?
  aiActionSufficiency    String?
  aiEffectivenessCriteria String?
  aiRecurrenceRisk       String?
  aiSystemicImplications String?
  aiLessonsLearned       String?
  aiGenerated            Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?
  createdBy              String?
  updatedBy              String?
  // Relations
  capaActions            EnvCapaAction[]

  @@index([status])
  @@index([capaType])
  @@index([severity])
  @@index([triggerSource])
  @@index([targetClosureDate])
  @@index([orgId])

  @@map("env_capas")
}

model EnvCapaAction {
  id          String   @id @default(cuid())
  orgId           String?
  capaId      String
  description String
  assignedTo  String
  dueDate     DateTime
  priority    String @default("MEDIUM")
  status      String @default("OPEN")
  notes       String?
  completedDate DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  createdBy     String?
  updatedBy     String?
  capa        EnvCapa  @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@index([capaId])
  @@index([status])
  @@index([dueDate])
  @@index([orgId])

  @@map("env_capa_actions")
}

// ============================================
// ENVIRONMENTAL AUDITS (ISO 14001 Clause 9.2)
// ============================================

model EnvAudit {
  id              String    @id @default(cuid())
  orgId           String?
  tenantId        String    @default("default")
  refNumber       String    @unique  // ENV-AUD-YYMM-XXXX
  title           String
  type            EnvAuditType
  scope           String
  auditDate       DateTime
  leadAuditor     String
  auditees        String[]
  department      String?
  auditTeam       String[]
  objective       String?
  criteria        String?
  methodology     String?
  status          String @default("PLANNED")
  iso14001Clauses String[]  // e.g. ["4.1","4.2","6.1.1","9.2"]
  openingMeetingDate DateTime?
  closingMeetingDate DateTime?
  reportDueDate   DateTime?
  completedDate   DateTime?
  recommendations String?
  aiAuditPlan     String?
  aiClauseAnalysis String?
  aiRiskAssessment String?
  aiRecommendations String?
  aiGenerated     Boolean   @default(false)
  findings        EnvAuditFinding[]
  summary         String?
  conclusions     String?
  nextAuditDate   DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  updatedBy       String?

  @@index([tenantId, status])
  @@index([tenantId, auditDate])
  @@index([status])
  @@index([orgId])

  @@map("env_audits")
}

model EnvAuditFinding {
  id              String              @id @default(cuid())
  orgId           String?
  auditId         String
  clause          String              // ISO 14001 clause reference e.g. "6.1.1"
  type            String
  description     String
  evidence        String?
  requirement     String?
  correctiveAction String?
  assignedTo      String?
  capaRef         String?             // Link to CAPA if NC
  status          String    @default("OPEN")
  dueDate         DateTime?
  closedDate      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  audit       EnvAudit            @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
  @@index([status])
  @@index([orgId])

  @@map("env_audit_findings")
}

model EnvAuditSchedule {
  id            String    @id @default(cuid())
  orgId           String?
  tenantId      String    @default("default")
  title         String
  type          EnvAuditType
  frequency     String
  nextDueDate   DateTime
  lastCompleted DateTime?
  assignedTo    String?
  assignedAuditor String?
  description   String?
  active        Boolean   @default(true)
  iso14001Clauses String[]
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  createdBy     String?
  updatedBy     String?

  @@index([tenantId, nextDueDate])
  @@index([isActive])
  @@index([orgId])

  @@map("env_audit_schedules")
}

// ============================================
// MANAGEMENT REVIEW (ISO 14001 Clause 9.3)
// ============================================

model EnvManagementReview {
  id                    String    @id @default(cuid())
  orgId           String?
  tenantId              String    @default("default")
  refNumber             String    @unique  // ENV-MR-YYYY-NN
  reviewDate            DateTime
  chair                 String
  attendees             String[]
  status                EnvReviewStatus @default(DRAFT)
  // ISO 14001 Clause 9.3 mandatory inputs
  prevActionStatus      String?
  changesInIssues       String?
  objectivesProgress    String?
  aspectsPerformance    String?
  legalCompliance       String?
  incidentSummary       String?
  auditResults          String?
  supplierPerformance   String?
  // ISO 14001 Clause 9.3 mandatory outputs
  continualImprovement  String?
  resourceNeeds         String?
  systemChanges         String?
  actions               EnvMRAction[]
  createdBy             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?
  updatedBy             String?

  @@index([tenantId, status])
  @@index([reviewDate])
  @@index([orgId])

  @@map("env_management_reviews")
}

model EnvMRAction {
  id          String              @id @default(cuid())
  orgId           String?
  reviewId    String
  action      String
  owner       String
  dueDate     DateTime
  status      EnvActionStatus     @default(OPEN)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  createdBy   String?
  updatedBy   String?

  review      EnvManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([status])
  @@index([dueDate])
  @@index([orgId])

  @@map("env_mr_actions")
}

// ============================================
// ENVIRONMENTAL MONITORING (kept from original)
// ============================================

model MonitoringData {
  id                     String   @id @default(cuid())
  orgId           String?
  monitoringPoint        String
  parameter              String
  unit                   String
  value                  Decimal  @db.Decimal(14, 6)
  limitValue             Decimal? @db.Decimal(14, 6)
  measurementDate        DateTime
  isCompliant            Boolean?
  exceedancePercent      Decimal? @db.Decimal(6, 2)
  measuredById           String?
  method                 String?
  equipmentUsed          String?
  calibrationDate        DateTime?
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?
  createdBy              String?
  updatedBy              String?

  @@index([monitoringPoint])
  @@index([parameter])
  @@index([measurementDate])
  @@index([orgId])

  @@map("env_monitoring_data")
}

// ============================================
// WASTE MANAGEMENT (kept from original)
// ============================================

model WasteRecord {
  id              String   @id @default(cuid())
  orgId           String?
  wasteType       WasteType
  wasteCategory   WasteCategory
  description     String?
  sourceLocation  String?
  sourceDepartment String?
  sourceProcess   String?
  quantity        Decimal  @db.Decimal(14, 4)
  unit            String
  storageLocation String?
  containerType   String?
  disposalMethod  DisposalMethod
  disposalDate    DateTime?
  disposalContractor String?
  wasteTransferNote String?
  hazardousWaste  Boolean  @default(false)
  ewcCode         String?
  status          WasteStatus @default(GENERATED)
  generatedDate   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  @@index([wasteType])
  @@index([status])
  @@index([generatedDate])
  @@index([orgId])

  @@map("env_waste_records")
}

// ============================================
// ENVIRONMENTAL METRICS (kept from original)
// ============================================

model EnvironmentalMetric {
  id    String @id @default(cuid())
  orgId           String?
  year  Int
  month Int
  electricityKwh      Decimal @default(0) @db.Decimal(14, 2)
  naturalGasM3        Decimal @default(0) @db.Decimal(14, 2)
  fuelLiters          Decimal @default(0) @db.Decimal(14, 2)
  renewableEnergyKwh  Decimal @default(0) @db.Decimal(14, 2)
  waterConsumptionM3  Decimal @default(0) @db.Decimal(14, 2)
  wastewaterM3        Decimal @default(0) @db.Decimal(14, 2)
  recycledWaterM3     Decimal @default(0) @db.Decimal(14, 2)
  totalWasteKg        Decimal @default(0) @db.Decimal(14, 2)
  recycledWasteKg     Decimal @default(0) @db.Decimal(14, 2)
  hazardousWasteKg    Decimal @default(0) @db.Decimal(14, 2)
  landfillWasteKg     Decimal @default(0) @db.Decimal(14, 2)
  co2EmissionsTonnes  Decimal @default(0) @db.Decimal(14, 4)
  scope1Emissions     Decimal @default(0) @db.Decimal(14, 4)
  scope2Emissions     Decimal @default(0) @db.Decimal(14, 4)
  scope3Emissions     Decimal @default(0) @db.Decimal(14, 4)
  recyclingRate       Decimal? @db.Decimal(6, 4)
  energyIntensity     Decimal? @db.Decimal(14, 4)
  waterIntensity      Decimal? @db.Decimal(14, 4)
  carbonIntensity     Decimal? @db.Decimal(14, 4)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?
  createdBy           String?
  updatedBy           String?

  @@unique([year, month])
  @@index([orgId])

  @@map("env_metrics")
}

// ============================================
// ENUMS
// ============================================

enum EnvActivityCategory {
  ENERGY_USE
  WATER_USE
  WASTE_GENERATION
  EMISSIONS_TO_AIR
  DISCHARGES_TO_WATER
  LAND_CONTAMINATION
  RESOURCE_USE
  NOISE_VIBRATION
  BIODIVERSITY
  TRANSPORT
  PROCUREMENT
  PRODUCT_DESIGN
  OTHER
}

enum EnvOperatingCondition {
  NORMAL
  ABNORMAL
  EMERGENCY
}

enum EnvImpactDirection {
  ADVERSE
  BENEFICIAL
}

enum EnvScale {
  LOCAL
  REGIONAL
  NATIONAL
  GLOBAL
}

enum EnvControlHierarchy {
  ELIMINATION
  SUBSTITUTION
  ENGINEERING
  ADMINISTRATIVE
  MONITORING
}

enum EnvReviewFrequency {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum EnvAspectStatus {
  ACTIVE
  UNDER_REVIEW
  CONTROLLED
  CLOSED
}

enum EnvEventType {
  SPILL_RELEASE
  NEAR_MISS
  REGULATORY_EXCEEDANCE
  STAKEHOLDER_COMPLAINT
  NON_CONFORMANCE
  ENVIRONMENTAL_EMERGENCY
  PERMIT_BREACH
  WASTE_MISMANAGEMENT
  NOISE_COMPLAINT
  OTHER
}

enum EnvEventSeverity {
  MINOR
  MODERATE
  MAJOR
  CRITICAL
  CATASTROPHIC
}

enum EnvEventStatus {
  REPORTED
  UNDER_INVESTIGATION
  CONTAINED
  REMEDIATED
  CLOSED
  REGULATORY_REVIEW
}

enum EnvReputationalImpact {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EnvRCAMethod {
  FIVE_WHY
  FISHBONE
  FAULT_TREE
  BOWTIE
  TIMELINE
  BARRIER_ANALYSIS
  OTHER
}

enum EnvObligationType {
  LEGISLATION
  REGULATION
  PERMIT
  LICENCE
  PLANNING_CONDITION
  INDUSTRY_STANDARD
  VOLUNTARY_COMMITMENT
  CONTRACTUAL
  ACOP
  GUIDANCE
}

enum EnvJurisdiction {
  UK
  EU
  INTERNATIONAL
  LOCAL_AUTHORITY
  OTHER
}

enum EnvLegalStatus {
  ACTIVE
  REVIEW_DUE
  SUPERSEDED
  ARCHIVED
}

enum EnvComplianceStatus {
  COMPLIANT
  PARTIALLY_COMPLIANT
  NON_COMPLIANT
  NOT_ASSESSED
  NOT_APPLICABLE
}

enum EnvAssessmentMethod {
  INTERNAL_AUDIT
  THIRD_PARTY_AUDIT
  SELF_ASSESSMENT
  REGULATORY_INSPECTION
  CONTINUOUS_MONITORING
}

enum EnvReportingFrequency {
  CONTINUOUS
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
  AS_REQUIRED
}

