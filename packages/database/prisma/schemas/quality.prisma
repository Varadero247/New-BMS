  meetingDate       DateTime
  chairperson       String?
  attendees         String?
  status            ManagementReviewStatus @default(PLANNED)

  // ISO 9001 §9.3.2 inputs
  previousActions   String?
  changesInContext   String?
  customerFeedback  String?
  qualityObjectives String?
  processPerformance String?
  nonconformanceSummary String?
  auditResults      String?
  supplierPerformance String?
  resourceAdequacy  String?
  riskAssessment    String?

  // ISO 9001 §9.3.3 outputs
  improvements      String?
  resourceNeeds     String?
  decisions         String?
  actionItems       String?
  nextReviewDate    DateTime?

  minutes           String?
  notes             String?

  organisationId    String
  createdBy         String
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  deletedAt         DateTime?

  @@map("qual_management_reviews")
  @@index([organisationId, deletedAt])
  @@index([status])
  @@index([meetingDate])
}
