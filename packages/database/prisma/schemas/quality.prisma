// Quality Schema - Quality Management Domain (ISO 9001:2015)
// 18 Qual-prefixed models for the Quality Management System
// Database: ims (shared) or ims_quality (microservice mode)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "../../generated/quality"
}

datasource db {
  provider = "postgresql"
  url      = env("QUALITY_DATABASE_URL")
}

// ============================================
// COTO LOG — INTERESTED PARTIES
// ============================================

model QualInterestedParty {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  partyName       String
  partyType       PartyType
  reasonForInclusion String
  needsExpectations  String?
  communicationMethod String?
  reviewFrequency ReviewFrequency @default(ANNUALLY)
  status          PartyStatus @default(ACTIVE)
  notes           String?

  // AI
  aiAnalysis      String?
  aiGenerated     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  // Relations
  issues          QualIssue[]

  @@index([partyType])
  @@index([status])
  @@index([createdAt])
  @@map("qual_interested_parties")
}

enum PartyType {
  INTERNAL
  EXTERNAL
}

enum PartyStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ReviewFrequency {
  MONTHLY
  QUARTERLY
  ANNUALLY
  BI_ANNUALLY
  ON_CHANGE
}

// ============================================
// COTO LOG — ISSUES REGISTER
// ============================================

model QualIssue {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  partyId         String?
  issueOfConcern  String
  bias            IssueBias
  processesAffected String?
  priority        IssuePriority @default(MEDIUM)
  treatmentMethod String
  recordReference String?
  status          IssueStatus @default(OPEN)
  notes           String?

  // AI
  aiAnalysis      String?
  aiGenerated     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  // Relations
  party           QualInterestedParty? @relation(fields: [partyId], references: [id])

  @@index([partyId])
  @@index([bias])
  @@index([priority])
  @@index([status])
  @@map("qual_issues")
}

enum IssueBias {
  RISK
  OPPORTUNITY
  MIXED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  UNDER_REVIEW
  TREATED
  MONITORED
  CLOSED
}

// ============================================
// COTO LOG — RISK REGISTER
// ============================================

model QualRisk {
  id                String   @id @default(cuid())
  referenceNumber   String   @unique
  process           QualRiskProcess
  riskDescription   String
  reportedBy        String?

  // Probability Assessment
  likelihood        Int      @default(1) // 1-6
  previousOccurrences String?
  probabilityRating Int      @default(1) // auto = likelihood

  // Consequence Assessment (each 0-5)
  lossOfContracts         Int @default(0)
  harmToUser              Int @default(0)
  unableToMeetTerms       Int @default(0)
  violationOfRegulations  Int @default(0)
  reputationImpact        Int @default(0)
  costOfCorrection        Int @default(0)
  consequenceRating       Int @default(0) // auto = max of above

  // Risk Scoring
  riskFactor        Int      @default(0) // auto = probability × consequence
  riskLevel         RiskLevel @default(LOW)

  // Treatment
  treatmentOption   TreatmentOption @default(ACCEPT)
  treatmentActions  String?
  responsiblePerson String?
  dueDate           DateTime?
  reviewDate        DateTime?
  status            RiskStatus @default(OPEN)

  // AI
  aiAnalysis        String?
  aiRootCauses      String?
  aiWarningIndicators String?
  aiTreatmentOptions String?
  aiResidualRisk    String?
  aiIsoClause       String?
  aiLinkedOpportunities String?
  aiGenerated       Boolean  @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  createdBy         String?
  updatedBy         String?

  @@index([riskLevel])
  @@index([status])
  @@index([process])
  @@index([dueDate])
  @@map("qual_risks")
}

enum QualRiskProcess {
  STRATEGIC
  FINANCE
  HR
  OPERATIONS
  MARKETING_SALES
  IT
  COMPLIANCE_LEGAL
  ALL_PROCESSES
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TreatmentOption {
  ACCEPT
  REDUCE
  TRANSFER
  AVOID
  CONTINGENCY
}

enum RiskStatus {
  OPEN
  BEING_TREATED
  MONITORED
  CLOSED
  ACCEPTED
}

// ============================================
// COTO LOG — OPPORTUNITY REGISTER
// ============================================

model QualOpportunity {
  id                  String   @id @default(cuid())
  referenceNumber     String   @unique
  process             QualRiskProcess
  interestedParties   String?
  opportunityDescription String
  reportedBy          String?

  // Probability Assessment
  likelihood          Int      @default(1) // 1-6
  previousOccurrences String?
  probabilityRating   Int      @default(1)

  // Benefit Assessment (each 0-4)
  newBusiness          Int @default(0)
  expansionOfCurrent   Int @default(0)
  satisfyingRegs       Int @default(0)
  internalQmsImprovement Int @default(0)
  reputationImprovement Int @default(0)
  costOfImplementation Int @default(0)

  benefitRating       Int      @default(0) // auto = max of above
  opportunityScore    Int      @default(0) // auto = probability × benefit
  priorityLevel       RiskLevel @default(LOW) // reuses LOW/MEDIUM/HIGH/CRITICAL

  // Action
  actionToExploit     String?
  responsiblePerson   String?
  targetDate          DateTime?
  status              OpportunityStatus @default(IDENTIFIED)

  // AI
  aiAnalysis          String?
  aiExploitationStrategy String?
  aiResourceRequirements String?
  aiKpis              String?
  aiRisksOfPursuing   String?
  aiGenerated         Boolean  @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?
  createdBy           String?
  updatedBy           String?

  @@index([priorityLevel])
  @@index([status])
  @@map("qual_opportunities")
}

enum OpportunityStatus {
  IDENTIFIED
  BEING_EXPLOITED
  ACHIEVED
  MISSED
  DEFERRED
}

// ============================================
// PROCESS REGISTER
// ============================================

model QualProcess {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  processName     String
  processType     ProcessType
  isoClause       String?
  department      String
  processOwner    String
  version         String   @default("1.0")
  status          ProcessStatus @default(DRAFT)

  // Turtle Diagram
  purposeScope    String
  inputs          String
  outputs         String
  customerOfOutput String?
  resourcesRequired String?
  competenceNeeded String?
  keyActivities   String?
  controlsMethods String?

  // Performance KPIs
  kpi1Description String?
  kpi1Target      String?
  kpi2Description String?
  kpi2Target      String?
  kpi3Description String?
  kpi3Target      String?
  monitoringMethod String?
  measurementFrequency MeasurementFrequency?

  // Linkage
  precedingProcesses String?
  followingProcesses String?
  relatedDocuments   String?
  relatedRiskRef     String?
  relatedLegalRef    String?

  // Review
  reviewFrequency ReviewFrequency @default(ANNUALLY)
  lastReviewed    DateTime?
  nextReviewDate  DateTime?
  reviewNotes     String?

  // AI
  aiAnalysis      String?
  aiProcessGaps   String?
  aiRiskPoints    String?
  aiKpiSuggestions String?
  aiIsoAlignment  String?
  aiGenerated     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  @@index([processType])
  @@index([status])
  @@map("qual_processes")
}

enum ProcessType {
  MANAGEMENT
  CORE
  SUPPORT
}

enum ProcessStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  RETIRED
}

enum MeasurementFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
}

// ============================================
// NON-CONFORMANCE REPORT
// ============================================

model QualNonConformance {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  ncType          NCType
  source          NCSource
  severity        NCSeverity @default(MINOR)
  isoClause       String?
  dateReported    DateTime @default(now())
  reportedBy      String
  department      String

  // Description
  title           String
  description     String
  evidenceRef     String?
  whereDetected   String?
  quantityAffected Int?
  quantityUnit    String?
  customerImpact  Boolean  @default(false)
  customerImpactDesc String?

  // Containment
  containmentRequired Boolean @default(false)
  containmentActions  String?
  productsQuarantined Boolean @default(false)
  customersNotified   Boolean @default(false)
  containmentEffectiveBy String?
  containmentDate     DateTime?

  // Root Cause
  rcaMethod       RCAMethod?
  why1            String?
  why2            String?
  why3            String?
  why4            String?
  why5            String?
  rootCause       String?
  rootCauseCategory RootCauseCategory?

  // CAPA
  capaRequired    Boolean  @default(false)
  capaReference   String?
  correctiveActions String?
  preventiveActions String?
  recurrencePrevention String?

  // Closure
  status          NCStatus @default(REPORTED)
  closedBy        String?
  closureDate     DateTime?
  effectivenessVerified EffectivenessStatus @default(PENDING)
  lessonsLearned  String?

  // Cross-module links
  linkedProcess   String?
  linkedFmea      String?
  linkedHsIncident String?
  linkedEnvEvent  String?

  // AI
  aiAnalysis      String?
  aiRootCauseSuggestions String?
  aiContainmentAdequacy String?
  aiCapaRecommendations String?
  aiIsoClause     String?
  aiGenerated     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  @@index([ncType])
  @@index([status])
  @@index([severity])
  @@index([dateReported])
  @@index([department])
  @@index([createdAt])
  @@map("qual_nonconformances")
}

enum NCType {
  INTERNAL
  CUSTOMER_COMPLAINT
  SUPPLIER
  REGULATORY
  AUDIT_FINDING
  PROCESS_FAILURE
  PRODUCT_DEFECT
  SERVICE_FAILURE
}

enum NCSource {
  INTERNAL_AUDIT
  CUSTOMER_FEEDBACK
  SUPPLIER_AUDIT
  PROCESS_MONITORING
  MANAGEMENT_REVIEW
  THIRD_PARTY_AUDIT
  INSPECTION
  OBSERVATION
}

enum NCSeverity {
  MINOR
  MODERATE
  MAJOR
  CRITICAL
}

enum RCAMethod {
  FIVE_WHY
  FISHBONE
  IS_IS_NOT
  EIGHT_D
  FAULT_TREE
  OTHER
}

enum RootCauseCategory {
  HUMAN_ERROR
  PROCESS_FAILURE
  EQUIPMENT
  MATERIAL
  MEASUREMENT
  ENVIRONMENT
  MANAGEMENT_SYSTEM
  SUPPLIER
}

enum NCStatus {
  REPORTED
  UNDER_REVIEW
  CONTAINED
  ROOT_CAUSE
  CAPA_RAISED
  VERIFICATION
  CLOSED
}

enum EffectivenessStatus {
  YES
  NO
  PENDING
}

// ============================================
// QUALITY ACTIONS
// ============================================

model QualAction {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  title           String
  actionType      QualActionType
  priority        ActionPriority @default(MEDIUM)
  source          ActionSource
  sourceReference String?
  description     String
  expectedOutcome String
  assignedTo      String
  department      String
  dueDate         DateTime
  status          ActionStatus @default(OPEN)
  progressNotes   String?
  completionDate  DateTime?
  percentComplete Int      @default(0)
  verificationMethod VerificationMethod?
  verifiedBy      String?
  verificationDate DateTime?
  effective       EffectivenessStatus?

  // Cross-links
  linkedNc        String?
  linkedCapa      String?
  linkedProcess   String?
  linkedFmea      String?

  // AI
  aiAnalysis      String?
  aiActionPlan    String?
  aiResourceEstimate String?
  aiSuccessCriteria String?
  aiGenerated     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  @@index([status])
  @@index([priority])
  @@index([actionType])
  @@index([assignedTo])
  @@index([dueDate])
  @@map("qual_actions")
}

enum QualActionType {
  CORRECTIVE
  PREVENTIVE
  IMPROVEMENT
  AUDIT_FINDING
  RISK_TREATMENT
  OBJECTIVE_SUPPORT
  LEGAL_COMPLIANCE
  OTHER
}

enum ActionSource {
  NC_REPORT
  CAPA
  INTERNAL_AUDIT
  MANAGEMENT_REVIEW
  RISK_REGISTER
  FMEA
  CUSTOMER_COMPLAINT
  SUPPLIER_AUDIT
  CONTINUAL_IMPROVEMENT
  OBJECTIVE
  OTHER
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  VERIFIED
  OVERDUE
  CANCELLED
}

enum VerificationMethod {
  DOCUMENT_REVIEW
  INSPECTION
  AUDIT
  TEST
  SIGN_OFF
}

// ============================================
// DOCUMENT CONTROL
// ============================================

model QualDocument {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  title           String
  documentType    DocumentType
  isoClause       String?
  linkedProcess   String?
  version         String   @default("1.0")
  status          DocumentStatus @default(DRAFT)
  language        String   @default("English")

  // Content
  purpose         String?
  scope           String?
  summary         String?
  keyChanges      String?

  // Ownership
  author          String
  ownerCustodian  String
  reviewer        String?
  approvedBy      String?
  issueDate       DateTime?
  effectiveDate   DateTime?
  nextReviewDate  DateTime?

  // Distribution
  distributionList String?
  accessLevel     AccessLevel @default(UNRESTRICTED)
  locationUrl     String?
  controlledCopies Int      @default(0)

  // Related
  supersedesDocument String?
  relatedProcedures  String?
  relatedForms       String?
  relatedRecords     String?

  // AI
  aiAnalysis      String?
  aiGapAnalysis   String?
  aiContentSuggestions String?
  aiGenerated     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  @@index([documentType])
  @@index([status])
  @@map("qual_documents")
}

enum DocumentType {
  POLICY
  PROCEDURE
  WORK_INSTRUCTION
  FORM
  RECORD
  SPECIFICATION
  DRAWING
  EXTERNAL
  PLAN
  REPORT
}

enum DocumentStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  ISSUED
  OBSOLETE
  SUPERSEDED
  EXTERNAL
}

enum AccessLevel {
  UNRESTRICTED
  CONTROLLED
  CONFIDENTIAL
  RESTRICTED
}

// ============================================
// CAPA MANAGEMENT
// ============================================

model QualCapa {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  capaType        CAPAType
  title           String
  severity        NCSeverity @default(MINOR)
  triggerSource   CAPATriggerSource
  sourceReference String?
  description     String
  isoClause       String?

  // Containment
  immediateActionRequired Boolean @default(false)
  actionsTaken    String?
  containmentVerifiedBy String?
  containmentDate DateTime?

  // Root Cause Analysis
  rcaMethod       RCAMethod?
  problemStatement String?
  why1            String?
  why2            String?
  why3            String?
  why4            String?
  why5            String?
  rootCauseStatement String?
  // Fishbone
  fishbonePeople  String?
  fishboneMethod  String?
  fishboneMachine String?
  fishboneMaterial String?
  fishboneMeasurement String?
  fishboneEnvironment String?
  // 8D
  d0EmergencyResponse String?
  d1Team          String?
  d2ProblemDescription String?
  d3Containment   String?
  d4RootCause     String?
  d5CorrectiveActions String?
  d6Implementation String?
  d7Prevention    String?
  d8CongratulateTeam String?

  rootCauseCategory RootCauseCategory?

  // Effectiveness
  effectivenessCriteria String?
  effectivenessKpi String?
  effectivenessTarget String?
  effectivenessMeasureMethod String?

  // Status
  status          CAPAStatus @default(INITIATED)
  progressNotes   String?
  percentComplete Int      @default(0)
  targetClosureDate DateTime?
  actualClosureDate DateTime?

  // Verification & Closure
  reviewDate      DateTime?
  verifiedBy      String?
  effectivenessAssessment String?
  recurrenceCheck Boolean?
  actionsEffective EffectivenessStatus?
  lessonsLearned  String?

  // Cross-module links
  linkedNc        String?
  linkedProcess   String?
  linkedFmea      String?
  linkedDocument  String?
  linkedHsCapa    String?
  linkedEnvCapa   String?

  // AI
  aiAnalysis      String?
  aiRootCauseValidation String?
  aiActionSuggestions String?
  aiEffectivenessCriteria String?
  aiSystemicImplications String?
  aiGenerated     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  // Relations
  capaActions     QualCapaAction[]

  @@index([capaType])
  @@index([status])
  @@index([severity])
  @@index([targetClosureDate])
  @@index([createdAt])
  @@map("qual_capas")
}

model QualCapaAction {
  id              String   @id @default(cuid())
  capaId          String
  action          String
  assignedTo      String
  dueDate         DateTime
  priority        ActionPriority @default(MEDIUM)
  status          ActionStatus @default(OPEN)
  notes           String?
  completedDate   DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  capa            QualCapa @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@index([capaId])
  @@index([status])
  @@index([dueDate])
  @@map("qual_capa_actions")
}

enum CAPAType {
  CORRECTIVE
  PREVENTIVE
  IMPROVEMENT
}

enum CAPATriggerSource {
  NC_REPORT
  CUSTOMER_COMPLAINT
  INTERNAL_AUDIT
  EXTERNAL_AUDIT
  MANAGEMENT_REVIEW
  SUPPLIER_AUDIT
  PROCESS_FAILURE
  FMEA
  RISK_REGISTER
  OTHER
}

enum CAPAStatus {
  INITIATED
  ROOT_CAUSE_ANALYSIS
  ACTIONS_DEFINED
  IMPLEMENTATION
  VERIFICATION
  CLOSED
  CANCELLED
}

// ============================================
// QUALITY LEGAL REGISTER
// ============================================

model QualLegal {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  title           String
  obligationType  LegalObligationType
  issuingBody     String?
  referenceDoc    String?
  description     String
  requirements    String?
  applicableScope String?

  // Quality-specific
  customerName    String?
  contractNumber  String?
  productServiceScope String?
  certificationBody String?

  // Compliance
  complianceStatus ComplianceStatus @default(NOT_ASSESSED)
  complianceNotes  String?
  gapAnalysis      String?
  lastAssessmentDate DateTime?
  nextAssessmentDate DateTime?

  // Monitoring
  responsiblePerson String?
  reviewFrequency ReviewFrequency @default(ANNUALLY)
  effectiveDate   DateTime?
  expiryDate      DateTime?
  status          LegalStatus @default(ACTIVE)

  // IMS cross-links
  trackedInHs     Boolean  @default(false)
  trackedInEnv    Boolean  @default(false)

  // AI
  aiAnalysis      String?
  aiComplianceChecklist String?
  aiGapAnalysis   String?
  aiGenerated     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  @@index([obligationType])
  @@index([complianceStatus])
  @@index([status])
  @@map("qual_legal")
}

enum LegalObligationType {
  PRODUCT_STANDARD
  CUSTOMER_CONTRACT
  REGULATORY
  INDUSTRY_CODE
  CERTIFICATION_REQUIREMENT
  VOLUNTARY_COMMITMENT
}

enum ComplianceStatus {
  COMPLIANT
  PARTIALLY_COMPLIANT
  NON_COMPLIANT
  NOT_ASSESSED
  UNDER_REVIEW
}

enum LegalStatus {
  ACTIVE
  PENDING
  EXPIRED
  SUPERSEDED
  WITHDRAWN
}

// ============================================
// FMEA
// ============================================

model QualFmea {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  fmeaType        FMEAType
  title           String
  productProcess  String
  partNumberRev   String?
  customer        String?
  teamMembers     String?
  scopeDescription String?
  linkedProcess   String?
  status          FMEAStatus @default(DRAFT)
  dateInitiated   DateTime @default(now())
  nextReviewDate  DateTime?

  // AIAG-VDA Harmonised Format support
  fmeaFormat      FmeaFormat @default(TRADITIONAL)
  actionPriority  FmeaActionPriority?
  preventionControls String?
  detectionControls  String?
  apRating        String?  // Action Priority rating for AIAG-VDA format

  // AI
  aiAnalysis      String?
  aiMissingFailureModes String?
  aiControlGaps   String?
  aiTopPriorityActions String?
  aiGenerated     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  // Relations
  rows            QualFmeaRow[]

  @@index([fmeaType])
  @@index([status])
  @@index([createdAt])
  @@map("qual_fmeas")
}

model QualFmeaRow {
  id              String   @id @default(cuid())
  fmeaId          String
  sortOrder       Int      @default(0)

  // Analysis
  itemProcessStep String?
  functionRequirement String?
  failureMode     String
  effectOfFailure String
  severity        Int      @default(1) // 1-10
  potentialCauses String
  currentPreventionControls String?
  occurrence      Int      @default(1) // 1-10
  currentDetectionControls String?
  detection       Int      @default(1) // 1-10

  // Scoring
  rpn             Int      @default(0) // auto S×O×D
  actionPriority  FMEAActionPriority @default(LOW)

  // Actions
  recommendedActions String?
  assignedTo      String?
  dueDate         DateTime?
  actionsTaken    String?

  // Revised scores
  revisedSeverity   Int?
  revisedOccurrence Int?
  revisedDetection  Int?
  revisedRpn        Int? // auto
  status          FMEARowStatus @default(OPEN)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fmea            QualFmea @relation(fields: [fmeaId], references: [id], onDelete: Cascade)

  @@index([fmeaId])
  @@index([rpn])
  @@map("qual_fmea_rows")
}

enum FMEAType {
  DFMEA
  PFMEA
  SFMEA
}

enum FMEAStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  ACTIVE
  ARCHIVED
}

enum FMEAActionPriority {
  LOW
  MEDIUM
  HIGH
}

enum FMEARowStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  VERIFIED
  ACCEPTED
}

enum FmeaFormat {
  TRADITIONAL
  AIAG_VDA_2024
}

enum FmeaActionPriority {
  HIGH
  MEDIUM
  LOW
}

// ============================================
// CONTINUAL IMPROVEMENT
// ============================================

model QualImprovement {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  title           String
  category        ImprovementCategory
  source          ImprovementSource
  submittedBy     String
  department      String?
  dateSubmitted   DateTime @default(now())

  // Description
  description     String
  currentState    String?
  proposedSolution String
  expectedBenefits String

  // Impact Assessment
  estimatedCost   Decimal? @db.Decimal(14, 2)
  estimatedTime   String?
  estimatedSaving Decimal? @db.Decimal(14, 2)
  qualityImpact   ImpactLevel @default(NONE)
  customerImpact  ImpactLevel @default(NONE)
  processImpact   ImpactLevel @default(NONE)
  environmentalImpact ImpactLevel @default(NONE)
  priorityScore   Int      @default(0) // auto-calculated

  // Evaluation
  status          ImprovementStatus @default(IDEA_SUBMITTED)
  evaluationNotes String?
  approvedBy      String?
  approvalDate    DateTime?
  pdcaStage       PDCAStage @default(PLAN)

  // Implementation
  linkedActions   String?
  pilotRequired   Boolean  @default(false)
  pilotResults    String?
