// Aerospace Schema - AS9100D / AS9110C Domain
// Used by the Aerospace microservice

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "../../generated/aerospace"
}

datasource db {
  provider = "postgresql"
  url      = env("AEROSPACE_DATABASE_URL")
}

// ============================================
// CONFIGURATION MANAGEMENT (AS9100D Clause 8.1.2)
// ============================================

model ConfigBaseline {
  id              String    @id @default(cuid())
  orgId           String?
  tenantId        String    @default("default")
  refNumber       String    @unique  // CB-NNN
  title           String
  description     String?
  program         String?
  status          BaselineStatus @default(DRAFT)
  effectiveDate   DateTime?
  approvedBy      String?
  approvedDate    DateTime?
  items           ConfigItem[]
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, status])
  @@index([effectiveDate])
  @@index([createdAt])
  @@index([orgId])

  @@map("config_baselines")
}

model ConfigItem {
  id              String    @id @default(cuid())
  orgId           String?
  baselineId      String
  partNumber      String
  nomenclature    String
  revision        String
  serialNumber    String?
  lotNumber       String?
  category        CICategory
  status          CIStatus @default(CURRENT)
  documentRef     String?
  specifications  String?
  supplier        String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  baseline        ConfigBaseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)

  @@index([baselineId])
  @@index([partNumber])
  @@index([status])
  @@index([orgId])
  @@index([deletedAt])

  @@map("config_items")
}

model EngineeringChangeProposal {
  id              String    @id @default(cuid())
  orgId           String?
  tenantId        String    @default("default")
  refNumber       String    @unique  // ECP-YYMM-XXXX
  title           String
  description     String
  reason          String
  urgency         ECPUrgency @default(ROUTINE)
  affectedItems   String[]  // Part numbers affected
  affectedBaselines String[] // Baseline IDs affected
  proposedBy      String
  proposedDate    DateTime  @default(now())
  status          ECPStatus @default(PROPOSED)
  ccbDecision     CCBDecision?
  ccbDate         DateTime?
  ccbMembers      String[]
  ccbNotes        String?
  implementedDate DateTime?
  verifiedDate    DateTime?
  verifiedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, status])
  @@index([urgency])
  @@index([orgId])

  @@map("engineering_change_proposals")
}

model ConfigAudit {
  id              String    @id @default(cuid())
  orgId           String?
  tenantId        String    @default("default")
  refNumber       String    @unique  // FCA-YYMM-XXXX or PCA-YYMM-XXXX
  type            ConfigAuditType
  title           String
  baselineId      String?
  auditDate       DateTime
  auditors        String[]
  status          ConfigAuditStatus @default(PLANNED)
  findings        String?   // JSON array of findings
  discrepancies   Int       @default(0)
  result          AuditResult?
  notes           String?
  completedDate   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, type])
  @@index([status])
  @@index([orgId])

  @@map("config_audits")
}

// ============================================
// ENUMS
// ============================================

enum BaselineStatus {
  DRAFT
  APPROVED
  ACTIVE
  SUPERSEDED
  ARCHIVED
}

enum CICategory {
  HARDWARE
  SOFTWARE
  FIRMWARE
  DOCUMENT
  TOOL
  TEST_EQUIPMENT
  MATERIAL
}

enum CIStatus {
  CURRENT
  SUPERSEDED
  OBSOLETE
  PENDING_CHANGE
}

enum ECPUrgency {
  EMERGENCY
  URGENT
  ROUTINE
}

enum ECPStatus {
  PROPOSED
  UNDER_REVIEW
  CCB_APPROVED
  CCB_REJECTED
  IMPLEMENTING
  IMPLEMENTED
  VERIFIED
  CLOSED
}

enum CCBDecision {
  APPROVE
  APPROVE_WITH_CONDITIONS
  REJECT
  DEFER
  MORE_INFO_NEEDED
}

enum ConfigAuditType {
  FCA
  PCA
}

enum ConfigAuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AuditResult {
  PASS
  PASS_WITH_FINDINGS
  FAIL
}

// ============================================
// FAI (First Article Inspection) - AS9102
// ============================================

model FirstArticleInspection {
  id              String    @id @default(cuid())
  orgId           String?
  tenantId        String    @default("default")
  refNumber       String    @unique  // FAI-YYMM-XXXX
  title           String
  partNumber      String
  partName        String
  revision        String
  drawingNumber   String?
  customer        String?
  poNumber        String?
  faiType         FAIType   @default(FULL)
  status          FAIStatus @default(PLANNING)
  // Part 1 - Design Characteristics
  part1Data       String?   // JSON: array of {charNum, charName, nominal, tolerance, actual, pass}
  part1Status     FAIPartStatus @default(NOT_STARTED)
  // Part 2 - Manufacturing Process Documentation
  part2Data       String?   // JSON: array of {docType, docNumber, revision, available}
  part2Status     FAIPartStatus @default(NOT_STARTED)
  // Part 3 - Test Results
  part3Data       String?   // JSON: array of {testName, testMethod, requirement, result, pass}
  part3Status     FAIPartStatus @default(NOT_STARTED)
  approvedBy      String?
  approvedDate    DateTime?
  esignatureId    String?
  openItems       String?   // JSON: partial FAI open items
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, status])
  @@index([partNumber])
  @@index([createdAt])
  @@index([orgId])

  @@map("first_article_inspections")
}

// ============================================
// ADDITIONAL ENUMS
// ============================================

enum FAIType {
  FULL
  PARTIAL
  DELTA
}

enum FAIStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  APPROVED
  APPROVED_PARTIAL
  REJECTED
}

enum FAIPartStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  NEEDS_REVIEW
}

// ============================================
// MRO Work Orders (AS9110)
// ============================================

model WorkOrder {
  id              String    @id @default(cuid())
  orgId           String?
  tenantId        String    @default("default")
  refNumber       String    @unique  // WO-YYMM-XXXX
  title           String
  aircraftType    String
  aircraftReg     String?
  description     String
  priority        WoPriority @default(ROUTINE)
  status          WoStatus @default(OPEN)
  tasks           TaskCard[]
  assignedTo      String?
  startDate       DateTime?
  dueDate         DateTime?
  completedDate   DateTime?
  releaseCertType ReleaseCertType?
  releaseCertRef  String?
  releasedBy      String?
  releasedDate    DateTime?
  esignatureId    String?
  inspectedBy     String?
  inspectedDate   DateTime?
  deferralRef     String?   // MEL/CDL reference if deferred
  deferralNotes   String?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, status])
  @@index([aircraftReg])
  @@index([priority])
  @@index([dueDate])
  @@index([createdAt])
  @@index([orgId])

  @@map("work_orders")
}

model TaskCard {
  id              String    @id @default(cuid())
  orgId           String?
  workOrderId     String
  taskNumber      String
  description     String
  zone            String?
  access          String?
  estimatedHours  Float?
  actualHours     Float?
  status          TaskCardStatus @default(OPEN)
  technicianId    String?
  technicianName  String?
  signedDate      DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workOrder       WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([status])
  @@index([orgId])

  @@map("task_cards")
}

enum WoPriority {
  AOG         // Aircraft on Ground (critical)
  URGENT
  ROUTINE
  DEFERRED
}

enum WoStatus {
  OPEN
  IN_PROGRESS
  INSPECTION
  RELEASED
  DEFERRED
  CLOSED
}

enum TaskCardStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  DEFERRED
}

enum ReleaseCertType {
  EASA_FORM_1
  FAA_8130_3
  CRS
}

// ============================================
// Human Factors (ICAO / Transport Canada)
// ============================================

model HumanFactorIncident {
  id              String    @id @default(cuid())
  orgId           String?
  tenantId        String    @default("default")
  refNumber       String    @unique  // HF-YYMM-XXXX
  title           String
  description     String
  category        DirtyDozenCategory
  severity        HfSeverity @default(LOW)
  location        String?
  shift           String?
  personnelInvolved String[]
  rootCause       String?
  correctiveAction String?
  capaRef         String?
  status          HfStatus @default(REPORTED)
  reportedBy      String?
  incidentDate    DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, category])
  @@index([incidentDate])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@index([orgId])

  @@map("human_factor_incidents")
}

model FatigueAssessment {
  id              String    @id @default(cuid())
  orgId           String?
  tenantId        String    @default("default")
  personnelId     String
  personnelName   String
  assessmentDate  DateTime
  hoursWorked     Float
  restHours       Float
  fatigueScore    Int       // 1-10
  riskLevel       FatigueRisk
  mitigations     String?
  fitForDuty      Boolean   @default(true)
  notes           String?
  createdBy       String?
  createdAt       DateTime  @default(now())

  @@index([tenantId, personnelId])
  @@index([orgId])

  @@map("fatigue_assessments")
}

enum DirtyDozenCategory {
  LACK_OF_COMMUNICATION
  COMPLACENCY
  LACK_OF_KNOWLEDGE
  DISTRACTION
  LACK_OF_TEAMWORK
  FATIGUE
  LACK_OF_RESOURCES
  PRESSURE
  LACK_OF_ASSERTIVENESS
  STRESS
  LACK_OF_AWARENESS
  NORMS
}

enum HfSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum HfStatus {
  REPORTED
  INVESTIGATING
  CAPA_RAISED
  CLOSED
}

enum FatigueRisk {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

// ============================================
// OASIS SUPPLIER CERTIFICATE LOOKUP (S4-04)
// ============================================

model OasisMonitoredSupplier {
  id              String    @id @default(cuid())
  orgId           String?
  tenantId        String    @default("default")
  cageCode        String
  companyName     String
  certStandard    String?   // AS9100, AS9110, AS9120
  certBody        String?
  certExpiry      DateTime?
  lastChecked     DateTime?
  certStatus      OasisCertStatus @default(UNKNOWN)
  alerts          OasisAlert[]
  notes           String?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, cageCode])
  @@index([tenantId])
  @@index([certStatus])
  @@index([orgId])

  @@map("oasis_monitored_suppliers")
}

model OasisAlert {
  id              String    @id @default(cuid())
  orgId           String?
  supplierId      String
  alertType       OasisAlertType
  message         String
  previousStatus  String?
  newStatus       String?
  acknowledged    Boolean   @default(false)
  acknowledgedBy  String?
  acknowledgedAt  DateTime?
  createdAt       DateTime  @default(now())

  supplier        OasisMonitoredSupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([acknowledged])
  @@index([orgId])

  @@map("oasis_alerts")
}

enum OasisCertStatus {
  CURRENT
  EXPIRED
  SUSPENDED
  REVOKED
  UNKNOWN
}

enum OasisAlertType {
  CERT_EXPIRING
  CERT_EXPIRED
  CERT_SUSPENDED
  CERT_REVOKED
  STATUS_CHANGED
}

// ============================================
// AEROSPACE AUDITS (AS9100D Clause 9.2)
// ============================================

model AeroAudit {
  id              String          @id @default(cuid())
  orgId           String?
  tenantId        String          @default("default")
  refNumber       String          @unique
  title           String
  auditType       AeroAuditType   @default(INTERNAL)
  standard        String          @default("AS9100D")
  scope           String
  scheduledDate   DateTime
  actualDate      DateTime?
  leadAuditor     String
  auditTeam       String[]
  auditee         String?
  location        String?
  clauses         String[]
  objectives      String?
  status          AeroAuditStatus @default(SCHEDULED)
  summary         String?
  notes           String?
  createdBy       String?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  findings        AeroAuditFinding[]

  @@index([status])
  @@index([auditType])
  @@index([scheduledDate])
  @@index([orgId])

  @@map("aero_audits")
}

model AeroAuditFinding {
  id                  String              @id @default(cuid())
  orgId           String?
  refNumber           String              @unique
  auditId             String
  auditRefNumber      String
  findingType         AeroFindingType
  severity            AeroFindingSeverity?
  clause              String?
  description         String
  evidence            String?
  requirement         String?
  responsiblePerson   String?
  raisedBy            String?
  targetDate          DateTime?
  status              AeroFindingStatus   @default(OPEN)
  correctiveAction    String?
  closedBy            String?
  closedDate          DateTime?
  verificationEvidence String?
  createdBy           String?
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  audit               AeroAudit           @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
  @@index([status])
  @@index([findingType])
  @@index([orgId])

  @@map("aero_audit_findings")
}

enum AeroAuditType {
  INTERNAL
  EXTERNAL
  CUSTOMER
  REGULATORY
  CERTIFICATION
  SURVEILLANCE
}

enum AeroAuditStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DEFERRED
}

enum AeroFindingType {
  NONCONFORMITY
  OBSERVATION
  OPPORTUNITY_FOR_IMPROVEMENT
  POSITIVE_FINDING
}

enum AeroFindingSeverity {
  MAJOR
  MINOR
}

enum AeroFindingStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  VERIFIED
}

// ============================================
// CONFIGURATION BASELINES (AS9100D 8.1.2)
// Route: baselines.ts → prisma.aeroConfigBaseline
// ============================================

model AeroConfigBaseline {
  id                  String              @id @default(cuid())
  orgId           String?
  tenantId            String              @default("default")
  refNumber           String              @unique
  title               String
  description         String?
  program             String?
  version             String?
  baselineType        AeroBaselineType    @default(PRODUCT)
  program_phase       String?
  configuration_items String?             // JSON array
  documents           String?             // JSON array
  status              AeroBaselineStatus  @default(DRAFT)
  effectiveDate       DateTime?
  approvedBy          String?
  approvedDate        DateTime?
  notes               String?
  createdBy           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  @@index([tenantId, status])
  @@index([effectiveDate])
  @@index([createdAt])
  @@index([orgId])

  @@map("aero_config_baselines")
}

enum AeroBaselineType {
  FUNCTIONAL
  ALLOCATED
  PRODUCT
  DESIGN
}

enum AeroBaselineStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  ACTIVE
  SUPERSEDED
  ARCHIVED
}

// ============================================
// CHANGE REQUESTS (AS9100D 8.5.6)
// Route: changes.ts → prisma.aeroChangeRequest
// ============================================

model AeroChangeRequest {
  id                    String              @id @default(cuid())
  orgId           String?
  tenantId              String              @default("default")
  refNumber             String              @unique
  title                 String
  description           String
  changeType            AeroChangeType      @default(DESIGN)
  priority              AeroChangePriority  @default(MEDIUM)
  reason                String?
  affectedDocuments     String?             // JSON array
  affectedProcesses     String?             // JSON array
  affectedParts         String?             // JSON array
  customerImpact        String?
  regulatoryImpact      String?
  safetyImpact          String?
  costEstimate          Float?
  proposedBy            String?
  requestedDate         DateTime?
  status                AeroChangeStatus    @default(DRAFT)
  notes                 String?
  createdBy             String?
  submittedDate         DateTime?
  submittedBy           String?
  reviewDecision        AeroReviewDecision?
  reviewNotes           String?
  reviewedBy            String?
  reviewedDate          DateTime?
  conditions            String?
  implementationNotes   String?
  implementedBy         String?
  implementedDate       DateTime?
  verificationRequired  Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?

  @@index([tenantId, status])
  @@index([priority])
  @@index([createdAt])
  @@index([orgId])

  @@map("aero_change_requests")
}

enum AeroChangeType {
  DESIGN
  PROCESS
  MATERIAL
  SUPPLIER
  DOCUMENT
  SOFTWARE
  TOOLING
  FACILITY
  REGULATORY
  CUSTOMER_DRIVEN
  OTHER
}

enum AeroChangePriority {
  EMERGENCY
  HIGH
  MEDIUM
  LOW
}

enum AeroChangeStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTING
  IMPLEMENTED
  VERIFIED
  CLOSED
  CANCELLED
}

enum AeroReviewDecision {
  APPROVE
  REJECT
  DEFER
  REQUEST_MORE_INFO
}

// ============================================
// COMPLIANCE TRACKER (AS9100D / DO-178C)
// Route: compliance-tracker.ts → prisma.aeroComplianceItem
// ============================================

model AeroComplianceItem {
  id                  String                  @id @default(cuid())
  orgId           String?
  tenantId            String                  @default("default")
  refNumber           String                  @unique
  clause              String
  title               String
  description         String?
  standard            String                  @default("AS9100D")
  complianceStatus    AeroComplianceStatus    @default(UNDER_REVIEW)
  evidenceDocuments   String?                 // JSON array
  responsiblePerson   String?
  targetDate          DateTime?
  lastReviewDate      DateTime?
  nextReviewDate      DateTime?
  notes               String?
  createdBy           String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  deletedAt           DateTime?

  @@index([tenantId, complianceStatus])
  @@index([standard])
  @@index([createdAt])
