enum AeroComplianceStatus {
  COMPLIANT
  PARTIALLY_COMPLIANT
  NON_COMPLIANT
  NOT_APPLICABLE
  UNDER_REVIEW
}

// ============================================
// COUNTERFEIT PARTS (AS9100D 8.1.4 / AS6174)
// Route: counterfeit.ts → prisma.aeroCounterfeitReport, prisma.aeroSuspectPart
// ============================================

model AeroCounterfeitReport {
  id                      String                      @id @default(cuid())
  orgId           String?
  tenantId                String                      @default("default")
  refNumber               String                      @unique
  title                   String
  partNumber              String
  partDescription         String?
  manufacturer            String?
  supplier                String?
  poNumber                String?
  quantity                Int?
  dateDiscovered          DateTime?
  discoveredBy            String?
  discrepancyDescription  String?
  suspicionIndicators     String?                     // JSON array
  disposition             AeroCounterfeitDisposition  @default(QUARANTINE)
  status                  AeroCounterfeitStatus       @default(OPEN)
  investigationFindings   String?
  correctiveAction        String?
  reportedToGidep         Boolean                     @default(false)
  gidepReportRef          String?
  safetyImpact            String?
  notes                   String?
  createdBy               String?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  deletedAt               DateTime?

  @@index([tenantId, status])
  @@index([partNumber])
  @@index([createdAt])
  @@index([orgId])

  @@map("aero_counterfeit_reports")
}

model AeroSuspectPart {
  id              String                  @id @default(cuid())
  orgId           String?
  tenantId        String                  @default("default")
  refNumber       String                  @unique
  partNumber      String
  nomenclature    String?
  manufacturer    String?
  nsn             String?
  riskLevel       AeroSuspectRiskLevel    @default(MEDIUM)
  indicators      String?                 // JSON array
  sources         String?                 // JSON array
  notes           String?
  createdBy       String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, riskLevel])
  @@index([partNumber])
  @@index([createdAt])
  @@index([orgId])

  @@map("aero_suspect_parts")
}

enum AeroCounterfeitDisposition {
  QUARANTINE
  RETURN_TO_SUPPLIER
  DESTROY
  PENDING_INVESTIGATION
}

enum AeroCounterfeitStatus {
  OPEN
  INVESTIGATING
  CONFIRMED
  CLEARED
  CLOSED
}

enum AeroSuspectRiskLevel {
  HIGH
  MEDIUM
  LOW
}

// ============================================
// FOD PREVENTION (NAS412 / AS9146)
// Route: fod.ts → prisma.aeroFodIncident, prisma.aeroFodInspection
// ============================================

model AeroFodIncident {
  id                  String          @id @default(cuid())
  orgId           String?
  tenantId            String          @default("default")
  refNumber           String          @unique
  title               String
  description         String?
  location            String?
  area                String?
  workCenter          String?
  fodType             AeroFodType     @default(UNKNOWN)
  severity            AeroFodSeverity @default(MINOR)
  foundBy             String?
  dateFound           DateTime?
  affectedEquipment   String?
  partNumberAffected  String?
  immediateAction     String?
  rootCause           String?
  preventiveAction    String?
  safetyImpact        String?
  status              AeroFodStatus   @default(OPEN)
  closedDate          DateTime?
  closedBy            String?
  notes               String?
  createdBy           String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  @@index([tenantId, status])
  @@index([fodType])
  @@index([severity])
  @@index([createdAt])
  @@index([orgId])

  @@map("aero_fod_incidents")
}

model AeroFodInspection {
  id              String                  @id @default(cuid())
