// ============================================
// PRODUCT SAFETY (AS9100D 8.1.1)
// Route: product-safety.ts → prisma.aeroProductSafetyItem, prisma.aeroSafetyReview
// ============================================

model AeroProductSafetyItem {
  id                    String                      @id @default(cuid())
  orgId           String?
  tenantId              String                      @default("default")
  refNumber             String                      @unique
  title                 String
  description           String?
  partNumber            String?
  category              AeroPsiCategory             @default(OTHER)
  regulatoryBasis       String?
  hazardDescription     String?
  riskLevel             AeroPsiRiskLevel            @default(NEGLIGIBLE)
  mitigations           String?                     // JSON array
  verificationMethod    String?
  complianceStatus      AeroPsiComplianceStatus     @default(NOT_ASSESSED)
  status                AeroPsiStatus               @default(ACTIVE)
  responsibleEngineer   String?
  lastReviewDate        DateTime?
  nextReviewDate        DateTime?
  notes                 String?
  createdBy             String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  deletedAt             DateTime?

  @@index([tenantId, status])
  @@index([category])
  @@index([riskLevel])
  @@index([createdAt])
  @@index([orgId])

  @@map("aero_product_safety_items")
}

model AeroSafetyReview {
  id                      String                      @id @default(cuid())
  orgId           String?
  tenantId                String                      @default("default")
  refNumber               String                      @unique
  title                   String
  reviewType              AeroSafetyReviewType        @default(SYSTEM_SAFETY)
  productSafetyItemIds    String?                     // JSON array
  scope                   String?
  scheduledDate           DateTime?
  reviewTeam              String?                     // JSON array
  leadReviewer            String?
  status                  AeroSafetyReviewStatus      @default(PLANNED)
  findings                String?
  recommendations         String?
  result                  AeroSafetyReviewResult?
  completedBy             String?
  completedDate           DateTime?
  approvedBy              String?
  notes                   String?
  createdBy               String?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  deletedAt               DateTime?

  @@index([tenantId, status])
  @@index([reviewType])
  @@index([scheduledDate])
  @@index([createdAt])
  @@index([orgId])

  @@map("aero_safety_reviews")
}

enum AeroPsiCategory {
  CRITICAL_SAFETY_ITEM
  FLIGHT_SAFETY_PART
  SAFETY_OF_FLIGHT
  FRACTURE_CRITICAL
  LIFE_LIMITED
  OTHER
}

enum AeroPsiRiskLevel {
  CATASTROPHIC
  CRITICAL
  MARGINAL
  NEGLIGIBLE
}

enum AeroPsiComplianceStatus {
  COMPLIANT
  NON_COMPLIANT
  PARTIALLY_COMPLIANT
  NOT_ASSESSED
}

enum AeroPsiStatus {
  ACTIVE
  UNDER_REVIEW
  CLOSED
  SUPERSEDED
}

enum AeroSafetyReviewType {
  PRELIMINARY_HAZARD
  SYSTEM_SAFETY
  FAILURE_MODE
  FAULT_TREE
  FUNCTIONAL_HAZARD
  COMMON_CAUSE
  DESIGN_REVIEW
}

enum AeroSafetyReviewStatus {
  PLANNED
  COMPLETED
}

enum AeroSafetyReviewResult {
  APPROVED
  APPROVED_WITH_CONDITIONS
  REQUIRES_REWORK
  REJECTED
}

// ============================================
// SPECIAL PROCESSES (AS9100D 8.5.1.2 / NADCAP)
// Route: special-processes.ts → prisma.aeroSpecialProcess, prisma.aeroNadcapApproval
// ============================================

model AeroSpecialProcess {
  id                        String                      @id @default(cuid())
  orgId           String?
  tenantId                  String                      @default("default")
  refNumber                 String                      @unique
  title                     String
  description               String?
  processType               AeroProcessType             @default(OTHER)
  specification             String?
  approvalBody              AeroApprovalBody            @default(INTERNAL)
  applicableParts           String?                     // JSON array
  qualityRequirements       String?
  equipmentRequired         String?
  personnelQualifications   String?
  controlPlan               String?
  responsibleEngineer       String?
  status                    AeroSpecialProcessStatus    @default(ACTIVE)
  notes                     String?
  createdBy                 String?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  deletedAt                 DateTime?

  nadcapApprovals           AeroNadcapApproval[]

  @@index([tenantId, status])
  @@index([processType])
  @@index([createdAt])
  @@index([orgId])

  @@map("aero_special_processes")
}

model AeroNadcapApproval {
  id                  String                      @id @default(cuid())
  orgId           String?
  tenantId            String                      @default("default")
  refNumber           String                      @unique
  specialProcessId    String
  supplier            String?
  commodity           String?
  accreditationBody   String?
  certificateNumber   String?
  auditDate           DateTime?
  approvalDate        DateTime?
  expiryDate          DateTime?
  scope               String?
  limitations         String?
  approvalStatus      AeroNadcapApprovalStatus    @default(ACTIVE)
  notes               String?
  createdBy           String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  deletedAt           DateTime?

  specialProcess      AeroSpecialProcess          @relation(fields: [specialProcessId], references: [id], onDelete: Cascade)

  @@index([specialProcessId])
  @@index([approvalStatus])
  @@index([expiryDate])
  @@index([orgId])

  @@map("aero_nadcap_approvals")
}

enum AeroProcessType {
  CHEMICAL_PROCESSING
  COATINGS
  COMPOSITES
  ELASTOMERS
  HEAT_TREATING
  MATERIALS_TESTING
  NONDESTRUCTIVE_TESTING
  SHOT_PEENING
  WELDING
  BRAZING
  OTHER
}

enum AeroApprovalBody {
  NADCAP
  CUSTOMER
  INTERNAL
  OTHER
}

enum AeroSpecialProcessStatus {
  ACTIVE
  UNDER_REVIEW
  SUSPENDED
  OBSOLETE
}

enum AeroNadcapApprovalStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  SUSPENDED
  REVOKED
}

// ===== AS9100D GAP CLOSURE MODELS =====

// Clause 8.1.3 - Product/Process Risk Management
model AeroProductRisk {
  id                    String           @id @default(uuid())
  referenceNumber       String           @unique
  title                 String
  productProcess        String
  riskCategory          AeroRiskCategory
  description           String           @db.Text
  consequence           String           @db.Text
  likelihood            Int
  severity              Int
  detectability         Int
  rpn                   Int
  riskLevel             String
  mitigationPlan        String?          @db.Text
  mitigationStatus      String           @default("OPEN")
  residualLikelihood    Int?
  residualSeverity      Int?
  residualDetectability Int?
  residualRpn           Int?
  owner                 String
  targetDate            DateTime?
  closedDate            DateTime?
  status                String           @default("ACTIVE")
  flightSafety          Boolean          @default(false)
  productSafety         Boolean          @default(false)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  @@map("aero_product_risks")
}

// Clause 8.5.6 - Manufacturing Change Control
model AeroManufacturingChange {
  id                          String               @id @default(uuid())
  referenceNumber             String               @unique
  title                       String
  changeType                  AeroChangeType
  description                 String               @db.Text
  reason                      String               @db.Text
  affectedParts               String[]
  affectedProcesses           String[]
  drawingRevision             String?
  customerApprovalRequired    Boolean              @default(false)
  customerApprovalStatus      String?
  customerApprovalRef         String?
  firstArticleRequired        Boolean              @default(false)
  faiRef                      String?
  qualificationRequired       Boolean              @default(false)
  qualificationStatus         String               @default("NOT_REQUIRED")
  flightSafetyCritical        Boolean              @default(false)
  flightSafetyReviewRequired  Boolean              @default(false)
  flightSafetyReviewStatus    String?
  status                      AeroMfgChangeStatus  @default(DRAFT)
  initiatedBy                 String
  reviewedBy                  String?
  approvedBy                  String?
  approvedAt                  DateTime?
  effectiveDate               DateTime?
  implementedDate             DateTime?
  rejectionReason             String?
  verificationMethod          String?              @db.Text
  verificationStatus          String               @default("PENDING")
  verifiedBy                  String?
  verifiedAt                  DateTime?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  deletedAt                   DateTime?

  @@map("aero_manufacturing_changes")
}

// 8.5.1.2 - Nadcap Scope Verification
model AeroNadcapScope {
  id                     String    @id @default(uuid())
  supplierName           String
  supplierCode           String?
  nadcapCertRef          String
  certExpiryDate         DateTime
  issuedByPri            Boolean   @default(true)
  commodityCodes         String[]
  commodityCodesRequired String[]
  scopeGaps              String[]
  processDescription     String    @db.Text
  auditBoard             String?
  lastAuditDate          DateTime?
  nextAuditDate          DateTime?
  verifiedBy             String
  verificationDate       DateTime
  approvedBy             String?
  notes                  String?   @db.Text
  status                 String    @default("VERIFIED_COMPLIANT")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  @@map("aero_nadcap_scopes")
}

// 8.5.1.2 - Process Parameter Records
model AeroProcessParameterRecord {
  id                       String   @id @default(uuid())
  processName              String
  processNumber            String?
  partNumber               String?
  workOrderRef             String?
  specialProcessRef        String?
  operatorId               String
  operatorName             String
  processDate              DateTime
  parameters               Json
  equipmentId              String?
  equipmentLastCalibrated  DateTime?
  processConforms          Boolean  @default(true)
  nonConformanceRef        String?
  verifiedBy               String?
  notes                    String?  @db.Text
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  deletedAt                DateTime?

  @@map("aero_process_parameter_records")
}

// 8.5.1.2 - Requalification Triggers
model AeroRequalificationTrigger {
  id                           String    @id @default(uuid())
  processRef                   String
  triggerType                  String
  triggerDate                  DateTime
  description                  String    @db.Text
  requiredByDate               DateTime?
  assignedTo                   String?
  requalificationCompletedDate DateTime?
  requalificationResult        String?
  approvedBy                   String?
  notes                        String?   @db.Text
  status                       String    @default("OPEN")
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt
  deletedAt                    DateTime?

  @@map("aero_requalification_triggers")
}

