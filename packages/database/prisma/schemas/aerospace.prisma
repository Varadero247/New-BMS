  fodDescription  String?
  completedBy     String?
  completedDate   DateTime?
  status          AeroFodInspectionStatus @default(SCHEDULED)
  notes           String?
  createdBy       String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, status])
  @@index([inspectionType])
  @@index([scheduledDate])
  @@index([createdAt])
  @@index([orgId])

  @@map("aero_fod_inspections")
}

enum AeroFodType {
  METALLIC
  NON_METALLIC
  HARDWARE
  TOOLING
  UNKNOWN
}

enum AeroFodSeverity {
  CRITICAL
  MAJOR
  MINOR
}

enum AeroFodStatus {
  OPEN
  INVESTIGATING
  CORRECTIVE_ACTION
  CLOSED
  CANCELLED
}

enum AeroFodInspectionType {
  SCHEDULED
  POST_MAINTENANCE
  SHIFT_CHANGE
  SPECIAL
