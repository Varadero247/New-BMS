// ISO 42001:2023 AI Management System Schema
// Comprehensive schema for AI governance, risk management, and compliance
// Covers AI system register, risk assessments, policies, incidents, controls, impact assessments

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "../../generated/iso42001"
}

datasource db {
  provider = "postgresql"
  url      = env("ISO42001_DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum AiSystemStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  DEPRECATED
  DECOMMISSIONED
}

enum AiSystemRiskTier {
  UNACCEPTABLE
  HIGH
  LIMITED
  MINIMAL
}

enum AiSystemCategory {
  DECISION_MAKING
  CONTENT_GENERATION
  ANALYTICS
  AUTOMATION
  RECOMMENDATION
  MONITORING
  OTHER
}

enum AiRiskLikelihood {
  VERY_LOW
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum AiRiskImpact {
  NEGLIGIBLE
  MINOR
  MODERATE
  MAJOR
  SEVERE
}

enum AiRiskStatus {
  IDENTIFIED
  ASSESSED
  MITIGATED
  ACCEPTED
  CLOSED
}

enum AiRiskCategory {
  BIAS
  SAFETY
  PRIVACY
  ACCOUNTABILITY
  TRANSPARENCY
  RELIABILITY
  SECURITY
  ENVIRONMENTAL
}

enum AiPolicyStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum AiIncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AiIncidentStatus {
  REPORTED
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum AiControlStatus {
  NOT_IMPLEMENTED
  PARTIALLY_IMPLEMENTED
  IMPLEMENTED
  NOT_APPLICABLE
}

enum AiImpactLevel {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum AiImpactAssessmentStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  APPROVED
}

enum AiSelfDeclarationStatus {
  DRAFT
  PUBLISHED
  EXPIRED
}

// ============================================
// AI SYSTEM REGISTER
// ============================================

model AiSystem {
  id              String             @id @default(cuid())
  reference       String?
  name            String
  description     String?
  version         String?
  vendor          String?
  purpose         String?
  category        AiSystemCategory   @default(OTHER)
  riskTier        AiSystemRiskTier   @default(MINIMAL)
  status          AiSystemStatus     @default(DRAFT)
  owner           String?
  custodian       String?
  department      String?
  dataInputs      String[]
  dataOutputs     String[]
  dataTypes       String?
  userBase        String?
  notes           String?
  deploymentDate  DateTime?
  lastReviewDate  DateTime?
  nextReviewDate  DateTime?

  organisationId  String
  createdBy       String
  updatedBy       String?
  deletedBy       String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  risks             AiRiskAssessment[]
  incidents         AiIncident[]
  impactAssessments AiImpactAssessment[]

  @@map("ai_systems")
  @@index([organisationId, deletedAt])
  @@index([status])
  @@index([riskTier])
  @@index([category])
  @@index([deletedAt])
}

// ============================================
// AI RISK ASSESSMENTS
// ============================================

model AiRiskAssessment {
  id                  String           @id @default(cuid())
  reference           String?
  systemId            String
  system              AiSystem         @relation(fields: [systemId], references: [id])
  title               String
  description         String?
  category            AiRiskCategory   @default(BIAS)
  likelihood          AiRiskLikelihood @default(MEDIUM)
  impact              AiRiskImpact     @default(MODERATE)
  riskScore           Int              @default(0)
  riskLevel           String?
  status              AiRiskStatus     @default(IDENTIFIED)
  mitigationPlan      String?
  residualRisk        String?
  existingControls    String?
  proposedMitigations String?
  owner               String?
  riskOwner           String?
  reviewDate          DateTime?
  notes               String?

  organisationId  String
  createdBy       String
  updatedBy       String?
  deletedBy       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  @@map("ai_risk_assessments")
  @@index([organisationId, deletedAt])
  @@index([systemId])
  @@index([status])
  @@index([category])
  @@index([riskScore])
  @@index([deletedAt])
}

// ============================================
// AI GOVERNANCE POLICIES
// ============================================

model AiPolicy {
  id              String          @id @default(cuid())
  reference       String?
  title           String
  description     String?
  summary         String?
  scope           String?
  content         String
  version         String          @default("1.0")
  status          AiPolicyStatus  @default(DRAFT)
  approvedBy      String?
  approvedAt      DateTime?
  effectiveDate   DateTime?
  reviewDate      DateTime?
  policyType      String          // AI_ETHICS, AI_GOVERNANCE, HUMAN_OVERSIGHT, DATA_GOVERNANCE, TRANSPARENCY
  owner           String?
  department      String?
  notes           String?

  organisationId  String
  createdBy       String
  updatedBy       String?
  deletedBy       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@map("ai_policies")
  @@index([organisationId, deletedAt])
  @@index([status])
  @@index([policyType])
  @@index([deletedAt])
}

// ============================================
// AI INCIDENT LOG
// ============================================

model AiIncident {
  id                      String              @id @default(cuid())
  reference               String?
  systemId                String
  system                  AiSystem            @relation(fields: [systemId], references: [id])
  title                   String
  description             String?
  severity                AiIncidentSeverity  @default(LOW)
  status                  AiIncidentStatus    @default(REPORTED)
  incidentDate            DateTime
  reportedBy              String?
  category                String?
  affectedParties         String?
  immediateAction         String?
  notes                   String?
  rootCause               String?
  findings                String?
  contributingFactors     String?
  investigator            String?
  investigationStartedAt  DateTime?
  resolution              String?
  resolvedAt              DateTime?
  lessonsLearned          String?
  preventiveActions       String?
  closedAt                DateTime?
  closedBy                String?

  organisationId  String
  createdBy       String
  updatedBy       String?
  deletedBy       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  @@map("ai_incidents")
  @@index([organisationId, deletedAt])
  @@index([systemId])
  @@index([severity])
  @@index([status])
  @@index([incidentDate])
  @@index([deletedAt])
}

// ============================================
// ISO 42001 ANNEX A CONTROLS
// ============================================

model AiControl {
  id                  String          @id @default(cuid())
  code                String          @unique
  title               String
  description         String?
  domain              String          // AI_GOVERNANCE, AI_RISK, AI_DEVELOPMENT, AI_DATA, AI_MONITORING
  status              AiControlStatus @default(NOT_IMPLEMENTED)
  implementationStatus String?
  justification       String?
  implementationNotes String?
  evidence            String?
  evidenceLinks       String[]
  owner               String?
  responsiblePerson   String?
  targetDate          DateTime?
  completionDate      DateTime?

  organisationId      String
  createdBy           String
  updatedBy           String?
  deletedBy           String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  @@map("ai_controls")
  @@index([organisationId, deletedAt])
  @@index([domain])
  @@index([status])
  @@index([code])
  @@index([deletedAt])
}

// ============================================
// EU AI ACT IMPACT ASSESSMENTS
// ============================================

model AiImpactAssessment {
  id                      String                    @id @default(cuid())
  reference               String?
  systemId                String
  system                  AiSystem                  @relation(fields: [systemId], references: [id])
  title                   String
  description             String?
  impactLevel             AiImpactLevel             @default(LOW)
  assessmentType          String?
  scope                   String?
  methodology             String?
  findings                String?
  humanRightsImpact       String?
  safetyImpact            String?
  privacyImpact           String?
  biasAssessment          String?
  transparencyAssessment  String?
  environmentalImpact     String?
  socialImpact            String?
  economicImpact          String?
  mitigationMeasures      String?
  residualRisk            String?
  assessor                String?
  reviewDate              DateTime?
  notes                   String?
  approvedBy              String?
  approvedAt              DateTime?
  status                  AiImpactAssessmentStatus  @default(DRAFT)

  organisationId          String
  createdBy               String
  updatedBy               String?
  deletedBy               String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  deletedAt               DateTime?

  @@map("ai_impact_assessments")
  @@index([organisationId, deletedAt])
  @@index([systemId])
  @@index([status])
  @@index([impactLevel])
  @@index([deletedAt])
}

// ============================================
// RESOLVEX ISO 42001 SELF-DECLARATION
// ============================================

model AiSelfDeclaration {
  id                    String                    @id @default(cuid())
  reference             String?
  title                 String
  standard              String                    @default("ISO 42001:2023")
  declarationDate       DateTime
  validUntil            DateTime?
  scope                 String
  conformanceStatement  String
  signedBy              String?
  status                AiSelfDeclarationStatus   @default(DRAFT)
  publishedAt           DateTime?
  exclusions            String?
  supportingEvidence    String?
  notes                 String?

  organisationId        String
  createdBy             String
  updatedBy             String?
  deletedBy             String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  deletedAt             DateTime?

  @@map("ai_self_declarations")
  @@index([organisationId, deletedAt])
  @@index([status])
  @@index([standard])
  @@index([deletedAt])
}

// ============================================
// AI AUDIT LOG — automatic decision logging
// ============================================

enum AiAuditAction {
  DECISION
  OVERRIDE
  REVIEW
  APPROVAL
  REJECTION
  ESCALATION
  CONFIG_CHANGE
}

model AiAuditLog {
  id              String          @id @default(cuid())
  systemId        String?
  action          AiAuditAction
  description     String
  inputSummary    String?
  outputSummary   String?
  userId          String
  userName        String?
  ipAddress       String?
  metadata        Json?
  riskScore       Int?

  organisationId  String
  createdAt       DateTime        @default(now())

  @@map("ai_audit_logs")
  @@index([organisationId])
  @@index([systemId])
  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// HUMAN REVIEW GATE — approval workflow for AI decisions
// ============================================

enum HumanReviewStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  EXPIRED
}

model AiHumanReview {
  id              String            @id @default(cuid())
  systemId        String
  title           String
  description     String?
  aiDecision      String
  aiConfidence    Float?
  aiReasoning     String?
  reviewerUserId  String?
  reviewerName    String?
  status          HumanReviewStatus @default(PENDING)
  decision        String?
  justification   String?
  reviewedAt      DateTime?
  expiresAt       DateTime?
  metadata        Json?

  organisationId  String
  createdBy       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  @@map("ai_human_reviews")
  @@index([organisationId, deletedAt])
  @@index([systemId])
  @@index([status])
  @@index([reviewerUserId])
  @@index([expiresAt])
  @@index([deletedAt])
}

// ============================================
// AI SYSTEM MONITORING (ISO 42001 §9.1)
// ============================================

enum AiMonitoringStatus {
  NORMAL
  WARNING
  ALERT
  CRITICAL
  RESOLVED
}

enum AiMonitoringMetricType {
  PERFORMANCE
  ACCURACY
  BIAS
  DRIFT
  AVAILABILITY
  LATENCY
  ERROR_RATE
  USAGE
  SAFETY
  COMPLIANCE
  OTHER
}

model AiMonitoring {
  id              String                 @id @default(cuid())
  systemId        String
  metricType      AiMonitoringMetricType @default(PERFORMANCE)
  metricName      String
  description     String?
  value           Float?
  unit            String?
  threshold       Float?
  thresholdType   String?
  status          AiMonitoringStatus     @default(NORMAL)
  isoClause       String?
  measuredBy      String?
  measurementDate DateTime               @default(now())
  notes           String?
  alertSent       Boolean                @default(false)
  resolvedAt      DateTime?
  resolvedBy      String?
  resolutionNotes String?
  metadata        Json?

  organisationId  String
  createdBy       String
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  deletedAt       DateTime?

  @@map("ai_monitoring")
  @@index([organisationId, deletedAt])
  @@index([systemId])
  @@index([status])
  @@index([metricType])
  @@index([measurementDate])
  @@index([deletedAt])
}
