// Finance Schema - Double-Entry Bookkeeping & Accounting
// Comprehensive schema for Finance & Accounting module (Phase 1)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "../../generated/finance"
}

datasource db {
  provider = "postgresql"
  url      = env("FINANCE_DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum FinAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum FinNormalBalance {
  DEBIT
  CREDIT
}

enum FinJournalStatus {
  DRAFT
  POSTED
  REVERSED
  VOID
}

enum FinInvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  CANCELLED
}

enum FinPOStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  CLOSED
}

enum FinBillStatus {
  DRAFT
  RECEIVED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  CANCELLED
}

enum FinPaymentMethod {
  BANK_TRANSFER
  CHEQUE
  CASH
  CREDIT_CARD
  DIRECT_DEBIT
  STANDING_ORDER
  OTHER
}

enum FinBankAccountType {
  CURRENT
  SAVINGS
  CREDIT_CARD
  LOAN
  MERCHANT
  OTHER
}

enum FinTaxJurisdiction {
  UK_VAT
  US_SALES
  EU_VAT
  CANADA_GST
  AUSTRALIA_GST
  OTHER
}

enum FinTaxReturnStatus {
  DRAFT
  CALCULATED
  SUBMITTED
  ACCEPTED
  REJECTED
  AMENDED
}

enum FinPeriodStatus {
  OPEN
  CLOSING
  CLOSED
  LOCKED
}

enum FinIntegrationProvider {
  XERO
  QUICKBOOKS
  SAGE
  STRIPE
  PAYPAL
  BANK_FEED
  CUSTOM
}

enum FinSyncDirection {
  INBOUND
  OUTBOUND
  BIDIRECTIONAL
}

enum FinSyncStatus {
  SUCCESS
  FAILED
  PARTIAL
  PENDING
}

enum FinReconciliationStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum FinCreditNoteStatus {
  DRAFT
  APPLIED
  REFUNDED
  VOID
}

// ============================================
// CHART OF ACCOUNTS
// ============================================

model FinAccount {
  id            String           @id @default(uuid())
  code          String           @unique
  name          String
  description   String?
  type          FinAccountType
  normalBalance FinNormalBalance
  parentId      String?
  parent        FinAccount?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      FinAccount[]     @relation("AccountHierarchy")
  isActive      Boolean          @default(true)
  isSystem      Boolean          @default(false)
  taxRateId     String?
  taxRate       FinTaxRate?      @relation(fields: [taxRateId], references: [id])
  currency      String           @default("GBP")
  openingBalance Decimal         @default(0) @db.Decimal(14, 2)
  createdBy     String
  updatedBy     String?
  deletedBy     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  journalLines  FinJournalLine[]
  budgets       FinBudget[]

  @@map("fin_accounts")
  @@index([type])
  @@index([parentId])
  @@index([code])
  @@index([deletedAt])
}

// ============================================
// GENERAL LEDGER / JOURNAL
// ============================================

model FinJournalEntry {
  id            String           @id @default(uuid())
  reference     String           @unique
  date          DateTime
  description   String
  status        FinJournalStatus @default(DRAFT)
  periodId      String
  period        FinPeriod        @relation(fields: [periodId], references: [id])
  isAutoGenerated Boolean        @default(false)
  sourceType    String?
  sourceId      String?
  notes         String?
  reversalOf    String?
  createdBy     String
  approvedBy    String?
  approvedAt    DateTime?
  postedAt      DateTime?
  postedBy      String?
  reversedBy    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  lines         FinJournalLine[]

  @@map("fin_journal_entries")
  @@index([date])
  @@index([status])
  @@index([periodId])
  @@index([reference])
  @@index([deletedAt])
}

model FinJournalLine {
  id            String          @id @default(uuid())
  journalId     String
  journal       FinJournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  accountId     String
  account       FinAccount      @relation(fields: [accountId], references: [id])
  description   String?
  debit         Decimal         @default(0) @db.Decimal(14, 2)
  credit        Decimal         @default(0) @db.Decimal(14, 2)
  taxRateId     String?
  taxAmount     Decimal         @default(0) @db.Decimal(14, 2)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("fin_journal_lines")
  @@index([journalId])
  @@index([accountId])
}

// ============================================
// ACCOUNTING PERIODS
// ============================================

model FinPeriod {
  id            String          @id @default(uuid())
  name          String
  startDate     DateTime
  endDate       DateTime
  status        FinPeriodStatus @default(OPEN)
  fiscalYear    Int
  quarter       Int?
  closedBy      String?
  closedAt      DateTime?
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  journalEntries FinJournalEntry[]

  @@map("fin_periods")
  @@unique([fiscalYear, name])
  @@index([status])
  @@index([fiscalYear])
}

// ============================================
// ACCOUNTS RECEIVABLE
// ============================================

model FinCustomer {
  id            String          @id @default(uuid())
  code          String          @unique
  name          String
  email         String?
  phone         String?
  contactPerson String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  region        String?
  postalCode    String?
  country       String          @default("GB")
  taxNumber     String?
  currency      String          @default("GBP")
  paymentTerms  Int             @default(30)
  creditLimit   Decimal?        @db.Decimal(14, 2)
  isActive      Boolean         @default(true)
  notes         String?
  createdBy     String
  updatedById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  invoices      FinInvoice[]
  payments      FinPaymentReceived[]
  creditNotes   FinCreditNote[]

  @@map("fin_customers")
  @@index([code])
  @@index([name])
  @@index([deletedAt])
}

model FinInvoice {
  id            String           @id @default(uuid())
  reference     String           @unique
  customerId    String
  customer      FinCustomer      @relation(fields: [customerId], references: [id])
  issueDate     DateTime
  dueDate       DateTime
  status        FinInvoiceStatus @default(DRAFT)
  subtotal      Decimal          @default(0) @db.Decimal(14, 2)
  taxTotal      Decimal          @default(0) @db.Decimal(14, 2)
  total         Decimal          @default(0) @db.Decimal(14, 2)
  amountPaid    Decimal          @default(0) @db.Decimal(14, 2)
  amountDue     Decimal          @default(0) @db.Decimal(14, 2)
  currency      String           @default("GBP")
  notes         String?
  termsAndConditions String?
  sentAt        DateTime?
  paidAt        DateTime?
  voidedAt      DateTime?
  voidReason    String?
  journalEntryId String?
  createdBy     String
  updatedById   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  lines         FinInvoiceLine[]
  payments      FinPaymentReceived[]

  @@map("fin_invoices")
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([reference])
  @@index([deletedAt])
}

model FinInvoiceLine {
  id            String     @id @default(uuid())
  invoiceId     String
  invoice       FinInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description   String
  quantity      Decimal    @default(1) @db.Decimal(10, 2)
  unitPrice     Decimal    @db.Decimal(14, 2)
  amount        Decimal    @db.Decimal(14, 2)
  taxRateId     String?
  taxAmount     Decimal    @default(0) @db.Decimal(14, 2)
  accountId     String?
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("fin_invoice_lines")
  @@index([invoiceId])
}

model FinPaymentReceived {
  id            String           @id @default(uuid())
  reference     String           @unique
  customerId    String
  customer      FinCustomer      @relation(fields: [customerId], references: [id])
  invoiceId     String?
  invoice       FinInvoice?      @relation(fields: [invoiceId], references: [id])
  date          DateTime
  amount        Decimal          @db.Decimal(14, 2)
  method        FinPaymentMethod
  bankAccountId String?
  bankAccount   FinBankAccount?  @relation(fields: [bankAccountId], references: [id])
  notes         String?
  journalEntryId String?
  createdBy     String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  @@map("fin_payments_received")
  @@index([customerId])
  @@index([invoiceId])
  @@index([date])
  @@index([deletedAt])
}

model FinCreditNote {
  id            String             @id @default(uuid())
  reference     String             @unique
  customerId    String
  customer      FinCustomer        @relation(fields: [customerId], references: [id])
  date          DateTime
  amount        Decimal            @db.Decimal(14, 2)
  reason        String
  status        FinCreditNoteStatus @default(DRAFT)
  invoiceId     String?
  journalEntryId String?
  createdBy     String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  @@map("fin_credit_notes")
  @@index([customerId])
  @@index([status])
  @@index([deletedAt])
}

// ============================================
// ACCOUNTS PAYABLE
// ============================================

model FinSupplier {
  id            String          @id @default(uuid())
  code          String          @unique
  name          String
  email         String?
  phone         String?
  contactPerson String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  region        String?
  postalCode    String?
  country       String          @default("GB")
  taxNumber     String?
  currency      String          @default("GBP")
  paymentTerms  Int             @default(30)
  isActive      Boolean         @default(true)
  notes         String?
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  purchaseOrders FinPurchaseOrder[]
  bills         FinBill[]
  payments      FinPaymentMade[]

  @@map("fin_suppliers")
  @@index([code])
  @@index([name])
  @@index([deletedAt])
}

model FinPurchaseOrder {
  id            String       @id @default(uuid())
  reference     String       @unique
  supplierId    String
  supplier      FinSupplier  @relation(fields: [supplierId], references: [id])
  orderDate     DateTime
  expectedDate  DateTime?
  status        FinPOStatus  @default(DRAFT)
  subtotal      Decimal      @default(0) @db.Decimal(14, 2)
  taxTotal      Decimal      @default(0) @db.Decimal(14, 2)
  total         Decimal      @default(0) @db.Decimal(14, 2)
  currency      String       @default("GBP")
  notes         String?
  approvedBy    String?
  approvedAt    DateTime?
  receivedAt    DateTime?
  createdBy     String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  lines         FinPOLine[]
  bills         FinBill[]

  @@map("fin_purchase_orders")
  @@index([supplierId])
  @@index([status])
  @@index([reference])
  @@index([deletedAt])
}

model FinPOLine {
  id            String          @id @default(uuid())
  purchaseOrderId String
  purchaseOrder FinPurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  description   String
  quantity      Decimal         @default(1) @db.Decimal(10, 2)
  unitPrice     Decimal         @db.Decimal(14, 2)
  amount        Decimal         @db.Decimal(14, 2)
  taxRateId     String?
  taxAmount     Decimal         @default(0) @db.Decimal(14, 2)
  receivedQty   Decimal         @default(0) @db.Decimal(10, 2)
  accountId     String?
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("fin_po_lines")
  @@index([purchaseOrderId])
}

model FinBill {
  id              String       @id @default(uuid())
  reference       String       @unique
  supplierId      String
  supplier        FinSupplier  @relation(fields: [supplierId], references: [id])
  purchaseOrderId String?
  purchaseOrder   FinPurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  billDate        DateTime
  dueDate         DateTime
  status          FinBillStatus @default(DRAFT)
  subtotal        Decimal      @default(0) @db.Decimal(14, 2)
  taxTotal        Decimal      @default(0) @db.Decimal(14, 2)
  total           Decimal      @default(0) @db.Decimal(14, 2)
  amountPaid      Decimal      @default(0) @db.Decimal(14, 2)
  amountDue       Decimal      @default(0) @db.Decimal(14, 2)
  currency        String       @default("GBP")
  supplierRef     String?
  notes           String?
  journalEntryId  String?
  createdBy       String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  lines           FinBillLine[]
  payments        FinPaymentMade[]

  @@map("fin_bills")
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
}

model FinBillLine {
  id            String   @id @default(uuid())
  billId        String
  bill          FinBill  @relation(fields: [billId], references: [id], onDelete: Cascade)
  description   String
  quantity      Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice     Decimal  @db.Decimal(14, 2)
  amount        Decimal  @db.Decimal(14, 2)
  taxRateId     String?
  taxAmount     Decimal  @default(0) @db.Decimal(14, 2)
  accountId     String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("fin_bill_lines")
  @@index([billId])
}

model FinPaymentMade {
  id            String           @id @default(uuid())
  reference     String           @unique
  supplierId    String
  supplier      FinSupplier      @relation(fields: [supplierId], references: [id])
  billId        String?
  bill          FinBill?         @relation(fields: [billId], references: [id])
  date          DateTime
  amount        Decimal          @db.Decimal(14, 2)
  method        FinPaymentMethod
  bankAccountId String?
  bankAccount   FinBankAccount?  @relation(fields: [bankAccountId], references: [id])
  notes         String?
  journalEntryId String?
  createdBy     String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  @@map("fin_payments_made")
  @@index([supplierId])
  @@index([billId])
  @@index([date])
  @@index([deletedAt])
}

// ============================================
// BANKING
// ============================================

model FinBankAccount {
  id            String            @id @default(uuid())
  name          String
  accountNumber String?
  sortCode      String?
  iban          String?
  swift         String?
  type          FinBankAccountType @default(CURRENT)
  currency      String            @default("GBP")
  currentBalance Decimal          @default(0) @db.Decimal(14, 2)
  accountId     String?
  isActive      Boolean           @default(true)
  bankName      String?
  lastReconciledDate DateTime?
  createdBy     String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  transactions  FinBankTransaction[]
  reconciliations FinReconciliation[]
  paymentsReceived FinPaymentReceived[]
  paymentsMade  FinPaymentMade[]

  @@map("fin_bank_accounts")
  @@index([type])
  @@index([deletedAt])
}

model FinBankTransaction {
  id            String         @id @default(uuid())
  bankAccountId String
  bankAccount   FinBankAccount @relation(fields: [bankAccountId], references: [id])
  date          DateTime
  description   String
  reference     String?
  amount        Decimal        @db.Decimal(14, 2)
  runningBalance Decimal?      @db.Decimal(14, 2)
  isReconciled  Boolean        @default(false)
  reconciliationId String?
  reconciliation FinReconciliation? @relation(fields: [reconciliationId], references: [id])
  journalEntryId String?
  sourceType    String?
  sourceId      String?
  importedAt    DateTime?
  createdBy     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("fin_bank_transactions")
  @@index([bankAccountId])
  @@index([date])
  @@index([isReconciled])
}

model FinReconciliation {
  id            String                  @id @default(uuid())
  bankAccountId String
  bankAccount   FinBankAccount          @relation(fields: [bankAccountId], references: [id])
  startDate     DateTime
  endDate       DateTime
  openingBalance Decimal                @db.Decimal(14, 2)
  closingBalance Decimal                @db.Decimal(14, 2)
  status        FinReconciliationStatus @default(IN_PROGRESS)
  completedAt   DateTime?
  completedBy   String?
  createdBy     String
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  transactions  FinBankTransaction[]

  @@map("fin_reconciliations")
  @@index([bankAccountId])
  @@index([status])
}

// ============================================
// TAX
// ============================================

model FinTaxRate {
  id            String             @id @default(uuid())
  name          String
  code          String             @unique
  rate          Decimal            @db.Decimal(5, 2)
  jurisdiction  FinTaxJurisdiction @default(UK_VAT)
  isActive      Boolean            @default(true)
  isDefault     Boolean            @default(false)
  description   String?
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdBy     String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  accounts      FinAccount[]
  taxReturns    FinTaxReturn[]

  @@map("fin_tax_rates")
  @@index([jurisdiction])
  @@index([code])
  @@index([deletedAt])
}

model FinTaxReturn {
  id            String             @id @default(uuid())
  reference     String             @unique
  taxRateId     String
  taxRate       FinTaxRate         @relation(fields: [taxRateId], references: [id])
  periodStart   DateTime
  periodEnd     DateTime
  status        FinTaxReturnStatus @default(DRAFT)
  salesTax      Decimal            @default(0) @db.Decimal(14, 2)
  purchaseTax   Decimal            @default(0) @db.Decimal(14, 2)
  netTax        Decimal            @default(0) @db.Decimal(14, 2)
  submittedAt   DateTime?
  submittedBy   String?
  notes         String?
  createdBy     String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  @@map("fin_tax_returns")
  @@index([taxRateId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([deletedAt])
}

// ============================================
// BUDGETS
// ============================================

model FinBudget {
  id            String   @id @default(uuid())
  name          String
  accountId     String
  account       FinAccount @relation(fields: [accountId], references: [id])
  fiscalYear    Int
  month         Int?
  quarter       Int?
  budgetAmount  Decimal  @db.Decimal(14, 2)
  actualAmount  Decimal  @default(0) @db.Decimal(14, 2)
  variance      Decimal  @default(0) @db.Decimal(14, 2)
  notes         String?
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@map("fin_budgets")
  @@index([accountId])
  @@index([fiscalYear])
  @@unique([accountId, fiscalYear, month])
  @@index([deletedAt])
}

// ============================================
// INTEGRATIONS
// ============================================

model FinIntegration {
  id            String                 @id @default(uuid())
  provider      FinIntegrationProvider
  name          String
  isActive      Boolean                @default(false)
  direction     FinSyncDirection       @default(BIDIRECTIONAL)
  lastSyncAt    DateTime?
  config        Json?
  createdBy     String
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  syncLogs      FinSyncLog[]

  @@map("fin_integrations")
  @@index([provider])
}

model FinSyncLog {
  id            String           @id @default(uuid())
  integrationId String
  integration   FinIntegration   @relation(fields: [integrationId], references: [id])
  direction     FinSyncDirection
  status        FinSyncStatus    @default(PENDING)
  recordsProcessed Int           @default(0)
  recordsFailed Int              @default(0)
  errorMessage  String?
  startedAt     DateTime         @default(now())
  completedAt   DateTime?
  createdAt     DateTime         @default(now())

  @@map("fin_sync_logs")
  @@index([integrationId])
  @@index([status])
}

// ============================================
// M8: Financial Compliance Models
// ============================================

enum FinControlStatus {
  ACTIVE
  INACTIVE
  UNDER_REVIEW
  REMEDIATION
}

enum FinIr35Determination {
  INSIDE
  OUTSIDE
  PENDING
}

model FinControl {
  id              String           @id @default(cuid())
  orgId           String
  referenceNumber String           @unique
  title           String
  description     String?
  controlType     String?
  riskArea        String?
  owner           String?
  ownerName       String?
  status          FinControlStatus @default(ACTIVE)
  frequency       String?
  lastTestedDate  DateTime?
  nextTestDate    DateTime?
  testResult      String?
  evidence        String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       String?
  updatedBy       String?
  deletedAt       DateTime?
  @@map("fin_controls")
  @@index([orgId])
  @@index([status])
  @@index([deletedAt])
}

model FinSodRule {
  id              String   @id @default(cuid())
  orgId           String
  role1           String
  role2           String
  conflictType    String?
  description     String?
  mitigatingControl String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  deletedAt       DateTime?
  @@map("fin_sod_rules")
  @@index([orgId])
  @@index([deletedAt])
}

model FinHmrcDeadline {
  id           String    @id @default(cuid())
  orgId        String
  title        String
  description  String?
  type         String?
  dueDate      DateTime
  filingRef    String?
  status       String    @default("PENDING")
  submittedDate DateTime?
  submittedBy  String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  deletedAt    DateTime?
  @@map("fin_hmrc_deadlines")
  @@index([orgId])
  @@index([dueDate])
  @@index([deletedAt])
}

model FinIr35Assessment {
  id              String              @id @default(cuid())
  orgId           String
  referenceNumber String              @unique
  contractorName  String
  contractorEmail String?
  engagementDesc  String?
  clientName      String?
  determination   FinIr35Determination @default(PENDING)
  assessmentDate  DateTime?
  assessedBy      String?
  reasoning       String?
  evidenceUrl     String?
  reviewDate      DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  createdBy       String?
  updatedBy       String?
  deletedAt       DateTime?
  @@map("fin_ir35_assessments")
  @@index([orgId])
  @@index([deletedAt])
}
