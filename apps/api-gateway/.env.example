# Database
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/ims?schema=public"

# API Gateway
PORT=4000
NODE_ENV=development

# JWT (must match across all services)
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# Redis (rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=CHANGE_ME

# CORS
# CORS_ORIGIN=http://localhost:3000

# CORS allowed origins (comma-separated, defaults to localhost:3000-3045)
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# CSRF (disable only for local development)
CSRF_ENABLED=true

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
